<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource Brush.Background}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
    <Setter Property="FontSize" Value="{DynamicResource FontSize.Body}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
  </Style>

  <Style Selector="TextBlock.title">
    <Setter Property="FontSize" Value="{DynamicResource FontSize.Title}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.hero">
    <Setter Property="FontSize" Value="{DynamicResource FontSize.Hero}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundMuted}" />
  </Style>

   <Style Selector="Border.banner">
     <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
     <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
     <Setter Property="BorderThickness" Value="1" />
     <Setter Property="CornerRadius" Value="10" />
   </Style>

    <Style Selector="Border.recent-file-item">
      <Setter Property="Padding" Value="10" />
      <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="Button.recent-file-button">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Button.recent-file-button:pointerover /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.92" />
    </Style>

    <Style Selector="Button.thumbnail-button">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Border.thumbnail-item">
      <Setter Property="Padding" Value="10" />
      <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style Selector="Button.thumbnail-button:pointerover Border.thumbnail-item">
      <Setter Property="Opacity" Value="0.92" />
    </Style>

    <Style Selector="Border.thumbnail-image-host">
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="Border.thumbnail-item:selected">
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
</Styles>
