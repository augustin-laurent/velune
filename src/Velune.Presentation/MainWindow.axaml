<Window
    x:Class="Velune.Presentation.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="1200"
    Height="800"
    MinWidth="900"
    MinHeight="600"
    Title="{Binding Title}">

  <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="260,*">

    <!-- Header -->
    <Border Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="16,12"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,0,1"
            Background="{DynamicResource Brush.Surface}">
      <DockPanel LastChildFill="False">
        <TextBlock Text="{Binding ApplicationTitle}"
                   Classes="title"
                   VerticalAlignment="Center" />

        <StackPanel Orientation="Horizontal"
                    Spacing="8"
                    DockPanel.Dock="Right">
          <Button Content="Open" Command="{Binding OpenCommand}" />
          <Button Content="Close" Command="{Binding CloseCommand}" />
          <Button Content="Zoom In" Command="{Binding ZoomInCommand}" />
          <Button Content="Zoom Out" Command="{Binding ZoomOutCommand}" />
          <Button Content="Rotate Left" Command="{Binding RotateLeftCommand}" />
          <Button Content="Rotate Right" Command="{Binding RotateRightCommand}" />
          <Button Content="Simulate Error" Command="{Binding SimulateErrorCommand}" />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Sidebar -->
    <Border Grid.Row="1"
            Grid.Column="0"
            Padding="12"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,1,0"
            Background="{DynamicResource Brush.Surface}">
      <StackPanel Spacing="8">
        <TextBlock Text="{Binding SidebarTitle}"
                   Classes="title" />

        <Border Classes="card"
                Padding="12"
                Background="{DynamicResource Brush.SurfaceMuted}">
          <TextBlock Text="Thumbnails will appear here."
                     Classes="muted" />
        </Border>
      </StackPanel>
    </Border>

    <!-- Main content -->
    <Grid Grid.Row="1"
          Grid.Column="1"
          Background="{DynamicResource Brush.Background}">

      <!-- Toast -->
      <Border Classes="banner"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="16"
              Padding="12,10"
              MinWidth="320"
              MaxWidth="420"
              ZIndex="10"
              IsVisible="{Binding HasUserMessage}">
        <DockPanel LastChildFill="True">
          <Button Content="Dismiss"
                  DockPanel.Dock="Right"
                  Command="{Binding DismissMessageCommand}" />

          <TextBlock Text="{Binding UserMessage}"
                     Classes="muted"
                     VerticalAlignment="Center"
                     Margin="0,0,12,0"
                     TextWrapping="Wrap" />
        </DockPanel>
      </Border>

      <!-- Empty state -->
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="16"
                  MaxWidth="420"
                  IsVisible="{Binding IsEmptyStateVisible}">
        <Border Classes="card"
                Padding="20"
                HorizontalAlignment="Center">
          <TextBlock Text="📄"
                     FontSize="40"
                     HorizontalAlignment="Center" />
        </Border>

        <TextBlock Text="{Binding EmptyStateTitle}"
                   Classes="hero"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />

        <TextBlock Text="{Binding EmptyStateDescription}"
                   Classes="muted"
                   FontSize="{DynamicResource FontSize.BodyLarge}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8">
          <Button Content="Open a file"
                  Width="140"
                  Command="{Binding OpenCommand}" />
          <Button Content="Simulate error"
                  Width="140"
                  Command="{Binding SimulateErrorCommand}" />
        </StackPanel>
      </StackPanel>

      <!-- Document info state -->
      <Border Classes="card"
              Margin="24"
              Padding="24"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="520"
              IsVisible="{Binding HasDocumentInfo}">
        <StackPanel Spacing="12">
          <TextBlock Text="Document session created"
                     Classes="hero"
                     TextAlignment="Center"
                     HorizontalAlignment="Center" />

          <TextBlock Text="{Binding CurrentDocumentName}"
                     Classes="title"
                     TextAlignment="Center"
                     HorizontalAlignment="Center" />

          <Grid ColumnDefinitions="Auto,*"
                RowDefinitions="Auto,Auto,Auto,Auto"
                Margin="0,8,0,0">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Type:" Classes="muted" Margin="0,0,12,8" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentDocumentType}" Margin="0,0,0,8" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Path:" Classes="muted" Margin="0,0,12,8" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentDocumentPath}" TextWrapping="Wrap" Margin="0,0,0,8" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Page:" Classes="muted" Margin="0,0,12,8" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentPage}" Margin="0,0,0,8" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Viewport:" Classes="muted" Margin="0,0,12,0" />
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CurrentZoom}" />
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="12,8"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,1,0,0"
            Background="{DynamicResource Brush.Surface}">
      <TextBlock Text="{Binding StatusText}"
                 Classes="muted" />
    </Border>
  </Grid>
</Window>
