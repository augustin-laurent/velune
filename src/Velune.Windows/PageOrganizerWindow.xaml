<Window
    x:Class="Velune.Windows.PageOrganizerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:Velune.Windows.Services"
    xmlns:vm="using:Velune.Windows.ViewModels"
    Title="{x:Bind ViewModel.WindowTitle}">

  <Window.SystemBackdrop>
    <MicaBackdrop />
  </Window.SystemBackdrop>

  <Grid x:Name="Root"
        Background="Transparent"
        Padding="0">

    <Grid.Resources>
      <ResourceDictionary>
        <services:BoolToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="SubtleButtonStyle" TargetType="Button">
          <Setter Property="Width" Value="36" />
          <Setter Property="Height" Value="36" />
          <Setter Property="MinWidth" Value="36" />
          <Setter Property="Padding" Value="0" />
          <Setter Property="CornerRadius" Value="{StaticResource MediumCornerRadius}" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
        </Style>

        <Style x:Key="ChipButtonStyle" TargetType="Button">
          <Setter Property="Height" Value="26" />
          <Setter Property="MinWidth" Value="36" />
          <Setter Property="Padding" Value="10,0" />
          <Setter Property="CornerRadius" Value="{StaticResource PillCornerRadius}" />
          <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
          <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
          <Setter Property="FontSize" Value="12" />
        </Style>
      </ResourceDictionary>
    </Grid.Resources>

    <Grid.KeyboardAccelerators>
      <KeyboardAccelerator Key="A" Modifiers="Control" Invoked="OnSelectAllAccelerator" />
      <KeyboardAccelerator Key="Z" Modifiers="Control" Invoked="OnUndoAccelerator" />
      <KeyboardAccelerator Key="Y" Modifiers="Control" Invoked="OnRedoAccelerator" />
      <KeyboardAccelerator Key="D" Modifiers="Control" Invoked="OnDuplicateAccelerator" />
      <KeyboardAccelerator Key="Delete" Invoked="OnDeleteAccelerator" />
      <KeyboardAccelerator Key="Escape" Invoked="OnCancelAccelerator" />
    </Grid.KeyboardAccelerators>

    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Command Bar -->
    <Border Grid.Row="0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,10,16,10">
      <StackPanel Spacing="8">
        <!-- Actions Row -->
        <StackPanel Orientation="Horizontal"
                    Spacing="2">
          <Button ToolTipService.ToolTip="{x:Bind ViewModel.RotateLeftLabel}"
                  AutomationProperties.Name="{x:Bind ViewModel.RotateLeftLabel}"
                  AutomationProperties.AutomationId="PageOrganizerRotateLeftButton"
                  Click="OnRotateLeftClick"
                  Style="{StaticResource SubtleButtonStyle}">
            <FontIcon Glyph="&#xE7AD;"
                      FontFamily="Segoe Fluent Icons"
                      FontSize="16"
                      RenderTransformOrigin="0.5,0.5">
              <FontIcon.RenderTransform>
                <ScaleTransform ScaleX="-1" />
              </FontIcon.RenderTransform>
            </FontIcon>
          </Button>
          <Button ToolTipService.ToolTip="{x:Bind ViewModel.RotateRightLabel}"
                  AutomationProperties.Name="{x:Bind ViewModel.RotateRightLabel}"
                  AutomationProperties.AutomationId="PageOrganizerRotateRightButton"
                  Click="OnRotateRightClick"
                  Style="{StaticResource SubtleButtonStyle}">
            <FontIcon Glyph="&#xE7AD;"
                      FontFamily="Segoe Fluent Icons"
                      FontSize="16" />
          </Button>

          <Rectangle Width="1"
                     Height="20"
                     Fill="{ThemeResource DividerBrush}"
                     Margin="8,0" />

          <Button ToolTipService.ToolTip="{x:Bind ViewModel.DeleteLabel}"
                  AutomationProperties.Name="{x:Bind ViewModel.DeleteLabel}"
                  AutomationProperties.AutomationId="PageOrganizerDeleteButton"
                  Click="OnDeleteClick"
                  Style="{StaticResource SubtleButtonStyle}">
            <FontIcon Glyph="&#xE107;"
                      FontFamily="Segoe Fluent Icons"
                      FontSize="16" />
          </Button>
          <Button ToolTipService.ToolTip="{x:Bind ViewModel.DuplicateLabel}"
                  AutomationProperties.Name="{x:Bind ViewModel.DuplicateLabel}"
                  AutomationProperties.AutomationId="PageOrganizerDuplicateButton"
                  Click="OnDuplicateClick"
                  Style="{StaticResource SubtleButtonStyle}">
            <FontIcon Glyph="&#xE8C8;"
                      FontFamily="Segoe Fluent Icons"
                      FontSize="16" />
          </Button>
          <Button ToolTipService.ToolTip="{x:Bind ViewModel.ReverseLabel}"
                  AutomationProperties.Name="{x:Bind ViewModel.ReverseLabel}"
                  AutomationProperties.AutomationId="PageOrganizerReverseButton"
                  Click="OnReverseClick"
                  Style="{StaticResource SubtleButtonStyle}">
            <FontIcon Glyph="&#xE174;"
                      FontFamily="Segoe Fluent Icons"
                      FontSize="16" />
          </Button>

          <Rectangle Width="1"
                     Height="20"
                     Fill="{ThemeResource DividerBrush}"
                     Margin="8,0" />

          <Button ToolTipService.ToolTip="{x:Bind ViewModel.UndoLabel}"
                  AutomationProperties.Name="{x:Bind ViewModel.UndoLabel}"
                  AutomationProperties.AutomationId="PageOrganizerUndoButton"
                  Click="OnUndoClick"
                  IsEnabled="{x:Bind ViewModel.CanUndo, Mode=OneWay}"
                  Style="{StaticResource SubtleButtonStyle}">
            <FontIcon Glyph="&#xE10E;"
                      FontFamily="Segoe Fluent Icons"
                      FontSize="16" />
          </Button>
          <Button ToolTipService.ToolTip="{x:Bind ViewModel.RedoLabel}"
                  AutomationProperties.Name="{x:Bind ViewModel.RedoLabel}"
                  AutomationProperties.AutomationId="PageOrganizerRedoButton"
                  Click="OnRedoClick"
                  IsEnabled="{x:Bind ViewModel.CanRedo, Mode=OneWay}"
                  Style="{StaticResource SubtleButtonStyle}">
            <FontIcon Glyph="&#xE10D;"
                      FontFamily="Segoe Fluent Icons"
                      FontSize="16" />
          </Button>
        </StackPanel>

        <!-- Selection Helpers Row -->
        <StackPanel Orientation="Horizontal"
                    Spacing="6">
          <TextBlock Text="{x:Bind ViewModel.SelectionLabel}"
                     VerticalAlignment="Center"
                     Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                     FontSize="12"
                     Margin="0,0,2,0" />
          <Button Content="{x:Bind ViewModel.SelectAllLabel}"
                  Click="OnSelectAllClick"
                  AutomationProperties.Name="{x:Bind ViewModel.SelectAllLabel}"
                  Style="{StaticResource ChipButtonStyle}" />
          <Button Content="{x:Bind ViewModel.SelectOddLabel}"
                  Click="OnSelectOddClick"
                  AutomationProperties.Name="{x:Bind ViewModel.SelectOddLabel}"
                  Style="{StaticResource ChipButtonStyle}" />
          <Button Content="{x:Bind ViewModel.SelectEvenLabel}"
                  Click="OnSelectEvenClick"
                  AutomationProperties.Name="{x:Bind ViewModel.SelectEvenLabel}"
                  Style="{StaticResource ChipButtonStyle}" />
          <Button Content="{x:Bind ViewModel.SelectInvertLabel}"
                  Click="OnInvertSelectionClick"
                  AutomationProperties.Name="{x:Bind ViewModel.SelectInvertLabel}"
                  Style="{StaticResource ChipButtonStyle}" />
          <Button Content="{x:Bind ViewModel.SelectNoneLabel}"
                  Click="OnDeselectAllClick"
                  AutomationProperties.Name="{x:Bind ViewModel.SelectNoneLabel}"
                  Style="{StaticResource ChipButtonStyle}" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- Page Grid -->
    <ScrollViewer Grid.Row="1"
                  x:Name="PageGridScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="16">
      <Grid>
        <ItemsRepeater x:Name="PageGridRepeater"
                       ItemsSource="{x:Bind ViewModel.Pages, Mode=OneWay}">
          <ItemsRepeater.Layout>
            <UniformGridLayout MinItemWidth="164"
                               MinItemHeight="224"
                               MinColumnSpacing="12"
                               MinRowSpacing="12"
                               ItemsStretch="None" />
          </ItemsRepeater.Layout>
          <ItemsRepeater.ItemTemplate>
            <DataTemplate x:DataType="vm:PageOrganizerItemViewModel">
              <Grid x:Name="PageItemRoot"
                    Width="164"
                    Height="224"
                    CornerRadius="{StaticResource LargeCornerRadius}"
                    Padding="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    PointerPressed="OnPageItemPointerPressed"
                    PointerMoved="OnPageItemPointerMoved"
                    PointerReleased="OnPageItemPointerReleased"
                    PointerEntered="OnPageItemPointerEntered"
                    PointerExited="OnPageItemPointerExited">
                <Grid.TranslationTransition>
                  <Vector3Transition Duration="0:0:0.25">
                    <Vector3Transition.Components>X,Y</Vector3Transition.Components>
                  </Vector3Transition>
                </Grid.TranslationTransition>
                <Grid.ScaleTransition>
                  <Vector3Transition Duration="0:0:0.15" />
                </Grid.ScaleTransition>
                <Grid.OpacityTransition>
                  <ScalarTransition Duration="0:0:0.2" />
                </Grid.OpacityTransition>
                <Grid.RowDefinitions>
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Thumbnail page surface -->
                <Viewbox Grid.Row="0"
                         Stretch="Uniform"
                         MaxWidth="150"
                         MaxHeight="172">
                  <Grid Width="172" Height="172">
                    <Grid Width="140"
                          Height="172"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          RenderTransformOrigin="0.5,0.5">
                      <Grid.RenderTransform>
                        <RotateTransform Angle="{x:Bind RotationAngle, Mode=OneWay}" />
                      </Grid.RenderTransform>

                      <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                              CornerRadius="4" />
                      <Image Source="{x:Bind Thumbnail, Mode=OneWay}"
                             Stretch="Uniform"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />

                      <Border CornerRadius="4"
                              BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                              BorderThickness="2.5"
                              Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                              IsHitTestVisible="False">
                        <Border.OpacityTransition>
                          <ScalarTransition Duration="0:0:0.15" />
                        </Border.OpacityTransition>
                      </Border>

                      <Border Width="24"
                              Height="24"
                              CornerRadius="12"
                              Background="{ThemeResource AccentFillColorDefaultBrush}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Margin="0,-10,-10,0"
                              Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                              IsHitTestVisible="False">
                        <FontIcon Glyph="&#xE73E;"
                                  FontFamily="Segoe Fluent Icons"
                                  FontSize="12"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                      </Border>
                    </Grid>
                  </Grid>
                </Viewbox>
                <ProgressRing Grid.Row="0"
                              Width="24"
                              Height="24"
                              IsActive="{x:Bind IsLoading, Mode=OneWay}"
                              Visibility="{x:Bind IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                <!-- Page Number -->
                <TextBlock Grid.Row="1"
                           Text="{x:Bind PageNumber, Mode=OneWay}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0,4,0,0" />

              </Grid>
            </DataTemplate>
          </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>

        <!-- Drag ghost overlay -->
        <Image x:Name="DragGhost"
               Width="100"
               Height="130"
               Stretch="Uniform"
               Opacity="0.75"
               IsHitTestVisible="False"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Visibility="Collapsed" />
      </Grid>
    </ScrollViewer>

    <!-- Status Bar + Actions -->
    <Border Grid.Row="2"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Padding="16,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                   VerticalAlignment="Center"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   FontSize="12" />

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8">
          <Button Content="{x:Bind ViewModel.CancelLabel}"
                  Click="OnCancelClick"
                  AutomationProperties.Name="{x:Bind ViewModel.CancelLabel}"
                  AutomationProperties.AutomationId="PageOrganizerCancelButton"
                  MinWidth="88"
                  CornerRadius="{StaticResource MediumCornerRadius}" />
          <Button Content="{x:Bind ViewModel.ApplyLabel}"
                  Click="OnApplyClick"
                  AutomationProperties.Name="{x:Bind ViewModel.ApplyLabel}"
                  AutomationProperties.AutomationId="PageOrganizerApplyButton"
                  Style="{ThemeResource AccentButtonStyle}"
                  MinWidth="88"
                  CornerRadius="{StaticResource MediumCornerRadius}" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
