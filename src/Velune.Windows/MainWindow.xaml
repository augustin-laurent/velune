<Window
    x:Class="Velune.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:Velune.Windows.Services"
    xmlns:vm="using:Velune.Windows.ViewModels"
    xmlns:dto="using:Velune.Application.DTOs"
    xmlns:domain="using:Velune.Domain.Annotations">

  <Window.SystemBackdrop>
    <MicaBackdrop />
  </Window.SystemBackdrop>

  <Grid x:Name="Root"
        Background="Transparent">

    <Grid.KeyboardAccelerators>
      <KeyboardAccelerator Key="C"
                           Modifiers="Control"
                           Invoked="OnCopySelectedTextKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="F"
                           Modifiers="Control"
                           Invoked="OnSearchKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="S"
                           Modifiers="Control"
                           Invoked="OnSaveKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="Z"
                           Modifiers="Control"
                           Invoked="OnUndoKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="Y"
                           Modifiers="Control"
                           Invoked="OnRedoKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="Delete"
                           Invoked="OnDeleteAnnotationKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="Right"
                           Modifiers="Shift"
                           Invoked="OnExtendSelectionRightKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="Left"
                           Modifiers="Shift"
                           Invoked="OnShrinkSelectionLeftKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="Right"
                           Modifiers="Control,Shift"
                           Invoked="OnExtendSelectionWordRightKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="Left"
                           Modifiers="Control,Shift"
                           Invoked="OnShrinkSelectionWordLeftKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="R"
                           Modifiers="Control"
                           Invoked="OnRotateRightKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="R"
                           Modifiers="Control,Shift"
                           Invoked="OnRotateLeftKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="Number0"
                           Modifiers="Control"
                           Invoked="OnFitPageKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="Number1"
                           Modifiers="Control"
                           Invoked="OnActualSizeKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="H"
                           Modifiers="Control,Shift"
                           Invoked="OnFlipHorizontalKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="Right"
                           Invoked="OnNextPageKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="Left"
                           Invoked="OnPreviousPageKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="PageDown"
                           Invoked="OnNextPageKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="PageUp"
                           Invoked="OnPreviousPageKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="Add"
                           Modifiers="Control"
                           Invoked="OnZoomInKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="Subtract"
                           Modifiers="Control"
                           Invoked="OnZoomOutKeyboardAcceleratorInvoked" />
    </Grid.KeyboardAccelerators>

    <Grid.Resources>
      <ResourceDictionary>
        <services:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <services:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <services:AnnotationToolBackgroundConverter x:Key="AnnotationToolBackground" />
        <services:BoolToSelectedToolBackgroundConverter x:Key="BoolToSelectedToolBackground" />
        <services:SubtractConverter x:Key="SubtractConverter" />
        <services:HexToSolidColorBrushConverter x:Key="HexToSolidColorBrush" />
        <services:DoubleToThicknessConverter x:Key="DoubleToThickness" />
        <services:DoubleToCornerRadiusConverter x:Key="DoubleToCornerRadius" />
        <services:PointListToPointCollectionConverter x:Key="PointListToPointCollection" />

        <Style x:Key="TitleBarIconButtonStyle" TargetType="Button">
          <Setter Property="Width" Value="42" />
          <Setter Property="Height" Value="42" />
          <Setter Property="MinWidth" Value="42" />
          <Setter Property="Padding" Value="0" />
          <Setter Property="CornerRadius" Value="{StaticResource SmallCornerRadius}" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="RibbonIconButtonStyle" TargetType="Button">
          <Setter Property="Width" Value="40" />
          <Setter Property="Height" Value="40" />
          <Setter Property="MinWidth" Value="40" />
          <Setter Property="Padding" Value="0" />
          <Setter Property="CornerRadius" Value="{StaticResource SmallCornerRadius}" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="RibbonTextButtonStyle" TargetType="Button">
          <Setter Property="Height" Value="40" />
          <Setter Property="MinWidth" Value="40" />
          <Setter Property="Padding" Value="10,0" />
          <Setter Property="CornerRadius" Value="{StaticResource SmallCornerRadius}" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="TopNavButtonStyle" TargetType="Button">
          <Setter Property="Height" Value="38" />
          <Setter Property="Padding" Value="14,0" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
          <Setter Property="FontSize" Value="{StaticResource NavigationFontSize}" />
        </Style>

        <Style x:Key="RibbonLabelStyle" TargetType="TextBlock">
          <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
          <Setter Property="FontSize" Value="12" />
          <Setter Property="HorizontalAlignment" Value="Center" />
          <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <Style x:Key="RibbonSeparatorStyle" TargetType="Rectangle">
          <Setter Property="Width" Value="1" />
          <Setter Property="Height" Value="64" />
          <Setter Property="Fill" Value="{ThemeResource DividerBrush}" />
          <Setter Property="Opacity" Value="0.55" />
          <Setter Property="VerticalAlignment" Value="Center" />
          <Setter Property="HorizontalAlignment" Value="Center" />
          <Setter Property="Margin" Value="14,0" />
        </Style>

        <Style x:Key="RibbonPillBorderStyle" TargetType="Border">
          <Setter Property="Padding" Value="1" />
          <Setter Property="Background" Value="{ThemeResource InputBrush}" />
          <Setter Property="BorderBrush" Value="{ThemeResource InputBorderBrush}" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="CornerRadius" Value="{StaticResource SmallCornerRadius}" />
          <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RibbonPillButtonStyle" TargetType="Button">
          <Setter Property="Height" Value="36" />
          <Setter Property="MinWidth" Value="40" />
          <Setter Property="Padding" Value="12,0" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderBrush" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="CornerRadius" Value="{StaticResource SmallCornerRadius}" />
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
          <Setter Property="HorizontalContentAlignment" Value="Center" />
          <Setter Property="VerticalContentAlignment" Value="Center" />
          <Setter Property="VerticalAlignment" Value="Center" />
          <Setter Property="UseSystemFocusVisuals" Value="True" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="Button">
                <Grid x:Name="TemplateRoot"
                      MinWidth="{TemplateBinding MinWidth}"
                      Height="{TemplateBinding Height}"
                      Background="Transparent">
                  <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup x:Name="CommonStates">
                      <VisualState x:Name="Normal" />

                      <VisualState x:Name="PointerOver">
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                           Storyboard.TargetProperty="Opacity"
                                           To="1"
                                           Duration="0:0:0.08" />
                        </Storyboard>
                      </VisualState>

                      <VisualState x:Name="Pressed">
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetName="PressedLayer"
                                           Storyboard.TargetProperty="Opacity"
                                           To="1"
                                           Duration="0:0:0.03" />
                        </Storyboard>
                      </VisualState>

                      <VisualState x:Name="Disabled">
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetName="DisabledLayer"
                                           Storyboard.TargetProperty="Opacity"
                                           To="1"
                                           Duration="0:0:0" />
                          <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                           Storyboard.TargetProperty="Opacity"
                                           To="0.45"
                                           Duration="0:0:0" />
                        </Storyboard>
                      </VisualState>
                    </VisualStateGroup>
                  </VisualStateManager.VisualStateGroups>

                  <Border x:Name="BaseLayer"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}" />

                  <Border x:Name="HoverLayer"
                          Background="{ThemeResource ActiveToolBrush}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Opacity="0" />

                  <Border x:Name="PressedLayer"
                          Background="{ThemeResource ActiveToolBorderBrush}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Opacity="0" />

                  <Border x:Name="DisabledLayer"
                          Background="{ThemeResource DisabledLayerBrush}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Opacity="0" />

                  <ContentPresenter x:Name="ContentPresenter"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    Padding="{TemplateBinding Padding}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>

        <Style x:Key="RibbonPillIconButtonStyle" TargetType="Button" BasedOn="{StaticResource RibbonPillButtonStyle}">
          <Setter Property="Width" Value="38" />
          <Setter Property="MinWidth" Value="38" />
          <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="RibbonPillDividerStyle" TargetType="Rectangle">
          <Setter Property="Width" Value="1" />
          <Setter Property="Height" Value="22" />
          <Setter Property="Fill" Value="{ThemeResource DividerBrush}" />
          <Setter Property="Opacity" Value="0.5" />
          <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyStrongTextBlockStyle}">
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="PanelLabelStyle" TargetType="TextBlock">
          <Setter Property="Foreground" Value="{ThemeResource PanelLabelBrush}" />
          <Setter Property="FontSize" Value="12" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="AnnotationToolStyle" TargetType="Button">
          <Setter Property="Width" Value="78" />
          <Setter Property="Height" Value="58" />
          <Setter Property="Margin" Value="0" />
          <Setter Property="CornerRadius" Value="{StaticResource SmallCornerRadius}" />
          <Setter Property="Background" Value="{ThemeResource CardBrush}" />
          <Setter Property="BorderBrush" Value="{ThemeResource ButtonBorderBrush}" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
          <Setter Property="HorizontalAlignment" Value="Center" />
          <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

      </ResourceDictionary>
    </Grid.Resources>

    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="RibbonAdaptiveStates">
        <VisualState x:Name="RibbonCompact">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="SearchBoxBorder.MinWidth" Value="420" />
            <Setter Target="SearchBoxBorder.MaxWidth" Value="1200" />
            <Setter Target="AnnotateBtnNote.Visibility" Value="Collapsed" />
            <Setter Target="AnnotateBtnStamp.Visibility" Value="Collapsed" />
            <Setter Target="AnnotateBtnInk.Visibility" Value="Collapsed" />
            <Setter Target="AnnotateBtnErase.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>

        <VisualState x:Name="RibbonMedium">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1550" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="SearchBoxBorder.MinWidth" Value="520" />
            <Setter Target="SearchBoxBorder.MaxWidth" Value="1200" />
            <Setter Target="AnnotateBtnNote.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnStamp.Visibility" Value="Collapsed" />
            <Setter Target="AnnotateBtnInk.Visibility" Value="Collapsed" />
            <Setter Target="AnnotateBtnErase.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>

        <VisualState x:Name="RibbonWide">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1750" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="SearchBoxBorder.MinWidth" Value="640" />
            <Setter Target="SearchBoxBorder.MaxWidth" Value="1400" />
            <Setter Target="AnnotateBtnNote.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnStamp.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnInk.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnErase.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>

        <VisualState x:Name="RibbonExtraWide">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1950" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="SearchBoxBorder.MinWidth" Value="760" />
            <Setter Target="SearchBoxBorder.MaxWidth" Value="1800" />
            <Setter Target="AnnotateBtnNote.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnStamp.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnInk.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnErase.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <Grid.RowDefinitions>
      <RowDefinition Height="50" />
      <RowDefinition Height="40" />
      <RowDefinition Height="106" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid x:Name="TitleBarDragRegion"
          Grid.Row="0"
          Padding="18,0,150,0"
          Background="{ThemeResource TitleBarBgBrush}">

      <Border x:Name="TitleBarDragHandle"
              Margin="-18,0,-150,0"
              Background="{ThemeResource TitleBarBgBrush}" />

      <StackPanel x:Name="TitleBarInteractiveRegion"
                  Orientation="Horizontal"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Bottom"
                  Spacing="4">
        <ItemsControl ItemsSource="{x:Bind ViewModel.DocumentTabs, Mode=OneWay}"
                      Height="46"
                      VerticalAlignment="Bottom">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <ItemsStackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:WindowsDocumentTabViewModel">
              <Border Width="250"
                      Height="36"
                      Margin="2,0"
                      Background="{x:Bind TabBackgroundHex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}"
                      BorderBrush="{x:Bind TabBorderHex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}"
                      BorderThickness="1"
                      CornerRadius="6"
                      PointerEntered="OnTabPointerEntered"
                      PointerExited="OnTabPointerExited">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <FontIcon Glyph="&#xE8A5;"
                            FontFamily="Segoe Fluent Icons"
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            FontSize="14"
                            Margin="12,0,8,0"
                            VerticalAlignment="Center" />

                  <TextBlock Grid.Column="1"
                             Text="{x:Bind Title}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontSize="12"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center" />

                  <Button Grid.Column="0"
                          Grid.ColumnSpan="2"
                          MinWidth="0"
                          Padding="0"
                          Background="Transparent"
                          BorderThickness="0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Click="OnTabClicked" />

                  <Button Grid.Column="2"
                          Width="30"
                          Height="30"
                          Margin="4,0,8,0"
                          Padding="0"
                          Background="Transparent"
                          BorderThickness="0"
                          Click="OnCloseTabClicked"
                          ToolTipService.ToolTip="{Binding DataContext.Labels.CloseTab, ElementName=Root}"
                          AutomationProperties.Name="{Binding DataContext.Labels.CloseTab, ElementName=Root}"
                          VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE8BB;"
                              FontFamily="Segoe Fluent Icons"
                              FontSize="10" />
                  </Button>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Style="{StaticResource TitleBarIconButtonStyle}"
                Command="{x:Bind ViewModel.OpenCommand}"
                ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Open}"
                AutomationProperties.AutomationId="OpenFileButton"

                AutomationProperties.Name="{x:Bind ViewModel.Labels.Open}">
          <FontIcon Glyph="&#xE710;"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="16" />
        </Button>
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1"
          Background="{ThemeResource MenuBarBrush}"
          BorderBrush="{ThemeResource MenuBarBorderBrush}"
          BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal"
                  Padding="18,0,0,0"
                  Spacing="4"
                  VerticalAlignment="Center">
        <Button Content="{x:Bind ViewModel.Labels.File}"
                Style="{StaticResource TopNavButtonStyle}">
          <Button.Flyout>
            <MenuFlyout>
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Open}" Command="{x:Bind ViewModel.OpenCommand}" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Save}" Command="{x:Bind ViewModel.SaveDocumentCommand}" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.SaveAs}" Command="{x:Bind ViewModel.SaveDocumentAsCommand}" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Merge}" Command="{x:Bind ViewModel.MergeCommand}" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Print}" Command="{x:Bind ViewModel.PrintCommand}" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.CloseTab}" Click="OnCloseActiveTabMenuClicked" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>

        <Grid>
          <Button Content="{x:Bind ViewModel.Labels.RibbonHome}"
                  Style="{StaticResource TopNavButtonStyle}"
                  FontWeight="SemiBold" />
          <Rectangle Height="3"
                     Fill="{ThemeResource AccentBrush}"
                     VerticalAlignment="Bottom"
                     Margin="14,0"
                     RadiusX="1"
                     RadiusY="1"
                     Opacity="0.8">
            <Rectangle.OpacityTransition>
              <ScalarTransition Duration="0:0:0.15" />
            </Rectangle.OpacityTransition>
          </Rectangle>
        </Grid>

        <Button Content="{x:Bind ViewModel.Labels.View}"
                Style="{StaticResource TopNavButtonStyle}">
          <Button.Flyout>
            <MenuFlyout>
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Pages}" Command="{x:Bind ViewModel.TogglePagesPanelCommand}" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Info}" Command="{x:Bind ViewModel.ToggleInfoPanelCommand}" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Search}" Command="{x:Bind ViewModel.OpenSearchCommand}" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.PageOrganizer}" Click="OnOpenPageOrganizerClicked" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.ZoomFit}" Command="{x:Bind ViewModel.FitPageCommand}" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.ZoomActual}" Command="{x:Bind ViewModel.ActualSizeCommand}" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>

        <Button Content="{x:Bind ViewModel.Labels.MenuSelection}"
                Style="{StaticResource TopNavButtonStyle}">
          <Button.Flyout>
            <MenuFlyout>
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.PageRotateLeft}" Click="OnRibbonRotateLeftClick">
                <MenuFlyoutItem.Icon>
                  <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" RenderTransformOrigin="0.5,0.5">
                    <FontIcon.RenderTransform>
                      <ScaleTransform ScaleX="-1" />
                    </FontIcon.RenderTransform>
                  </FontIcon>
                </MenuFlyoutItem.Icon>
              </MenuFlyoutItem>
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.PageRotateRight}" Click="OnRibbonRotateRightClick">
                <MenuFlyoutItem.Icon>
                  <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" />
                </MenuFlyoutItem.Icon>
              </MenuFlyoutItem>
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.PageMoveUp}" Click="OnThumbnailMoveUpClick">
                <MenuFlyoutItem.Icon>
                  <FontIcon Glyph="&#xE74A;" FontFamily="Segoe Fluent Icons" />
                </MenuFlyoutItem.Icon>
              </MenuFlyoutItem>
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.PageMoveDown}" Click="OnThumbnailMoveDownClick">
                <MenuFlyoutItem.Icon>
                  <FontIcon Glyph="&#xE74B;" FontFamily="Segoe Fluent Icons" />
                </MenuFlyoutItem.Icon>
              </MenuFlyoutItem>
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.PageDelete}" Click="OnThumbnailDeleteClick">
                <MenuFlyoutItem.Icon>
                  <FontIcon Glyph="&#xE107;" FontFamily="Segoe Fluent Icons" />
                </MenuFlyoutItem.Icon>
              </MenuFlyoutItem>
            </MenuFlyout>
          </Button.Flyout>
        </Button>

        <Button Content="{x:Bind ViewModel.Labels.Annotate}"
                Style="{StaticResource TopNavButtonStyle}">
          <Button.Flyout>
            <MenuFlyout>
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Select}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Select" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Highlight}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Highlight" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Ink}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Ink" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Text}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Text" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Note}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Note" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Rectangle}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Rectangle" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Signature}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Signature" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Stamp}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Stamp" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Annotations}" Command="{x:Bind ViewModel.ToggleAnnotationsPanelCommand}" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>

        <Button Content="{x:Bind ViewModel.Labels.RibbonHelp}"
                Style="{StaticResource TopNavButtonStyle}">
          <Button.Flyout>
            <MenuFlyout>
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Settings}" Command="{x:Bind ViewModel.ToggleSettingsPanelCommand}" />
              <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Info}" Command="{x:Bind ViewModel.ToggleInfoPanelCommand}" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>
      </StackPanel>
    </Grid>

    <Border Grid.Row="2"
            Margin="8,6,8,6"
            Background="{ThemeResource RibbonBrush}"
            BorderBrush="{ThemeResource RibbonBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Translation="0,0,32">
      <Border.Shadow>
        <ThemeShadow />
      </Border.Shadow>
      <Grid Padding="16,8,16,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
            <Border Style="{StaticResource RibbonPillBorderStyle}">
              <StackPanel Orientation="Horizontal" Spacing="0">
                <Button Style="{StaticResource RibbonPillButtonStyle}"
                        Command="{x:Bind ViewModel.OpenCommand}"
                        ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Open}"
                        AutomationProperties.Name="{x:Bind ViewModel.Labels.Open}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE838;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                    <TextBlock Text="{x:Bind ViewModel.Labels.Open}" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>

                <Button Style="{StaticResource RibbonPillButtonStyle}"
                        Command="{x:Bind ViewModel.MergeCommand}"
                        ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Merge}"
                        AutomationProperties.AutomationId="MergeButton"

                        AutomationProperties.Name="{x:Bind ViewModel.Labels.Merge}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8A5;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                    <TextBlock Text="{x:Bind ViewModel.Labels.Merge}" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource RibbonPillBorderStyle}">
              <Button Style="{StaticResource RibbonPillButtonStyle}"
                      Command="{x:Bind ViewModel.PrintCommand}"
                      ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Print}"
                      AutomationProperties.AutomationId="PrintButton"

                      AutomationProperties.Name="{x:Bind ViewModel.Labels.Print}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <FontIcon Glyph="&#xE749;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                  <TextBlock Text="{x:Bind ViewModel.Labels.Print}" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </Border>
          </StackPanel>

          <TextBlock Text="{x:Bind ViewModel.Labels.RibbonFileGroup}"
                     Style="{StaticResource RibbonLabelStyle}" />
        </StackPanel>

        <Rectangle Grid.Column="1" Style="{StaticResource RibbonSeparatorStyle}" />

        <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    Command="{x:Bind ViewModel.PreviousPageCommand}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.Labels.PreviousPage}"
                    AutomationProperties.AutomationId="PreviousPageButton"

                    AutomationProperties.Name="{x:Bind ViewModel.Labels.PreviousPage}">
              <FontIcon Glyph="&#xE76B;" FontFamily="Segoe Fluent Icons" />
            </Button>

            <Border Height="40"
                    MinWidth="74"
                    Padding="14,0"
                    Background="{ThemeResource InputBrush}"
                    BorderBrush="{ThemeResource InputBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
              <TextBlock Text="{x:Bind ViewModel.ActiveDocumentTab.PageText, Mode=OneWay}"
                         Foreground="{ThemeResource TextPrimaryBrush}"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center" />
            </Border>

            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    Command="{x:Bind ViewModel.NextPageCommand}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.Labels.NextPage}"
                    AutomationProperties.AutomationId="NextPageButton"

                    AutomationProperties.Name="{x:Bind ViewModel.Labels.NextPage}">
              <FontIcon Glyph="&#xE76C;" FontFamily="Segoe Fluent Icons" />
            </Button>

            <Rectangle Width="1" Height="24" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="4,0" />

            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    Click="OnRibbonRotateLeftClick"
                    ToolTipService.ToolTip="{x:Bind ViewModel.Labels.PageRotateLeft}"
                    AutomationProperties.AutomationId="RotateLeftButton"

                    AutomationProperties.Name="{x:Bind ViewModel.Labels.PageRotateLeft}">
              <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" RenderTransformOrigin="0.5,0.5">
                <FontIcon.RenderTransform>
                  <ScaleTransform ScaleX="-1" />
                </FontIcon.RenderTransform>
              </FontIcon>
            </Button>

            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    Click="OnRibbonRotateRightClick"
                    ToolTipService.ToolTip="{x:Bind ViewModel.Labels.PageRotateRight}"
                    AutomationProperties.AutomationId="RotateRightButton"

                    AutomationProperties.Name="{x:Bind ViewModel.Labels.PageRotateRight}">
              <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" />
            </Button>
          </StackPanel>

          <TextBlock Text="{x:Bind ViewModel.Labels.RibbonNavigation}"
                     Style="{StaticResource RibbonLabelStyle}" />
        </StackPanel>

        <Rectangle Grid.Column="3" Style="{StaticResource RibbonSeparatorStyle}" />

        <StackPanel Grid.Column="4" Spacing="4" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    Command="{x:Bind ViewModel.ZoomOutCommand}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.Labels.ZoomOut}"
                    AutomationProperties.AutomationId="ZoomOutButton"

                    AutomationProperties.Name="{x:Bind ViewModel.Labels.ZoomOut}">
              <FontIcon Glyph="&#xE738;" FontFamily="Segoe Fluent Icons" FontSize="16" />
            </Button>

            <Button Height="40"
                    MinWidth="92"
                    Padding="14,0"
                    Background="{ThemeResource InputBrush}"
                    BorderBrush="{ThemeResource InputBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
              <Button.Flyout>
                <MenuFlyout>
                  <MenuFlyoutItem Text="50%" Command="{x:Bind ViewModel.SetZoomCommand}" CommandParameter="0.5" />
                  <MenuFlyoutItem Text="75%" Command="{x:Bind ViewModel.SetZoomCommand}" CommandParameter="0.75" />
                  <MenuFlyoutItem Text="100%" Command="{x:Bind ViewModel.SetZoomCommand}" CommandParameter="1.0" />
                  <MenuFlyoutItem Text="125%" Command="{x:Bind ViewModel.SetZoomCommand}" CommandParameter="1.25" />
                  <MenuFlyoutItem Text="135%" Command="{x:Bind ViewModel.SetZoomCommand}" CommandParameter="1.35" />
                  <MenuFlyoutItem Text="150%" Command="{x:Bind ViewModel.SetZoomCommand}" CommandParameter="1.5" />
                  <MenuFlyoutItem Text="200%" Command="{x:Bind ViewModel.SetZoomCommand}" CommandParameter="2.0" />
                  <MenuFlyoutItem Text="300%" Command="{x:Bind ViewModel.SetZoomCommand}" CommandParameter="3.0" />
                  <MenuFlyoutSeparator />
                  <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.ZoomFit}" Command="{x:Bind ViewModel.FitPageCommand}" />
                  <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.ZoomActual}" Command="{x:Bind ViewModel.ActualSizeCommand}" />
                </MenuFlyout>
              </Button.Flyout>
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.ActiveDocumentTab.ZoomText, Mode=OneWay}" VerticalAlignment="Center" />
                <FontIcon Glyph="&#xE70D;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="10"
                          Foreground="{ThemeResource TextSecondaryBrush}" />
              </StackPanel>
            </Button>

            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    Command="{x:Bind ViewModel.ZoomInCommand}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.Labels.ZoomIn}"
                    AutomationProperties.AutomationId="ZoomInButton"

                    AutomationProperties.Name="{x:Bind ViewModel.Labels.ZoomIn}">
              <FontIcon Glyph="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="16" />
            </Button>

            <Button Style="{StaticResource RibbonTextButtonStyle}"
                    Command="{x:Bind ViewModel.FitPageCommand}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.Labels.ZoomFit}"
                    AutomationProperties.AutomationId="ZoomFitButton"

                    AutomationProperties.Name="{x:Bind ViewModel.Labels.ZoomFit}">
              <StackPanel Spacing="2">
                <FontIcon Glyph="&#xE9A6;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="16"
                          HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.Labels.ZoomFit}"
                           FontSize="12"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button Style="{StaticResource RibbonTextButtonStyle}"
                    Command="{x:Bind ViewModel.ActualSizeCommand}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.Labels.ZoomActual}"
                    AutomationProperties.AutomationId="ZoomActualButton"

                    AutomationProperties.Name="{x:Bind ViewModel.Labels.ZoomActual}">
              <StackPanel Spacing="2">
                <FontIcon Glyph="&#xE740;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="16"
                          HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.Labels.ZoomActual}" FontSize="12" />
              </StackPanel>
            </Button>
          </StackPanel>

          <TextBlock Text="{x:Bind ViewModel.Labels.RibbonZoom}"
                     Style="{StaticResource RibbonLabelStyle}" />
        </StackPanel>

        <Rectangle Grid.Column="5" Style="{StaticResource RibbonSeparatorStyle}" />

        <Grid Grid.Column="6"
              Margin="24,0"
              VerticalAlignment="Center"
              HorizontalAlignment="Stretch">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Border x:Name="SearchBoxBorder"
                  Grid.Row="0"
                  Height="40"
                  MinWidth="200"
                  MaxWidth="1200"
                  HorizontalAlignment="Stretch"
                  Background="{ThemeResource SearchBrush}"
                  BorderBrush="{ThemeResource InputBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <FontIcon Glyph="&#xE721;"
                        FontFamily="Segoe Fluent Icons"
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        Margin="12,0,8,0"
                        VerticalAlignment="Center" />

              <TextBox Grid.Column="1"
                       Background="Transparent"
                       BorderThickness="0"
                       VerticalAlignment="Center"
                       VerticalContentAlignment="Center"
                       PlaceholderText="{x:Bind ViewModel.Labels.SearchPlaceholder}"
                       Text="{x:Bind ViewModel.ActiveDocumentTab.SearchQuery, Mode=TwoWay}"
                       KeyDown="OnSearchBoxKeyDown" />

              <TextBlock Grid.Column="2"
                         Text="Ctrl+F"
                         Foreground="{ThemeResource TextSecondaryBrush}"
                         FontSize="11"
                         Margin="8,0,12,0"
                         VerticalAlignment="Center" />
            </Grid>
          </Border>

          <TextBlock Grid.Row="1"
                     Text="{x:Bind ViewModel.Labels.Search}"
                     Style="{StaticResource RibbonLabelStyle}" />
        </Grid>

        <Rectangle Grid.Column="7" Style="{StaticResource RibbonSeparatorStyle}" />

        <StackPanel Grid.Column="8" Spacing="6" VerticalAlignment="Center">
          <Border Style="{StaticResource RibbonPillBorderStyle}">
            <StackPanel Orientation="Horizontal" Spacing="0">
              <Button Style="{StaticResource RibbonPillIconButtonStyle}"
                      Command="{x:Bind ViewModel.TogglePagesPanelCommand}"
                      ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Pages}"
                      AutomationProperties.AutomationId="PagesPanelButton"

                      AutomationProperties.Name="{x:Bind ViewModel.Labels.Pages}">
                <FontIcon Glyph="&#xE8FE;" FontFamily="Segoe Fluent Icons" />
              </Button>

              <Button Style="{StaticResource RibbonPillIconButtonStyle}"
                      Command="{x:Bind ViewModel.ToggleInfoPanelCommand}"
                      ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Info}"
                      AutomationProperties.AutomationId="InfoPanelButton"

                      AutomationProperties.Name="{x:Bind ViewModel.Labels.Info}">
                <FontIcon Glyph="&#xE946;" FontFamily="Segoe Fluent Icons" />
              </Button>
            </StackPanel>
          </Border>

          <TextBlock Text="{x:Bind ViewModel.Labels.RibbonDisplay}"
                     Style="{StaticResource RibbonLabelStyle}" />
        </StackPanel>

        <Rectangle Grid.Column="9" Style="{StaticResource RibbonSeparatorStyle}" />

        <StackPanel Grid.Column="10" Spacing="6" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <Border Style="{StaticResource RibbonPillBorderStyle}">
              <StackPanel Orientation="Horizontal" Spacing="0">
                <Button x:Name="AnnotateBtnSelect"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Background="{x:Bind ViewModel.ActiveDocumentTab.SelectedAnnotationTool, Mode=OneWay, Converter={StaticResource AnnotationToolBackground}, ConverterParameter=Select}"
                        Command="{x:Bind ViewModel.SelectAnnotationToolCommand}"
                        CommandParameter="Select"
                        ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Select}"
                        AutomationProperties.AutomationId="AnnotationSelectButton"

                        AutomationProperties.Name="{x:Bind ViewModel.Labels.Select}">
                  <FontIcon Glyph="&#xE8B3;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnHighlight"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Background="{x:Bind ViewModel.ActiveDocumentTab.SelectedAnnotationTool, Mode=OneWay, Converter={StaticResource AnnotationToolBackground}, ConverterParameter=Highlight}"
                        Command="{x:Bind ViewModel.SelectAnnotationToolCommand}"
                        CommandParameter="Highlight"
                        ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Highlight}"
                        AutomationProperties.AutomationId="AnnotationHighlightButton"

                        AutomationProperties.Name="{x:Bind ViewModel.Labels.Highlight}">
                  <FontIcon Glyph="&#xE891;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnText"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Background="{x:Bind ViewModel.ActiveDocumentTab.SelectedAnnotationTool, Mode=OneWay, Converter={StaticResource AnnotationToolBackground}, ConverterParameter=Text}"
                        Command="{x:Bind ViewModel.SelectAnnotationToolCommand}"
                        CommandParameter="Text"
                        ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Text}"
                        AutomationProperties.AutomationId="AnnotationTextButton"

                        AutomationProperties.Name="{x:Bind ViewModel.Labels.Text}">
                  <FontIcon Glyph="&#xE8D2;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnNote"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Background="{x:Bind ViewModel.ActiveDocumentTab.SelectedAnnotationTool, Mode=OneWay, Converter={StaticResource AnnotationToolBackground}, ConverterParameter=Note}"
                        Command="{x:Bind ViewModel.SelectAnnotationToolCommand}"
                        CommandParameter="Note"
                        ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Note}"
                        AutomationProperties.AutomationId="AnnotationNoteButton"

                        AutomationProperties.Name="{x:Bind ViewModel.Labels.Note}">
                  <FontIcon Glyph="&#xE90A;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnStamp"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Visibility="Collapsed"
                        Background="{x:Bind ViewModel.ActiveDocumentTab.SelectedAnnotationTool, Mode=OneWay, Converter={StaticResource AnnotationToolBackground}, ConverterParameter=Stamp}"
                        Command="{x:Bind ViewModel.SelectAnnotationToolCommand}"
                        CommandParameter="Stamp"
                        ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Stamp}"
                        AutomationProperties.AutomationId="AnnotationStampButton"

                        AutomationProperties.Name="{x:Bind ViewModel.Labels.Stamp}">
                  <FontIcon Glyph="&#xE945;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnInk"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Visibility="Collapsed"
                        Background="{x:Bind ViewModel.ActiveDocumentTab.SelectedAnnotationTool, Mode=OneWay, Converter={StaticResource AnnotationToolBackground}, ConverterParameter=Ink}"
                        Command="{x:Bind ViewModel.SelectAnnotationToolCommand}"
                        CommandParameter="Ink"
                        ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Ink}"
                        AutomationProperties.AutomationId="AnnotationInkButton"

                        AutomationProperties.Name="{x:Bind ViewModel.Labels.Ink}">
                  <FontIcon Glyph="&#xE70F;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnErase"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Visibility="Collapsed"
                        Command="{x:Bind ViewModel.SelectAnnotationToolCommand}"
                        CommandParameter="Erase"
                        ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Erase}"
                        AutomationProperties.Name="{x:Bind ViewModel.Labels.Erase}">
                  <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnPanel"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Command="{x:Bind ViewModel.ToggleAnnotationsPanelCommand}"
                        ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Annotations}"
                        AutomationProperties.AutomationId="AnnotationsPanelButton"

                        AutomationProperties.Name="{x:Bind ViewModel.Labels.Annotations}">
                  <FontIcon Glyph="&#xE924;" FontFamily="Segoe Fluent Icons" />
                </Button>
              </StackPanel>
            </Border>

            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Settings}"
                    AutomationProperties.AutomationId="SettingsPanelButton"

                    AutomationProperties.Name="{x:Bind ViewModel.Labels.Settings}">
              <Button.Flyout>
                <MenuFlyout>
                  <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Settings}"
                                  Command="{x:Bind ViewModel.ToggleSettingsPanelCommand}">
                    <MenuFlyoutItem.Icon>
                      <FontIcon Glyph="&#xE713;" FontFamily="Segoe Fluent Icons" />
                    </MenuFlyoutItem.Icon>
                  </MenuFlyoutItem>
                </MenuFlyout>
              </Button.Flyout>
              <FontIcon Glyph="&#xE712;" FontFamily="Segoe Fluent Icons" />
            </Button>
          </StackPanel>

          <TextBlock Text="{x:Bind ViewModel.Labels.RibbonAnnotateGroup}"
                     Style="{StaticResource RibbonLabelStyle}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="3" Margin="8,0,8,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Width="180"
              Background="{ThemeResource PanelDeepBrush}"
              BorderBrush="{ThemeResource PanelLineBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Visibility="{Binding DataContext.IsPagesPanelVisible, ElementName=Root, Mode=OneWay, FallbackValue=Collapsed, Converter={StaticResource BoolToVisibility}}">
        <Border.TranslationTransition>
          <Vector3Transition Duration="0:0:0.2" />
        </Border.TranslationTransition>
        <Grid Padding="10,12,10,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Grid Margin="4,0,4,8">
            <TextBlock Text="{Binding DataContext.Labels.Pages, ElementName=Root}"
                       Style="{StaticResource PanelTitleStyle}"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal"
                        Spacing="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
              <Button Width="28"
                      Height="28"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      ToolTipService.ToolTip="Page Organizer"
                      Click="OnOpenPageOrganizerClicked">
                <FontIcon Glyph="&#xE8FD;"
                          FontFamily="Segoe Fluent Icons"
                          Foreground="{ThemeResource TextSecondaryBrush}"
                          FontSize="14" />
              </Button>
              <Button Width="28"
                      Height="28"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      ToolTipService.ToolTip="Filter">
                <FontIcon Glyph="&#xE71C;"
                          FontFamily="Segoe Fluent Icons"
                          Foreground="{ThemeResource TextSecondaryBrush}"
                          FontSize="14" />
              </Button>
              <Button Width="28"
                      Height="28"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      Command="{Binding DataContext.TogglePagesPanelCommand, ElementName=Root}"
                      ToolTipService.ToolTip="{Binding DataContext.Labels.CloseTab, ElementName=Root}">
                <FontIcon Glyph="&#xE8BB;"
                          FontFamily="Segoe Fluent Icons"
                          Foreground="{ThemeResource TextSecondaryBrush}"
                          FontSize="14" />
              </Button>
            </StackPanel>
          </Grid>

          <Grid x:Name="ThumbnailDragSurface"
                Grid.Row="1"
                Background="Transparent"
                AllowDrop="True"
                DragOver="OnThumbnailExternalDragOver"
                DragLeave="OnThumbnailExternalDragLeave"
                Drop="OnThumbnailExternalDrop">
            <ScrollViewer x:Name="ThumbnailScrollViewer"
                           VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <ItemsControl x:Name="ThumbnailListView"
                            ItemsSource="{Binding DataContext.ActiveDocumentTab.Thumbnails, ElementName=Root, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:WindowsPageThumbnailViewModel">
                    <Grid Padding="0,4"
                          HorizontalAlignment="Stretch"
                          PointerPressed="OnThumbnailItemPointerPressed"
                          PointerMoved="OnThumbnailItemPointerMoved"
                          PointerReleased="OnThumbnailItemPointerReleased"
                          PointerEntered="OnThumbnailPointerEntered"
                          PointerExited="OnThumbnailPointerExited"
                          Tapped="OnThumbnailItemTapped"
                          RightTapped="OnThumbnailItemRightTapped">
                      <Grid.ContextFlyout>
                        <MenuFlyout>
                          <MenuFlyoutItem Text="{Binding DataContext.Labels.PageRotateLeft, ElementName=Root}" Click="OnThumbnailRotateLeftClick">
                            <MenuFlyoutItem.Icon>
                              <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" RenderTransformOrigin="0.5,0.5">
                                <FontIcon.RenderTransform><ScaleTransform ScaleX="-1" /></FontIcon.RenderTransform>
                              </FontIcon>
                            </MenuFlyoutItem.Icon>
                          </MenuFlyoutItem>
                          <MenuFlyoutItem Text="{Binding DataContext.Labels.PageRotateRight, ElementName=Root}" Click="OnThumbnailRotateRightClick">
                            <MenuFlyoutItem.Icon>
                              <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" />
                            </MenuFlyoutItem.Icon>
                          </MenuFlyoutItem>
                          <MenuFlyoutSeparator />
                          <MenuFlyoutItem Text="{Binding DataContext.Labels.PageMoveUp, ElementName=Root}" Click="OnThumbnailMoveUpClick">
                            <MenuFlyoutItem.Icon>
                              <FontIcon Glyph="&#xE74A;" FontFamily="Segoe Fluent Icons" />
                            </MenuFlyoutItem.Icon>
                          </MenuFlyoutItem>
                          <MenuFlyoutItem Text="{Binding DataContext.Labels.PageMoveDown, ElementName=Root}" Click="OnThumbnailMoveDownClick">
                            <MenuFlyoutItem.Icon>
                              <FontIcon Glyph="&#xE74B;" FontFamily="Segoe Fluent Icons" />
                            </MenuFlyoutItem.Icon>
                          </MenuFlyoutItem>
                          <MenuFlyoutSeparator />
                          <MenuFlyoutItem Text="{Binding DataContext.Labels.PageDelete, ElementName=Root}" Click="OnThumbnailDeleteClick">
                            <MenuFlyoutItem.Icon>
                              <FontIcon Glyph="&#xE107;" FontFamily="Segoe Fluent Icons" />
                            </MenuFlyoutItem.Icon>
                          </MenuFlyoutItem>
                        </MenuFlyout>
                      </Grid.ContextFlyout>
                      <Grid.TranslationTransition>
                        <Vector3Transition Duration="0:0:0.2" />
                      </Grid.TranslationTransition>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>

                      <Rectangle Grid.Column="0"
                                 Width="3"
                                 RadiusX="1.5"
                                 RadiusY="1.5"
                                 Fill="{ThemeResource AccentBrush}"
                                 VerticalAlignment="Stretch"
                                 Margin="0,8"
                                 Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                      <Rectangle x:Name="HoverBar"
                                 Grid.Column="0"
                                 Width="3"
                                 RadiusX="1.5"
                                 RadiusY="1.5"
                                 Fill="{ThemeResource AccentBrush}"
                                 VerticalAlignment="Stretch"
                                 Margin="0,8"
                                 Opacity="0" />

                      <StackPanel Grid.Column="1"
                                  Margin="4,0,0,0"
                                  HorizontalAlignment="Center"
                                  Spacing="4">
                        <Grid Width="110" Height="144">
                          <Image Source="{x:Bind Image, Mode=OneWay}"
                                 Stretch="Uniform"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                          <ProgressRing Width="24"
                                        Height="24"
                                        IsActive="{x:Bind IsLoading, Mode=OneWay}"
                                        Visibility="{x:Bind IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                          <TextBlock Text="{x:Bind PlaceholderText, Mode=OneWay}"
                                     Foreground="{ThemeResource TextSecondaryBrush}"
                                     FontSize="11"
                                     TextAlignment="Center"
                                     TextWrapping="Wrap"
                                     MaxWidth="100"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Visibility="{x:Bind HasPlaceholder, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                        <TextBlock Text="{x:Bind PageNumber, Mode=OneWay}"
                                   Foreground="{ThemeResource TextPrimaryBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center" />
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <!-- Drag ghost overlay -->
            <Image x:Name="ThumbnailDragGhost"
                   Width="80"
                   Height="104"
                   Stretch="Uniform"
                   Opacity="0.8"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Visibility="Collapsed" />

            <!-- Drop indicator line -->
            <Rectangle x:Name="ThumbnailDropIndicator"
                       Height="3"
                       RadiusX="1.5"
                       RadiusY="1.5"
                       Fill="{ThemeResource AccentBrush}"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Top"
                       IsHitTestVisible="False"
                       Margin="8,0"
                       Visibility="Collapsed" />
          </Grid>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Width="8"
              Visibility="{Binding DataContext.IsPagesPanelVisible, ElementName=Root, Mode=OneWay, FallbackValue=Collapsed, Converter={StaticResource BoolToVisibility}}" />

      <Border Grid.Column="2"
              Background="{ThemeResource ViewerBackgroundBrush}"
              BorderBrush="{ThemeResource PanelLineBrush}"
              BorderThickness="1"
              CornerRadius="8">
        <Grid>
          <Grid.ChildrenTransitions>
            <EntranceThemeTransition />
          </Grid.ChildrenTransitions>
          <ScrollViewer x:Name="DocumentScrollViewer"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        ZoomMode="Enabled"
                        SizeChanged="OnDocumentScrollViewerSizeChanged">
            <Grid MinHeight="840"
                  Padding="40,16,40,24"
>
              <Grid HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      Width="{x:Bind ViewModel.ActiveDocumentTab.CommentLaneWidth, Mode=OneWay}"
                      Height="{x:Bind ViewModel.ActiveDocumentTab.CurrentPagePixelHeight, Mode=OneWay}"
                      Visibility="{x:Bind ViewModel.ActiveDocumentTab.HasCurrentPageComments, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                  <ItemsControl ItemsSource="{x:Bind ViewModel.ActiveDocumentTab.CurrentPageCommentOverlays, Mode=OneWay}"
                                Width="280"
                                Height="{x:Bind ViewModel.ActiveDocumentTab.CurrentPagePixelHeight, Mode=OneWay}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:WindowsCommentOverlayViewModel">
                        <Grid Width="{x:Bind LaneWidth, Mode=OneWay}"
                              MinHeight="78"
                              Margin="{x:Bind Margin, Mode=OneWay}">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                          </Grid.ColumnDefinitions>

                          <Border Background="{ThemeResource CardBrush}"
                                  BorderBrush="{ThemeResource CardBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="12,10"
                                  DoubleTapped="OnCommentCardDoubleTapped">
                            <StackPanel Spacing="6">
                              <Grid>
                                <TextBlock Text="{x:Bind PageLabel}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11" />
                                <TextBlock Text="{x:Bind TimeText, Mode=OneWay}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11"
                                           HorizontalAlignment="Right" />
                              </Grid>
                              <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         FontSize="13"
                                         TextWrapping="Wrap"
                                         MaxLines="4"
                                         Visibility="{x:Bind ReadVisibility, Mode=OneWay}" />
                              <TextBox Text="{x:Bind EditText, Mode=TwoWay}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       AcceptsReturn="True"
                                       MinHeight="40"
                                       Padding="6,4"
                                       Background="Transparent"
                                       BorderThickness="0"
                                       Visibility="{x:Bind EditVisibility, Mode=OneWay}"
                                       LostFocus="OnCommentEditLostFocus"
                                       KeyDown="OnCommentEditKeyDown" />
                            </StackPanel>
                          </Border>

                          <Grid Grid.Column="1"
                                Height="28"
                                Margin="0,18,0,0"
                                VerticalAlignment="Top">
                            <Rectangle Height="1"
                                       Fill="{x:Bind StrokeHex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}"
                                       VerticalAlignment="Center" />
                            <Ellipse Width="8"
                                     Height="8"
                                     Fill="{x:Bind StrokeHex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center" />
                          </Grid>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>

                <Border Grid.Column="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Background="{ThemeResource PaperBrush}"
                      BorderBrush="{ThemeResource PaperBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="2">
                <Grid x:Name="DocumentPageLayer"
                      Width="{x:Bind ViewModel.ActiveDocumentTab.CurrentPagePixelWidth, Mode=OneWay}"
                      Height="{x:Bind ViewModel.ActiveDocumentTab.CurrentPagePixelHeight, Mode=OneWay}"
                      Background="Transparent"
                      PointerPressed="OnDocumentLayerPointerPressed"
                      PointerMoved="OnDocumentLayerPointerMoved"
                      PointerReleased="OnDocumentLayerPointerReleased"
                      PointerCanceled="OnDocumentLayerPointerCanceled"
                      RightTapped="OnDocumentLayerRightTapped">
                  <Grid.ContextFlyout>
                    <MenuFlyout x:Name="AnnotationContextMenu">
                      <MenuFlyoutItem x:Name="ContextMenuDeleteItem" Click="OnContextMenuDelete">
                        <MenuFlyoutItem.Icon>
                          <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" />
                        </MenuFlyoutItem.Icon>
                        <MenuFlyoutItem.KeyboardAccelerators>
                          <KeyboardAccelerator Key="Delete" />
                        </MenuFlyoutItem.KeyboardAccelerators>
                      </MenuFlyoutItem>
                      <MenuFlyoutSeparator />
                      <MenuFlyoutItem x:Name="ContextMenuRotate90Item" Click="OnContextMenuRotate90">
                        <MenuFlyoutItem.Icon>
                          <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" />
                        </MenuFlyoutItem.Icon>
                      </MenuFlyoutItem>
                      <MenuFlyoutItem x:Name="ContextMenuResetRotationItem" Click="OnContextMenuResetRotation">
                        <MenuFlyoutItem.Icon>
                          <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" />
                        </MenuFlyoutItem.Icon>
                      </MenuFlyoutItem>
                      <MenuFlyoutSeparator />
                      <MenuFlyoutItem x:Name="ContextMenuFlipHItem" Click="OnContextMenuFlipH">
                        <MenuFlyoutItem.Icon>
                          <FontIcon Glyph="&#xEA4F;" FontFamily="Segoe Fluent Icons" />
                        </MenuFlyoutItem.Icon>
                      </MenuFlyoutItem>
                      <MenuFlyoutItem x:Name="ContextMenuFlipVItem" Click="OnContextMenuFlipV">
                        <MenuFlyoutItem.Icon>
                          <FontIcon Glyph="&#xEA4E;" FontFamily="Segoe Fluent Icons" />
                        </MenuFlyoutItem.Icon>
                      </MenuFlyoutItem>
                    </MenuFlyout>
                  </Grid.ContextFlyout>
                  <Image Source="{x:Bind ViewModel.ActiveDocumentTab.CurrentPageImage, Mode=OneWay}"
                         Width="{x:Bind ViewModel.ActiveDocumentTab.CurrentPagePixelWidth, Mode=OneWay}"
                         Height="{x:Bind ViewModel.ActiveDocumentTab.CurrentPagePixelHeight, Mode=OneWay}"
                         Stretch="None"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Top" />

                  <ItemsControl ItemsSource="{x:Bind ViewModel.ActiveDocumentTab.CurrentPageAnnotationOverlays, Mode=OneWay}"
                                Width="{x:Bind ViewModel.ActiveDocumentTab.CurrentPagePixelWidth, Mode=OneWay}"
                                Height="{x:Bind ViewModel.ActiveDocumentTab.CurrentPagePixelHeight, Mode=OneWay}"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Grid />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:WindowsAnnotationOverlayViewModel">
                        <Canvas Width="{x:Bind Width, Mode=OneWay}"
                                Height="{x:Bind Height, Mode=OneWay}"
                                Margin="{x:Bind Margin, Mode=OneWay}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Opacity="{x:Bind Opacity, Mode=OneWay}"
                                Visibility="{x:Bind IsHidden, Mode=OneWay, Converter={StaticResource InverseBoolToVisibility}}">
                          <!-- Rotatable annotation content + selection -->
                          <Canvas Width="{x:Bind Width, Mode=OneWay}"
                                  Height="{x:Bind Height, Mode=OneWay}">
                            <Canvas.RenderTransform>
                              <RotateTransform Angle="{x:Bind RotationAngle, Mode=OneWay}"
                                               CenterX="{x:Bind RotationCenterX, Mode=OneWay}"
                                               CenterY="{x:Bind RotationCenterY, Mode=OneWay}" />
                            </Canvas.RenderTransform>
                            <Border Width="{x:Bind Width, Mode=OneWay}"
                                    Height="{x:Bind Height, Mode=OneWay}"
                                    Background="{x:Bind FillHex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}"
                                    BorderBrush="{x:Bind StrokeHex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}"
                                    BorderThickness="{x:Bind BorderThickness, Mode=OneWay}"
                                    CornerRadius="{x:Bind CornerRadius, Mode=OneWay}"
                                    Visibility="{x:Bind BoxVisibility, Mode=OneWay}" />
                            <Polyline Points="{x:Bind InkPoints, Mode=OneWay, Converter={StaticResource PointListToPointCollection}}"
                                      Stroke="{x:Bind StrokeHex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}"
                                      StrokeThickness="{x:Bind StrokeThickness, Mode=OneWay}"
                                      Visibility="{x:Bind InkVisibility, Mode=OneWay}" />
                            <Image Width="{x:Bind Width, Mode=OneWay}"
                                   Height="{x:Bind Height, Mode=OneWay}"
                                   Source="{x:Bind SignatureImageSource, Mode=OneWay}"
                                   Stretch="Uniform"
                                   Visibility="{x:Bind SignatureImageVisibility, Mode=OneWay}" />
                            <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                                       Foreground="{x:Bind TextHex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}"
                                       FontSize="{x:Bind TextFontSize, Mode=OneWay}"
                                       FontFamily="{x:Bind TextFontFamily, Mode=OneWay}"
                                       Width="{x:Bind Width, Mode=OneWay}"
                                       Padding="4,2"
                                       TextWrapping="Wrap"
                                       Visibility="{x:Bind TextVisibility, Mode=OneWay}" />
                            <FontIcon Glyph="{x:Bind Glyph}"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{x:Bind TextHex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}"
                                      FontSize="16"
                                      Visibility="{x:Bind GlyphVisibility, Mode=OneWay}" />
                            <!-- Selection box + rotate button (all rotate with content) -->
                            <Canvas Width="{x:Bind SelectionWidth, Mode=OneWay}"
                                    Height="{x:Bind SelectionHeight, Mode=OneWay}"
                                    Margin="{x:Bind SelectionMargin, Mode=OneWay}"
                                    Visibility="{x:Bind SelectionVisibility, Mode=OneWay}">
                              <Rectangle Width="{x:Bind SelectionWidth, Mode=OneWay}"
                                         Height="{x:Bind SelectionHeight, Mode=OneWay}"
                                         Stroke="{ThemeResource AccentBrush}"
                                         StrokeThickness="2"
                                         StrokeDashArray="4,3"
                                         Fill="Transparent" />
                              <Ellipse Width="10" Height="10"
                                       Canvas.Left="-5" Canvas.Top="-5"
                                       Fill="{ThemeResource AccentBrush}" />
                              <Ellipse Width="10" Height="10"
                                       Canvas.Left="-5"
                                       Fill="{ThemeResource AccentBrush}">
                                <Canvas.Top>
                                  <Binding Path="SelectionHeight" Converter="{StaticResource SubtractConverter}" ConverterParameter="5" />
                                </Canvas.Top>
                              </Ellipse>
                              <Ellipse Width="10" Height="10"
                                       Canvas.Top="-5"
                                       Fill="{ThemeResource AccentBrush}">
                                <Canvas.Left>
                                  <Binding Path="SelectionWidth" Converter="{StaticResource SubtractConverter}" ConverterParameter="5" />
                                </Canvas.Left>
                              </Ellipse>
                              <Ellipse Width="10" Height="10"
                                       Fill="{ThemeResource AccentBrush}">
                                <Canvas.Left>
                                  <Binding Path="SelectionWidth" Converter="{StaticResource SubtractConverter}" ConverterParameter="5" />
                                </Canvas.Left>
                                <Canvas.Top>
                                  <Binding Path="SelectionHeight" Converter="{StaticResource SubtractConverter}" ConverterParameter="5" />
                                </Canvas.Top>
                              </Ellipse>
                              <!-- Rotation stem line from top-center upward -->
                              <Line X1="0" Y1="0" X2="0" Y2="-10"
                                    Stroke="{ThemeResource AccentBrush}"
                                    StrokeThickness="1.5"
                                    Canvas.Top="0">
                                <Canvas.Left>
                                  <Binding Path="RotateStemLeft" />
                                </Canvas.Left>
                              </Line>
                              <!-- Rotation handle at top-center -->
                              <Border Width="20" Height="20"
                                      CornerRadius="10"
                                      Background="{ThemeResource AccentBrush}">
                                <FontIcon Glyph="&#xE7AD;" FontSize="11" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Canvas.Left>
                                  <Binding Path="RotateButtonLeft" />
                                </Canvas.Left>
                                <Canvas.Top>
                                  <Binding Path="RotateButtonTop" />
                                </Canvas.Top>
                              </Border>
                            </Canvas>
                          </Canvas>
                        </Canvas>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <Grid Width="{x:Bind ViewModel.ActiveDocumentTab.InlineTextEditor.Width, Mode=OneWay, FallbackValue=180}"
                        Height="{x:Bind ViewModel.ActiveDocumentTab.InlineTextEditor.Height, Mode=OneWay, FallbackValue=72}"
                        Margin="{x:Bind ViewModel.ActiveDocumentTab.InlineTextEditor.Margin, Mode=OneWay}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Visibility="{x:Bind ViewModel.ActiveDocumentTab.HasInlineTextEditor, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <TextBox x:Name="InlineTextEditorBox"
                             Padding="4,2"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{x:Bind ViewModel.ActiveDocumentTab.InlineTextEditor.StrokeHex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}"
                             FontSize="{x:Bind ViewModel.ActiveDocumentTab.InlineTextEditor.FontSize, Mode=OneWay, FallbackValue=14}"
                             FontFamily="{x:Bind ViewModel.ActiveDocumentTab.InlineTextEditor.FontFamily, Mode=OneWay, FallbackValue='Segoe UI'}"
                             Text="{x:Bind ViewModel.ActiveDocumentTab.InlineTextEditor.Text, Mode=OneWay}"
                             TextWrapping="Wrap"
                             TextChanged="OnInlineTextEditorTextChanged"
                             LostFocus="OnInlineTextEditorLostFocus"
                             KeyDown="OnInlineTextEditorKeyDown" />
                  </Grid>

                  <ItemsControl ItemsSource="{x:Bind ViewModel.ActiveDocumentTab.SearchHighlights, Mode=OneWay}"
                                Width="{x:Bind ViewModel.ActiveDocumentTab.CurrentPagePixelWidth, Mode=OneWay}"
                                Height="{x:Bind ViewModel.ActiveDocumentTab.CurrentPagePixelHeight, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.ActiveDocumentTab.HasSearchHighlights, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Grid />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:TextSelectionHighlightItem">
                        <Border Width="{x:Bind Width, Mode=OneWay}"
                                Height="{x:Bind Height, Mode=OneWay}"
                                Margin="{x:Bind Margin, Mode=OneWay}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Background="{ThemeResource SearchHighlightBrush}"
                                Opacity="0.34" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <ItemsControl ItemsSource="{x:Bind ViewModel.ActiveDocumentTab.TextSelectionHighlights, Mode=OneWay}"
                                Width="{x:Bind ViewModel.ActiveDocumentTab.CurrentPagePixelWidth, Mode=OneWay}"
                                Height="{x:Bind ViewModel.ActiveDocumentTab.CurrentPagePixelHeight, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.ActiveDocumentTab.HasTextSelectionHighlights, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Grid />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:TextSelectionHighlightItem">
                        <Border Width="{x:Bind Width, Mode=OneWay}"
                                Height="{x:Bind Height, Mode=OneWay}"
                                Margin="{x:Bind Margin, Mode=OneWay}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Background="{ThemeResource AccentBrush}"
                                Opacity="0.28" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>
              </Border>
              </Grid>
            </Grid>
          </ScrollViewer>
        </Grid>
      </Border>

      <Grid Grid.Column="3" HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="8,0,0,0"
            Visibility="{x:Bind ViewModel.ActiveDocumentTab.IsAnyRightPanelOpen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
        <Grid.TranslationTransition>
          <Vector3Transition Duration="0:0:0.2" />
        </Grid.TranslationTransition>
        <Border Width="420"
                VerticalAlignment="Stretch"
                Background="{ThemeResource PanelDeepBrush}"
                BorderBrush="{ThemeResource PanelLineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                x:Name="AnnotationsPanel"

                x:Load="{x:Bind ViewModel.ActiveDocumentTab.IsAnnotationsPanelOpen, Mode=OneWay}"

                Visibility="{x:Bind ViewModel.ActiveDocumentTab.IsAnnotationsPanelOpen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
          <Grid Padding="20,20,20,12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
              <StackPanel Spacing="6">
                <TextBlock Text="{x:Bind ViewModel.Labels.Annotations}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Foreground="{ThemeResource TextPrimaryBrush}" />
                <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationDescriptionShort}"
                           Foreground="{ThemeResource TextSecondaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Width="28"
                      Height="28"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Command="{x:Bind ViewModel.ToggleAnnotationsPanelCommand}"
                      ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Close}">
                <FontIcon Glyph="&#xE8BB;"
                          FontFamily="Segoe Fluent Icons"
                          Foreground="{ThemeResource TextSecondaryBrush}"
                          FontSize="12" />
              </Button>
            </Grid>

            <Border Grid.Row="1"
                    Height="38"
                    Margin="0,14,0,14"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
              <Grid Margin="3">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{ThemeResource ActiveToolBgBrush}"
                        CornerRadius="8"
                        Visibility="{x:Bind ViewModel.IsAnnotationToolsTabSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                  <Rectangle Height="2"
                             Width="40"
                             RadiusX="1"
                             RadiusY="1"
                             Fill="{ThemeResource AccentBrush}"
                             VerticalAlignment="Bottom"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,2" />
                </Border>
                <Button Grid.Column="0"
                        Height="32"
                        MinWidth="0"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{x:Bind ViewModel.SelectAnnotationPanelTabCommand}"
                        CommandParameter="Tools"
                        AutomationProperties.Name="{x:Bind ViewModel.Labels.AnnotationToolsTab}">
                  <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationToolsTab}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontSize="13"
                             FontWeight="SemiBold" />
                </Button>

                <Border Grid.Column="1"
                        Background="{ThemeResource ActiveToolBgBrush}"
                        CornerRadius="8"
                        Visibility="{x:Bind ViewModel.IsAnnotationCommentsTabSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                  <Rectangle Height="2"
                             Width="40"
                             RadiusX="1"
                             RadiusY="1"
                             Fill="{ThemeResource AccentBrush}"
                             VerticalAlignment="Bottom"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,2" />
                </Border>
                <Button Grid.Column="1"
                        Height="32"
                        MinWidth="0"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{x:Bind ViewModel.SelectAnnotationPanelTabCommand}"
                        CommandParameter="Comments"
                        AutomationProperties.Name="{x:Bind ViewModel.Labels.AnnotationCommentsTab}">
                  <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationCommentsTab}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontSize="13"
                             FontWeight="SemiBold" />
                </Button>
              </Grid>
            </Border>

            <Grid Grid.Row="2"
                  RowSpacing="8"
                  HorizontalAlignment="Stretch"
                  Visibility="{x:Bind ViewModel.IsAnnotationToolsAppearancePanelVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationActiveTool}"
                         Foreground="{ThemeResource PanelLabelBrush}"
                         FontSize="13" />
              <Button Grid.Row="1"
                      Height="42"
                      Background="{ThemeResource CardBrush}"
                      BorderBrush="{ThemeResource CardBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="14,0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      ToolTipService.ToolTip="{x:Bind ViewModel.ActiveAnnotationToolLabel}"
                      AutomationProperties.Name="{x:Bind ViewModel.ActiveAnnotationToolLabel}">
                <Button.Flyout>
                  <MenuFlyout>
                    <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Select}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Select" />
                    <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Highlight}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Highlight" />
                    <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Ink}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Ink" />
                    <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Text}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Text" />
                    <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Note}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Note" />
                    <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Rectangle}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Rectangle" />
                    <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Signature}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Signature" />
                    <MenuFlyoutItem Text="{x:Bind ViewModel.Labels.Stamp}" Command="{x:Bind ViewModel.SelectAnnotationToolCommand}" CommandParameter="Stamp" />
                  </MenuFlyout>
                </Button.Flyout>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <Border Width="22"
                          Height="22"
                          Background="{x:Bind ViewModel.SelectedAnnotationColorHex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}"
                          CornerRadius="8"
                          VerticalAlignment="Center" />

                  <TextBlock Grid.Column="1"
                             Text="{x:Bind ViewModel.ActiveAnnotationToolLabel}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontSize="14"
                             Margin="12,0,0,0"
                             VerticalAlignment="Center" />

                  <FontIcon Grid.Column="2"
                            Glyph="&#xE70D;"
                            FontFamily="Segoe Fluent Icons"
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            FontSize="11"
                            VerticalAlignment="Center" />
                </Grid>
              </Button>
            </Grid>

            <StackPanel Grid.Row="3"
                        Margin="0,12,0,0"
                        Spacing="10"
                        HorizontalAlignment="Stretch"
                        Visibility="{x:Bind ViewModel.IsAnnotationToolsTabSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
              <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationQuickTools}"
                         Foreground="{ThemeResource PanelLabelBrush}"
                         FontSize="13" />
              <ItemsControl ItemsSource="{x:Bind ViewModel.AnnotationTools, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"
                                   MaximumRowsOrColumns="4"
                                   ItemWidth="90"
                                   ItemHeight="68" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:WindowsAnnotationToolItem">
                    <Button Width="82"
                            Height="58"
                            Margin="0"
                            CornerRadius="8"
                            Background="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToSelectedToolBackground}}"
                            BorderBrush="{ThemeResource ButtonBorderBrush}"
                            BorderThickness="1"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
                            ToolTipService.ToolTip="{x:Bind Label}"
                            AutomationProperties.Name="{x:Bind Label}"
                            Click="OnAnnotationToolClicked">
                      <FontIcon Glyph="{x:Bind Glyph}"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="20" />
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <StackPanel Spacing="6"
                          Visibility="{x:Bind ViewModel.ShowAnnotationTextEditor, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationText}"
                           Foreground="{ThemeResource PanelLabelBrush}"
                           FontSize="13" />
                <TextBox MinHeight="78"
                         Padding="10,8"
                         Background="{ThemeResource InputBrush}"
                         BorderBrush="{ThemeResource InputBorderBrush}"
                         BorderThickness="1"
                         CornerRadius="8"
                         Foreground="{ThemeResource TextPrimaryBrush}"
                         PlaceholderText="{x:Bind ViewModel.Labels.AnnotationTextPlaceholder}"
                         Text="{x:Bind ViewModel.AnnotationTextDraft, Mode=TwoWay}"
                         TextWrapping="Wrap"
                         KeyDown="OnAnnotationTextDraftKeyDown" />
              </StackPanel>

              <StackPanel Spacing="10"
                          Visibility="{x:Bind ViewModel.ShowTextStyleControls, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Font"
                           Foreground="{ThemeResource PanelLabelBrush}"
                           FontSize="13" />
                <ComboBox ItemsSource="{x:Bind ViewModel.AnnotationFontFamilyOptions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.AnnotationFontFamily, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"
                          Background="{ThemeResource InputBrush}"
                          BorderBrush="{ThemeResource InputBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="8" />
                <Grid ColumnSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Size"
                             Foreground="{ThemeResource PanelLabelBrush}"
                             FontSize="13"
                             VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            Width="90"
                            ItemsSource="{x:Bind ViewModel.AnnotationFontSizeOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.AnnotationFontSize, Mode=TwoWay}"
                            Background="{ThemeResource InputBrush}"
                            BorderBrush="{ThemeResource InputBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8" />
                </Grid>
              </StackPanel>

              <StackPanel Spacing="10"
                          Visibility="{x:Bind ViewModel.ShowSignatureControls, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <Grid ColumnSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Bind ViewModel.Labels.SignatureLibrary}"
                             Foreground="{ThemeResource PanelLabelBrush}"
                             FontSize="13"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="1"
                          Height="32"
                          MinWidth="0"
                          Padding="10,0"
                          CornerRadius="8"
                          Background="{ThemeResource CardBrush}"
                          BorderBrush="{ThemeResource CardBorderBrush}"
                          BorderThickness="1"
                          Command="{x:Bind ViewModel.ImportSignatureAssetCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE8E5;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="13" />
                      <TextBlock Text="{x:Bind ViewModel.Labels.SignatureImportImage}"
                                 FontSize="12" />
                    </StackPanel>
                  </Button>
                  <Button Grid.Column="2"
                          Width="32"
                          Height="32"
                          Padding="0"
                          CornerRadius="8"
                          Background="Transparent"
                          BorderBrush="{ThemeResource CardBorderBrush}"
                          BorderThickness="1"
                          Command="{x:Bind ViewModel.DeleteSelectedSignatureAssetCommand}"
                          CommandParameter="{x:Bind ViewModel.SelectedSignatureAssetId, Mode=OneWay}"
                          ToolTipService.ToolTip="{x:Bind ViewModel.Labels.SignatureDeleteSelected}"
                          AutomationProperties.Name="{x:Bind ViewModel.Labels.SignatureDeleteSelected}">
                    <FontIcon Glyph="&#xE74D;"
                              FontFamily="Segoe Fluent Icons"
                              FontSize="13" />
                  </Button>
                </Grid>

                <ScrollViewer MaxHeight="132"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="{x:Bind ViewModel.HasSignatureAssets, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                  <ItemsControl ItemsSource="{x:Bind ViewModel.SignatureAssets, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="domain:SignatureAsset">
                        <Border Background="{ThemeResource CardBrush}"
                                BorderBrush="{ThemeResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,0,6">
                          <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding DataContext.SelectSignatureAssetCommand, ElementName=Root}"
                                    CommandParameter="{x:Bind Id, Mode=OneWay}">
                              <StackPanel Spacing="2">
                                <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                           Foreground="{ThemeResource TextPrimaryBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind FilePath, Mode=OneWay}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis" />
                              </StackPanel>
                            </Button>
                            <Button Grid.Column="1"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding DataContext.DeleteSelectedSignatureAssetCommand, ElementName=Root}"
                                    CommandParameter="{x:Bind Id, Mode=OneWay}"
                                    ToolTipService.ToolTip="{Binding DataContext.Labels.SignatureDeleteSelected, ElementName=Root}"
                                    AutomationProperties.Name="{Binding DataContext.Labels.SignatureDeleteSelected, ElementName=Root}">
                              <FontIcon Glyph="&#xE74D;"
                                        FontFamily="Segoe Fluent Icons"
                                        Foreground="{ThemeResource TextSecondaryBrush}"
                                        FontSize="13" />
                            </Button>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>

                <TextBlock Text="{x:Bind ViewModel.Labels.SignatureDraw}"
                           Foreground="{ThemeResource PanelLabelBrush}"
                           FontSize="13" />
                <TextBox Height="36"
                         Padding="10,0"
                         Background="{ThemeResource InputBrush}"
                         BorderBrush="{ThemeResource InputBorderBrush}"
                         BorderThickness="1"
                         CornerRadius="8"
                         Foreground="{ThemeResource TextPrimaryBrush}"
                         PlaceholderText="{x:Bind ViewModel.Labels.SignatureNamePlaceholder}"
                         Text="{x:Bind ViewModel.SignatureAssetNameInput, Mode=TwoWay}" />

                <Border Height="146"
                        Background="{ThemeResource CardBrush}"
                        BorderBrush="{ThemeResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10">
                  <Grid HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Rectangle Width="248"
                               Height="124"
                               Fill="{ThemeResource SignaturePadBgBrush}"
                               RadiusX="4"
                               RadiusY="4" />
                    <Polyline Points="{x:Bind ViewModel.SignaturePadPoints, Mode=OneWay, Converter={StaticResource PointListToPointCollection}}"
                              Stroke="{ThemeResource SignatureInkBrush}"
                              StrokeThickness="2.2"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    <Border x:Name="SignaturePadInteractionLayer"
                            Width="248"
                            Height="124"
                            Background="Transparent"
                            PointerPressed="OnSignaturePadPointerPressed"
                            PointerMoved="OnSignaturePadPointerMoved"
                            PointerReleased="OnSignaturePadPointerReleased"
                            PointerCanceled="OnSignaturePadPointerCanceled" />
                  </Grid>
                </Border>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                  <Button Height="32"
                          MinWidth="0"
                          Padding="10,0"
                          CornerRadius="8"
                          Background="{ThemeResource CardBrush}"
                          BorderBrush="{ThemeResource CardBorderBrush}"
                          BorderThickness="1"
                          Command="{x:Bind ViewModel.ClearSignatureCaptureCommand}"
                          Content="{x:Bind ViewModel.Labels.SignatureClearDrawing}" />
                  <Button Height="32"
                          MinWidth="0"
                          Padding="10,0"
                          CornerRadius="8"
                          Background="{ThemeResource AccentBgBrush}"
                          BorderBrush="{ThemeResource AccentBrush}"
                          BorderThickness="1"
                          Command="{x:Bind ViewModel.SaveDrawnSignatureAssetCommand}"
                          Content="{x:Bind ViewModel.Labels.SignatureSave}" />
                </StackPanel>
              </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="4"
                        Margin="0,2,0,0"
                        Spacing="8"
                        HorizontalAlignment="Stretch"
                        Visibility="{x:Bind ViewModel.IsAnnotationToolsAppearancePanelVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
              <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationColor}"
                         Foreground="{ThemeResource PanelLabelBrush}"
                         FontSize="13" />
              <ItemsControl ItemsSource="{x:Bind ViewModel.AnnotationColorOptions, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:WindowsAnnotationColorItem">
                    <Button Width="30"
                            Height="30"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTipService.ToolTip="{x:Bind Hex, Mode=OneWay}"
                            AutomationProperties.Name="{x:Bind Hex, Mode=OneWay}"
                            Click="OnAnnotationColorClicked">
                      <Grid>
                        <Ellipse Width="24"
                                 Height="24"
                                 Fill="{x:Bind Hex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}" />
                        <Ellipse Width="30"
                                 Height="30"
                                 Stroke="{ThemeResource AccentBrush}"
                                 StrokeThickness="3"
                                 Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                        <Ellipse Width="20"
                                 Height="20"
                                 Stroke="{ThemeResource TextPrimaryBrush}"
                                 StrokeThickness="1"
                                 Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                      </Grid>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Grid.Row="5"
                        Margin="0,10,0,0"
                        Spacing="6"
                        HorizontalAlignment="Stretch"
                        Visibility="{x:Bind ViewModel.IsAnnotationToolsAppearancePanelVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
              <Grid>
                <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationOpacity}"
                           Foreground="{ThemeResource PanelLabelBrush}"
                           FontSize="13" />
                <TextBlock Text="{x:Bind ViewModel.AnnotationOpacityText, Mode=OneWay}"
                           Foreground="{ThemeResource TextPrimaryBrush}"
                           FontSize="12"
                           HorizontalAlignment="Right" />
              </Grid>
              <Slider Minimum="0"
                      Maximum="100"
                      Value="{x:Bind ViewModel.AnnotationOpacity, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Grid.Row="6"
                        Margin="0,10,0,0"
                        Spacing="8"
                        HorizontalAlignment="Stretch"
                        Visibility="{x:Bind ViewModel.ShowRectangleFillControls, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
              <CheckBox Content="{x:Bind ViewModel.Labels.AnnotationFill}"
                        IsChecked="{x:Bind ViewModel.AnnotationFillEnabled, Mode=TwoWay}" />
              <StackPanel Spacing="6"
                          Visibility="{x:Bind ViewModel.AnnotationFillEnabled, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationFillColor}"
                           Foreground="{ThemeResource PanelLabelBrush}"
                           FontSize="13" />
                <ItemsControl ItemsSource="{x:Bind ViewModel.AnnotationFillColorOptions, Mode=OneWay}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:WindowsAnnotationColorItem">
                      <Button Width="28"
                              Height="28"
                              Padding="0"
                              Background="Transparent"
                              BorderThickness="0"
                              ToolTipService.ToolTip="{x:Bind Hex, Mode=OneWay}"
                              Click="OnAnnotationFillColorClicked">
                        <Grid>
                          <Ellipse Width="22"
                                   Height="22"
                                   Fill="{x:Bind Hex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}" />
                          <Ellipse Width="28"
                                   Height="28"
                                   Stroke="{ThemeResource AccentBrush}"
                                   StrokeThickness="3"
                                   Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </StackPanel>

            <Border Grid.Row="7"
                    Margin="0,14,0,0"
                    HorizontalAlignment="Stretch"
                    BorderBrush="{ThemeResource AnnotationSeparatorBrush}"
                    BorderThickness="0"
                    Visibility="{x:Bind ViewModel.IsAnnotationToolsTabSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
              <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                  <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationCurrent}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontSize="14" />
                  <Border HorizontalAlignment="Right"
                          Padding="10,4"
                          Background="{ThemeResource CardBrush}"
                          BorderBrush="{ThemeResource CardBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationRecent}"
                                 Foreground="{ThemeResource TextPrimaryBrush}"
                                 FontSize="12" />
                      <FontIcon Glyph="&#xE70D;"
                                FontFamily="Segoe Fluent Icons"
                                Foreground="{ThemeResource TextSecondaryBrush}"
                                FontSize="10"
                                VerticalAlignment="Center" />
                    </StackPanel>
                  </Border>
                </Grid>

                <Grid Grid.Row="1">
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled"
                                Visibility="{x:Bind ViewModel.ActiveDocumentTab.HasCurrentPageAnnotations, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.ActiveDocumentTab.CurrentPageAnnotationOverlays, Mode=OneWay}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WindowsAnnotationOverlayViewModel">
                          <Border Background="{ThemeResource CardBrush}"
                                  BorderBrush="{ThemeResource CardBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="12,10"
                                  Margin="0,0,0,8"
                                  Opacity="{x:Bind ListItemOpacity, Mode=OneWay}"
                                  Tapped="OnAnnotationListItemTapped">
                            <Grid ColumnSpacing="12">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>

                              <Grid Grid.Column="0"
                                    VerticalAlignment="Top"
                                    Margin="0,2,0,0">
                                <FontIcon Glyph="{x:Bind Glyph}"
                                          FontFamily="Segoe Fluent Icons"
                                          Foreground="{x:Bind StrokeHex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}"
                                          FontSize="18" />
                                <FontIcon Glyph="&#xE72E;"
                                          FontFamily="Segoe Fluent Icons"
                                          Foreground="{ThemeResource TextSecondaryBrush}"
                                          FontSize="10"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Bottom"
                                          Margin="0,0,-4,-4"
                                          Visibility="{x:Bind LockIconVisibility, Mode=OneWay}" />
                                <FontIcon Glyph="&#xED1A;"
                                          FontFamily="Segoe Fluent Icons"
                                          Foreground="{ThemeResource TextSecondaryBrush}"
                                          FontSize="10"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Bottom"
                                          Margin="-4,0,0,-4"
                                          Visibility="{x:Bind HiddenIconVisibility, Mode=OneWay}" />
                              </Grid>

                              <StackPanel Grid.Column="1" Spacing="1">
                                <TextBlock Text="{x:Bind Label}"
                                           Foreground="{ThemeResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind PageLabel}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11" />
                                <TextBlock Text="{x:Bind PreviewText, Mode=OneWay}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{x:Bind HasPreviewText, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                              </StackPanel>

                              <StackPanel Grid.Column="2"
                                          Orientation="Horizontal"
                                          Spacing="6"
                                          VerticalAlignment="Top"
                                          Margin="0,2,0,0">
                                <TextBlock Text="{x:Bind TimeText, Mode=OneWay}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                                <Button Width="28"
                                        Height="28"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0">
                                  <FontIcon Glyph="&#xE712;"
                                            FontFamily="Segoe Fluent Icons"
                                            Foreground="{ThemeResource TextSecondaryBrush}"
                                            FontSize="13" />
                                  <Button.Flyout>
                                    <MenuFlyout>
                                      <MenuFlyoutItem Text="{Binding DataContext.Labels.AnnotationMenuEdit, ElementName=Root}"
                                                      Tag="{x:Bind Id, Mode=OneWay}"
                                                      Click="OnAnnotationMenuEditClicked">
                                        <MenuFlyoutItem.Icon>
                                          <FontIcon Glyph="&#xE70F;" FontFamily="Segoe Fluent Icons" />
                                        </MenuFlyoutItem.Icon>
                                      </MenuFlyoutItem>
                                      <MenuFlyoutItem Text="{x:Bind HideMenuText, Mode=OneWay}"
                                                      Tag="{x:Bind Id, Mode=OneWay}"
                                                      Click="OnAnnotationMenuHideClicked">
                                        <MenuFlyoutItem.Icon>
                                          <FontIcon Glyph="&#xED1A;" FontFamily="Segoe Fluent Icons" />
                                        </MenuFlyoutItem.Icon>
                                      </MenuFlyoutItem>
                                      <MenuFlyoutItem Text="{x:Bind LockMenuText, Mode=OneWay}"
                                                      Tag="{x:Bind Id, Mode=OneWay}"
                                                      Click="OnAnnotationMenuLockClicked">
                                        <MenuFlyoutItem.Icon>
                                          <FontIcon Glyph="&#xE72E;" FontFamily="Segoe Fluent Icons" />
                                        </MenuFlyoutItem.Icon>
                                      </MenuFlyoutItem>
                                      <MenuFlyoutSeparator />
                                      <MenuFlyoutItem Text="{Binding DataContext.Labels.AnnotationMenuDelete, ElementName=Root}"
                                                      Tag="{x:Bind Id, Mode=OneWay}"
                                                      Click="OnAnnotationMenuDeleteClicked">
                                        <MenuFlyoutItem.Icon>
                                          <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" />
                                        </MenuFlyoutItem.Icon>
                                      </MenuFlyoutItem>
                                    </MenuFlyout>
                                  </Button.Flyout>
                                </Button>
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <StackPanel VerticalAlignment="Top"
                              HorizontalAlignment="Center"
                              Spacing="10"
                              Margin="0,96,0,0"
                              Visibility="{x:Bind ViewModel.ActiveDocumentTab.HasCurrentPageAnnotations, Mode=OneWay, Converter={StaticResource InverseBoolToVisibility}}">
                    <FontIcon Glyph="&#xE90A;"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="{ThemeResource EmptyStateIconBrush}"
                              FontSize="38"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationEmptyPage}"
                               Foreground="{ThemeResource TextPrimaryBrush}"
                               FontSize="12"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationEmptyHint}"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="12"
                               Width="260" />
                  </StackPanel>
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="7"
                    Margin="0,14,0,0"
                    HorizontalAlignment="Stretch"
                    BorderBrush="{ThemeResource AnnotationSeparatorBrush}"
                    BorderThickness="0"
                    Visibility="{x:Bind ViewModel.IsAnnotationCommentsTabSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
              <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                  <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationCommentsCurrent}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontSize="14" />
                  <Border HorizontalAlignment="Right"
                          Padding="10,4"
                          Background="{ThemeResource CardBrush}"
                          BorderBrush="{ThemeResource CardBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6">
                    <TextBlock Text="{x:Bind ViewModel.ActiveDocumentTab.CurrentPageCommentCountText, Mode=OneWay}"
                               Foreground="{ThemeResource TextPrimaryBrush}"
                               FontSize="12" />
                  </Border>
                </Grid>

                <Grid Grid.Row="1">
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled"
                                Visibility="{x:Bind ViewModel.ActiveDocumentTab.HasCurrentPageComments, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.ActiveDocumentTab.CurrentPageCommentOverlays, Mode=OneWay}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WindowsCommentOverlayViewModel">
                          <Border Background="{ThemeResource CardBrush}"
                                  BorderBrush="{ThemeResource CardBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="12,10"
                                  Margin="0,0,0,8">
                            <Grid ColumnSpacing="12">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>

                              <FontIcon Grid.Column="0"
                                        Glyph="&#xE90A;"
                                        FontFamily="Segoe Fluent Icons"
                                        Foreground="{x:Bind StrokeHex, Mode=OneWay, Converter={StaticResource HexToSolidColorBrush}}"
                                        FontSize="18"
                                        VerticalAlignment="Top"
                                        Margin="0,2,0,0" />

                              <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                                           Foreground="{ThemeResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           MaxLines="3" />
                                <TextBlock Text="{x:Bind PageLabel}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11" />
                              </StackPanel>

                              <StackPanel Grid.Column="2"
                                          Orientation="Horizontal"
                                          Spacing="6"
                                          VerticalAlignment="Top"
                                          Margin="0,2,0,0">
                                <TextBlock Text="{x:Bind TimeText, Mode=OneWay}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                                <Button Width="28"
                                        Height="28"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTipService.ToolTip="{Binding DataContext.Labels.AnnotationDeleteSelected, ElementName=Root}"
                                        AutomationProperties.Name="{Binding DataContext.Labels.AnnotationDeleteSelected, ElementName=Root}"
                                        Tapped="OnDeleteAnnotationTapped">
                                  <FontIcon Glyph="&#xE712;"
                                            FontFamily="Segoe Fluent Icons"
                                            Foreground="{ThemeResource TextSecondaryBrush}"
                                            FontSize="13" />
                                </Button>
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <StackPanel VerticalAlignment="Top"
                              HorizontalAlignment="Center"
                              Spacing="10"
                              Margin="0,96,0,0"
                              Visibility="{x:Bind ViewModel.ActiveDocumentTab.HasCurrentPageComments, Mode=OneWay, Converter={StaticResource InverseBoolToVisibility}}">
                    <FontIcon Glyph="&#xE90A;"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="{ThemeResource EmptyStateIconBrush}"
                              FontSize="38"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationCommentsEmptyPage}"
                               Foreground="{ThemeResource TextPrimaryBrush}"
                               FontSize="12"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Bind ViewModel.Labels.AnnotationCommentsEmptyHint}"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="12"
                               Width="260" />
                  </StackPanel>
                </Grid>
              </Grid>
            </Border>

            <Button Grid.Row="8"
                    HorizontalAlignment="Right"
                    Width="40"
                    Height="36"
                    Margin="0,8,0,0"
                    Padding="0"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Command="{x:Bind ViewModel.ToggleAnnotationsPanelCommand}"
                    ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Annotations}"
                    AutomationProperties.Name="{x:Bind ViewModel.Labels.Annotations}">
              <TextBlock Text="&#x00AB;"
                         Foreground="{ThemeResource TextPrimaryBrush}"
                         FontSize="22" />
            </Button>
          </Grid>
        </Border>

        <Border Width="356"
                Background="{ThemeResource PanelDeepBrush}"
                BorderBrush="{ThemeResource PanelLineBrush}"
                BorderThickness="1,0,0,0"
                CornerRadius="0"
                x:Name="SettingsPanel"

                x:Load="{x:Bind ViewModel.ActiveDocumentTab.IsSettingsPanelOpen, Mode=OneWay}"

                Visibility="{x:Bind ViewModel.ActiveDocumentTab.IsSettingsPanelOpen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
          <StackPanel Padding="18,14" Spacing="16">
            <StackPanel Spacing="5">
              <TextBlock Text="{x:Bind ViewModel.Labels.Settings}" Style="{StaticResource PanelTitleStyle}" />
              <TextBlock Text="{x:Bind ViewModel.Labels.PreferencesDescription}"
                         Foreground="{ThemeResource TextSecondaryBrush}"
                         FontSize="12"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Border Background="{ThemeResource CardBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
              <StackPanel Spacing="14">
                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Bind ViewModel.Labels.PreferencesLanguage}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{x:Bind ViewModel.PreferenceLanguageOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedPreferenceLanguage, Mode=TwoWay}" />
                </Grid>

                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Bind ViewModel.Labels.PreferencesTheme}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{x:Bind ViewModel.PreferenceThemeOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedPreferenceTheme, Mode=TwoWay}" />
                </Grid>

                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Bind ViewModel.Labels.PreferencesDefaultZoom}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{x:Bind ViewModel.PreferenceZoomOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedPreferenceZoom, Mode=TwoWay}" />
                </Grid>

                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{x:Bind ViewModel.Labels.PreferencesShowThumbnails}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap" />
                  <ToggleSwitch Grid.Column="1"
                                IsOn="{x:Bind ViewModel.ShowThumbnails, Mode=TwoWay}"
                                OnContent=""
                                OffContent="" />
                </Grid>

                <StackPanel Spacing="6">
                  <Grid>
                    <TextBlock Text="{x:Bind ViewModel.Labels.PreferencesCacheSize}"
                               Foreground="{ThemeResource TextPrimaryBrush}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{x:Bind ViewModel.CacheSizeText, Mode=OneWay}"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               HorizontalAlignment="Right" />
                  </Grid>
                  <Slider Minimum="64"
                          Maximum="1024"
                          Value="{x:Bind ViewModel.CacheSizeMegabytes, Mode=TwoWay}" />
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Width="420"
                VerticalAlignment="Stretch"
                Background="{ThemeResource PanelDeepBrush}"
                BorderBrush="{ThemeResource PanelLineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                x:Name="InfoPanel"

                x:Load="{x:Bind ViewModel.ActiveDocumentTab.IsInfoPanelOpen, Mode=OneWay}"

                Visibility="{x:Bind ViewModel.ActiveDocumentTab.IsInfoPanelOpen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
          <Grid Padding="20,20,20,12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
              <StackPanel Spacing="6">
                <TextBlock Text="{x:Bind ViewModel.Labels.Info}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Foreground="{ThemeResource TextPrimaryBrush}" />
                <TextBlock Text="{x:Bind ViewModel.Labels.InfoDescription}"
                           Foreground="{ThemeResource TextSecondaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Width="28"
                      Height="28"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Command="{x:Bind ViewModel.ToggleInfoPanelCommand}"
                      ToolTipService.ToolTip="{x:Bind ViewModel.Labels.Close}">
                <FontIcon Glyph="&#xE8BB;"
                          FontFamily="Segoe Fluent Icons"
                          Foreground="{ThemeResource TextSecondaryBrush}"
                          FontSize="12" />
              </Button>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,14,0,0"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
              <StackPanel Spacing="10">
                <TextBlock Text="{x:Bind ViewModel.ActiveDocumentTab.Title}"
                           Foreground="{ThemeResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <Grid ColumnSpacing="12" RowSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <TextBlock Grid.Row="0" Grid.Column="0"
                             Text="{x:Bind ViewModel.Labels.InfoFileSize}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="0" Grid.Column="1"
                             Text="{x:Bind ViewModel.ActiveDocumentTab.FileSize, Mode=OneWay}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />

                  <TextBlock Grid.Row="1" Grid.Column="0"
                             Text="{x:Bind ViewModel.Labels.InfoDimensions}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="1" Grid.Column="1"
                             Text="{x:Bind ViewModel.ActiveDocumentTab.Dimensions, Mode=OneWay}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />

                  <TextBlock Grid.Row="2" Grid.Column="0"
                             Text="{x:Bind ViewModel.Labels.InfoPages}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="2" Grid.Column="1"
                             Text="{x:Bind ViewModel.ActiveDocumentTab.PageCountText, Mode=OneWay}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />

                  <TextBlock Grid.Row="3" Grid.Column="0"
                             Text="{x:Bind ViewModel.Labels.InfoFormat}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="3" Grid.Column="1"
                             Text="{x:Bind ViewModel.ActiveDocumentTab.Format, Mode=OneWay}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />

                  <TextBlock Grid.Row="4" Grid.Column="0"
                             Text="{x:Bind ViewModel.Labels.InfoAuthor}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="4" Grid.Column="1"
                             Text="{x:Bind ViewModel.ActiveDocumentTab.Author, Mode=OneWay}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />

                  <TextBlock Grid.Row="5" Grid.Column="0"
                             Text="{x:Bind ViewModel.Labels.InfoCreated}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="5" Grid.Column="1"
                             Text="{x:Bind ViewModel.ActiveDocumentTab.CreatedDate, Mode=OneWay}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />

                  <TextBlock Grid.Row="6" Grid.Column="0"
                             Text="{x:Bind ViewModel.Labels.InfoModified}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="6" Grid.Column="1"
                             Text="{x:Bind ViewModel.ActiveDocumentTab.ModifiedDate, Mode=OneWay}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />
                </Grid>
              </StackPanel>
            </Border>
          </Grid>
        </Border>

        <Border Width="356"
                VerticalAlignment="Stretch"
                Background="{ThemeResource PanelDeepBrush}"
                BorderBrush="{ThemeResource PanelLineBrush}"
                BorderThickness="1,0,0,0"
                CornerRadius="0"
                x:Name="SearchPanel"

                x:Load="{x:Bind ViewModel.ActiveDocumentTab.IsSearchPanelOpen, Mode=OneWay}"

                Visibility="{x:Bind ViewModel.ActiveDocumentTab.IsSearchPanelOpen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
          <Grid Padding="18,14" RowSpacing="14">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="5">
              <TextBlock Text="{x:Bind ViewModel.Labels.Search}" Style="{StaticResource PanelTitleStyle}" />
              <TextBlock Text="{x:Bind ViewModel.Labels.SearchDescription}"
                         Foreground="{ThemeResource TextSecondaryBrush}"
                         FontSize="12"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,8"
                    Visibility="{x:Bind ViewModel.ActiveDocumentTab.HasSearchPanelNotice, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
              <TextBlock Text="{x:Bind ViewModel.ActiveDocumentTab.SearchPanelNotice, Mode=OneWay}"
                         Foreground="{ThemeResource TextSecondaryBrush}"
                         TextWrapping="Wrap" />
            </Border>

            <StackPanel Grid.Row="2" Spacing="8">
              <TextBlock Text="{x:Bind ViewModel.Labels.SearchQuery}"
                         Style="{StaticResource PanelLabelStyle}" />
              <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Height="38"
                        Background="{ThemeResource SearchBrush}"
                        BorderBrush="{ThemeResource InputBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE721;"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="{ThemeResource TextSecondaryBrush}"
                              Margin="12,0,8,0"
                              VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Background="Transparent"
                             BorderThickness="0"
                             PlaceholderText="{x:Bind ViewModel.Labels.SearchQueryPlaceholder}"
                             Text="{x:Bind ViewModel.ActiveDocumentTab.SearchQuery, Mode=TwoWay}"
                             KeyDown="OnSearchBoxKeyDown" />
                  </Grid>
                </Border>

                <Button Grid.Column="1"
                        Height="38"
                        MinWidth="78"
                        Content="{x:Bind ViewModel.Labels.Search}"
                        Command="{x:Bind ViewModel.SearchTextCommand}" />
              </Grid>
            </StackPanel>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        Spacing="8">
              <Button Content="{x:Bind ViewModel.Labels.SearchRecognize}"
                      Command="{x:Bind ViewModel.RunSearchOcrCommand}"
                      Visibility="{x:Bind ViewModel.ActiveDocumentTab.RequiresSearchOcr, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
              <ProgressRing Width="24"
                            Height="24"
                            IsActive="{x:Bind ViewModel.ActiveDocumentTab.IsAnalyzingDocumentText, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.ActiveDocumentTab.IsAnalyzingDocumentText, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>

            <Border Grid.Row="4"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10"
                    Visibility="{x:Bind ViewModel.ActiveDocumentTab.HasSearchResults, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Text="{x:Bind ViewModel.ActiveDocumentTab.SearchResultSummary, Mode=OneWay}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontWeight="SemiBold" />
                  <TextBlock Text="{x:Bind ViewModel.ActiveDocumentTab.SearchSelectionIndicator, Mode=OneWay}"
                             Foreground="{ThemeResource TextSecondaryBrush}"
                             FontSize="12" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                  <Button Width="32"
                          Height="32"
                          Padding="0"
                          Command="{x:Bind ViewModel.PreviousSearchResultCommand}"
                          ToolTipService.ToolTip="{x:Bind ViewModel.Labels.SearchPreviousResult}"
                          AutomationProperties.Name="{x:Bind ViewModel.Labels.SearchPreviousResult}">
                    <FontIcon Glyph="&#xE70E;" FontFamily="Segoe Fluent Icons" FontSize="11" />
                  </Button>
                  <Button Width="32"
                          Height="32"
                          Padding="0"
                          Command="{x:Bind ViewModel.NextSearchResultCommand}"
                          ToolTipService.ToolTip="{x:Bind ViewModel.Labels.SearchNextResult}"
                          AutomationProperties.Name="{x:Bind ViewModel.Labels.SearchNextResult}">
                    <FontIcon Glyph="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="11" />
                  </Button>
                </StackPanel>
              </Grid>
            </Border>

            <ListView Grid.Row="5"
                      ItemsSource="{x:Bind ViewModel.ActiveDocumentTab.SearchResults, Mode=OneWay}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      SelectionChanged="OnSearchResultSelectionChanged"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      Visibility="{x:Bind ViewModel.ActiveDocumentTab.HasSearchResults, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
              <ListView.ItemTemplate>
                  <DataTemplate x:DataType="vm:WindowsSearchResultItemViewModel">
                    <Border Background="{ThemeResource CardBrush}"
                            BorderBrush="{ThemeResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,8">
                      <StackPanel Spacing="5">
                        <TextBlock Text="{x:Bind PageLabel}"
                                   Foreground="{ThemeResource PanelLabelBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind Excerpt, Mode=OneWay}"
                                   Foreground="{ThemeResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </Grid>
        </Border>

      </Grid>
    </Grid>

    <Border Grid.Row="4"
            Background="{ThemeResource TitleBarBgBrush}"
            BorderBrush="{ThemeResource PanelLineBrush}"
            BorderThickness="0,1,0,0"
            Padding="12,4">
      <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                 Foreground="{ThemeResource TextSecondaryBrush}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 TextTrimming="CharacterEllipsis" />
    </Border>

  </Grid>
</Window>
