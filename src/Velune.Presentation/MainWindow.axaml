<Window
    x:Class="Velune.Presentation.Views.MainWindow"
    x:Name="RootWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="1280"
    Height="860"
    MinWidth="1000"
    MinHeight="700"
    KeyDown="OnWindowKeyDown"
    Title="{Binding Title}">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenCommand}" />
    <KeyBinding Gesture="Meta+O" Command="{Binding OpenCommand}" />
    <KeyBinding Gesture="Ctrl+P" Command="{Binding PrintDocumentCommand}" />
    <KeyBinding Gesture="Meta+P" Command="{Binding PrintDocumentCommand}" />
    <KeyBinding Gesture="Ctrl+F" Command="{Binding ToggleSearchPanelCommand}" />
    <KeyBinding Gesture="Meta+F" Command="{Binding ToggleSearchPanelCommand}" />
    <KeyBinding Gesture="Ctrl+Add" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Ctrl+OemPlus" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Meta+Add" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Meta+OemPlus" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Ctrl+Subtract" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Ctrl+OemMinus" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Meta+Subtract" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Meta+OemMinus" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+Up" Command="{Binding MoveCurrentPageEarlierCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+Down" Command="{Binding MoveCurrentPageLaterCommand}" />
    <KeyBinding Gesture="Meta+Shift+Up" Command="{Binding MoveCurrentPageEarlierCommand}" />
    <KeyBinding Gesture="Meta+Shift+Down" Command="{Binding MoveCurrentPageLaterCommand}" />
    <KeyBinding Gesture="Right" Command="{Binding NextPageCommand}" />
    <KeyBinding Gesture="Left" Command="{Binding PreviousPageCommand}" />
    <KeyBinding Gesture="PageDown" Command="{Binding NextPageCommand}" />
    <KeyBinding Gesture="PageUp" Command="{Binding PreviousPageCommand}" />
  </Window.KeyBindings>

  <Grid RowDefinitions="Auto,*,Auto">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="{Binding SidebarColumnWidth}" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Header -->
    <Border Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="18,14"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,0,1"
            Background="{DynamicResource Brush.Surface}">
      <Grid ColumnDefinitions="*,Auto,*"
            ColumnSpacing="20">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="16">
          <StackPanel MaxWidth="360"
                      Spacing="2">
            <TextBlock Text="{Binding HeaderTitle}"
                       Classes="title"
                       TextTrimming="CharacterEllipsis"
                       ToolTip.Tip="{Binding CurrentDocumentPath}" />
            <TextBlock Text="{Binding HeaderSubtitle}"
                       Classes="muted"
                       TextTrimming="CharacterEllipsis"
                       ToolTip.Tip="{Binding CurrentDocumentPath}" />
          </StackPanel>

          <Border Classes="header-chip-group">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="toolbar-primary-button"
                      Command="{Binding OpenCommand}"
                      IsVisible="{Binding ShouldEmphasizeOpenAction}"
                      ToolTip.Tip="Open a document">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                  <materialIcons:MaterialIcon Classes="toolbar-primary-icon"
                                              Kind="FolderOpenOutline"
                                              Width="20"
                                              Height="20" />
                  <TextBlock Text="Open"
                             Classes="toolbar-primary-label" />
                </StackPanel>
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding OpenCommand}"
                      IsVisible="{Binding HasOpenDocument}"
                      ToolTip.Tip="Open another document">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <materialIcons:MaterialIcon Classes="toolbar-icon"
                                              Kind="FolderOpenOutline"
                                              Width="18"
                                              Height="18" />
                  <TextBlock Text="Open"
                             Classes="header-action-label" />
                </StackPanel>
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding PrintDocumentCommand}"
                      IsVisible="{Binding HasOpenDocument}"
                      ToolTip.Tip="Print the current document">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="PrinterOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding CloseCommand}"
                      IsVisible="{Binding HasOpenDocument}"
                      ToolTip.Tip="Close the current document">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="Close"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10"
                    IsVisible="{Binding HasOpenDocument}">
          <Border Classes="header-pill"
                  IsVisible="{Binding IsPageNavigationVisible}">
            <StackPanel Orientation="Horizontal"
                        Spacing="6">
              <Button Classes="header-pill-button"
                      Command="{Binding PreviousPageCommand}"
                      ToolTip.Tip="Previous page">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="ChevronLeft"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Border Classes="header-pill-divider" />

              <TextBox Classes="header-page-input"
                       Width="46"
                       Text="{Binding GoToPageInput}"
                       IsEnabled="{Binding CanGoToPage}"
                       ToolTip.Tip="Enter a page number then press Enter"
                       KeyDown="OnGoToPageInputKeyDown" />

              <TextBlock Text="/"
                         Classes="header-pill-text header-pill-muted" />
              <TextBlock Text="{Binding TotalPages}"
                         Classes="header-pill-text" />

              <Border Classes="header-pill-divider" />

              <Button Classes="header-pill-button"
                      Command="{Binding NextPageCommand}"
                      ToolTip.Tip="Next page">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="ChevronRight"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>

          <Border Classes="header-pill">
            <StackPanel Orientation="Horizontal"
                        Spacing="6">
              <Button Classes="header-pill-button"
                      Command="{Binding ZoomOutCommand}"
                      ToolTip.Tip="Zoom out">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="MagnifyMinusOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Border Classes="header-pill-divider" />

              <TextBlock Text="{Binding CurrentZoom}"
                         Classes="header-pill-text" />

              <Border Classes="header-pill-divider" />

              <Button Classes="header-pill-button"
                      Command="{Binding FitToWidthCommand}"
                      ToolTip.Tip="Fit to width">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="ArrowExpandHorizontal"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-pill-button"
                      Command="{Binding FitToPageCommand}"
                      ToolTip.Tip="Fit to page">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="FitToPageOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-pill-button"
                      Command="{Binding ZoomInCommand}"
                      ToolTip.Tip="Zoom in">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="MagnifyPlusOutline"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Spacing="8">
          <Border Classes="header-chip-group"
                  IsVisible="{Binding HasOpenDocument}">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="header-action-button"
                      Command="{Binding RotateLeftCommand}"
                      ToolTip.Tip="Rotate left">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="RotateLeftVariant"
                                            Width="18"
                                            Height="18" />
              </Button>

              <TextBlock Text="{Binding CurrentRotation}"
                         Classes="header-chip-label" />

              <Button Classes="header-action-button"
                      Command="{Binding RotateRightCommand}"
                      ToolTip.Tip="Rotate right">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="RotateRightVariant"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>

          <Border Classes="header-chip-group"
                  IsVisible="{Binding HasOpenDocument}">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="header-action-button"
                      Command="{Binding ToggleSearchPanelCommand}"
                      ToolTip.Tip="Search text">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="Magnify"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding ToggleInfoPanelCommand}"
                      ToolTip.Tip="Show file information">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="InformationCircleOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding TogglePreferencesPanelCommand}"
                      ToolTip.Tip="Show preferences">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="CogOutline"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Sidebar -->
    <Border Grid.Row="1"
            Grid.Column="0"
            Width="{Binding SidebarWidth}"
            Padding="14"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,1,0"
            Background="{DynamicResource Brush.Surface}"
            IsVisible="{Binding IsSidebarVisible}">
      <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0"
                    Spacing="12"
                    Margin="0,0,0,12">
          <Grid ColumnDefinitions="*,Auto,Auto"
                ColumnSpacing="8">
            <TextBlock Text="{Binding SidebarTitle}"
                       Classes="title"
                       VerticalAlignment="Center" />

            <Button Grid.Column="1"
                    Classes="sidebar-info-button"
                    IsVisible="{Binding IsPdfStructureActionsVisible}"
                    ToolTip.Tip="Drag thumbnails to prepare a new page order. Right-click a thumbnail to extract or delete that page.">
              <materialIcons:MaterialIcon Classes="toolbar-icon"
                                          Kind="InformationCircleOutline"
                                          Width="16"
                                          Height="16" />
            </Button>

            <TextBlock Grid.Column="2"
                       Text="Loading..."
                       Classes="muted"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsGeneratingThumbnails}" />
          </Grid>

          <WrapPanel ItemSpacing="6"
                     LineSpacing="6"
                     IsVisible="{Binding IsSidebarActionStripVisible}">
            <Button Classes="sidebar-context-button"
                    Command="{Binding PersistCurrentPageRotationCommand}"
                    IsVisible="{Binding CanPersistCurrentPageRotation}">
              Save rotations
            </Button>

            <Button Classes="sidebar-context-button"
                    Command="{Binding SaveReorderedPdfCommand}"
                    IsVisible="{Binding HasPendingPageReorder}">
              Save order
            </Button>
          </WrapPanel>
        </StackPanel>

        <Grid x:Name="ThumbnailDragSurface"
              Grid.Row="1"
              Width="220"
              MaxWidth="220"
              ClipToBounds="False">
          <ScrollViewer x:Name="ThumbnailScrollViewer"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ThumbnailItemsControl"
                          ItemsSource="{Binding Thumbnails}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="thumbnail-hitbox"
                          ToolTip.Tip="Right-click for page actions"
                          PointerPressed="OnThumbnailPointerPressed"
                          PointerMoved="OnThumbnailPointerMoved"
                          PointerReleased="OnThumbnailPointerReleased"
                          PointerCaptureLost="OnThumbnailPointerCaptureLost"
                          Tapped="OnThumbnailTapped">
                    <Border.ContextMenu>
                      <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Open page"
                                  Command="{Binding DataContext.SelectThumbnailCommand, ElementName=RootWindow}"
                                  CommandParameter="{Binding}" />
                        <MenuItem Header="Extract this page"
                                  Command="{Binding DataContext.ExtractThumbnailPageCommand, ElementName=RootWindow}"
                                  CommandParameter="{Binding}" />
                        <MenuItem Header="Delete this page"
                                  Command="{Binding DataContext.DeleteThumbnailPageCommand, ElementName=RootWindow}"
                                  CommandParameter="{Binding}" />
                      </ContextMenu>
                    </Border.ContextMenu>

                    <Border Classes="thumbnail-item"
                            Classes.selected="{Binding IsSelected}"
                            Classes.dragging="{Binding IsDragging}"
                            Width="200"
                            MaxWidth="200"
                            MinHeight="120">
                      <StackPanel Spacing="8">
                        <Border Classes="thumbnail-image-host"
                                Width="176"
                                MaxWidth="176"
                                Height="154"
                                HorizontalAlignment="Center">
                          <Grid>
                            <Image Source="{Binding Thumbnail}"
                                   Stretch="Uniform"
                                   MaxWidth="170"
                                   MaxHeight="150"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="Loading..."
                                       Classes="muted"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding IsLoading}" />
                          </Grid>
                        </Border>

                        <TextBlock Text="{Binding DisplayPageNumber, StringFormat=Page {0}}"
                                   HorizontalAlignment="Center"
                                   FontWeight="SemiBold" />
                      </StackPanel>
                    </Border>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Canvas x:Name="ThumbnailDragOverlay"
                  IsHitTestVisible="False"
                  ClipToBounds="False">
            <Border x:Name="ThumbnailDropIndicator"
                    Classes="thumbnail-drop-indicator"
                    IsVisible="False" />
            <Border x:Name="ThumbnailDragGhostHost"
                    Classes="thumbnail-drag-ghost"
                    IsVisible="False">
              <Border Classes="thumbnail-item thumbnail-drag-preview-item"
                      Width="200"
                      MaxWidth="200"
                      MinHeight="120">
                <StackPanel Spacing="8">
                  <Border Classes="thumbnail-image-host"
                          Width="180"
                          MaxWidth="180"
                          Height="160"
                          HorizontalAlignment="Center">
                    <Grid>
                      <Image x:Name="ThumbnailDragGhostPreviewImage"
                             Stretch="Uniform"
                             MaxWidth="170"
                             MaxHeight="150"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                      <TextBlock x:Name="ThumbnailDragGhostLoadingText"
                                 Text="Loading..."
                                 Classes="muted"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 IsVisible="False" />
                    </Grid>
                  </Border>

                  <TextBlock x:Name="ThumbnailDragGhostPageLabel"
                             HorizontalAlignment="Center"
                             FontWeight="SemiBold" />
                </StackPanel>
              </Border>
            </Border>
          </Canvas>
        </Grid>
      </Grid>
    </Border>

    <!-- Main content -->
    <Grid Grid.Row="1"
          Grid.Column="1"
          ColumnDefinitions="*,Auto"
          Background="{DynamicResource Brush.Background}">

      <!-- Toast -->
      <Border Classes="banner"
              Grid.ColumnSpan="2"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="16"
              Padding="12,10"
              MinWidth="320"
              MaxWidth="460"
              ZIndex="10"
              IsVisible="{Binding HasUserMessage}">
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="Auto,*">
            <materialIcons:MaterialIcon Grid.Column="0"
                                        Kind="{Binding NotificationIconKind}"
                                        Width="18"
                                        Height="18"
                                        Foreground="{DynamicResource Brush.Accent}"
                                        VerticalAlignment="Top"
                                        Margin="0,1,10,0" />

            <StackPanel Grid.Column="1"
                        Spacing="4">
              <TextBlock Text="{Binding UserMessageTitle}"
                         FontWeight="SemiBold"
                         IsVisible="{Binding HasUserMessageTitle}" />

              <TextBlock Text="{Binding UserMessage}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <Button Content="{Binding NotificationSecondaryActionLabel}"
                    Command="{Binding NotificationSecondaryActionCommand}"
                    IsVisible="{Binding HasNotificationSecondaryAction}" />

            <Button Content="{Binding NotificationPrimaryActionLabel}"
                    Command="{Binding NotificationPrimaryActionCommand}"
                    IsVisible="{Binding HasNotificationPrimaryAction}" />

            <Button Content="Dismiss"
                    Command="{Binding DismissMessageCommand}"
                    IsVisible="{Binding CanDismissUserMessage}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Empty state -->
      <StackPanel HorizontalAlignment="Center"
                  Grid.ColumnSpan="2"
                  VerticalAlignment="Center"
                  Spacing="16"
                  MaxWidth="520"
                  IsVisible="{Binding IsEmptyStateVisible}">
        <Border Classes="card"
                Padding="20"
                HorizontalAlignment="Center">
          <TextBlock Text="📄"
                     FontSize="40"
                     HorizontalAlignment="Center" />
        </Border>

        <TextBlock Text="{Binding EmptyStateTitle}"
                   Classes="hero"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />

        <TextBlock Text="{Binding EmptyStateDescription}"
                   Classes="muted"
                   FontSize="{DynamicResource FontSize.BodyLarge}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8">
          <Button Content="Open a file"
                  Width="140"
                  Command="{Binding OpenCommand}" />
          <Button Content="Simulate error"
                  Width="140"
                  Command="{Binding SimulateErrorCommand}" />
        </StackPanel>

        <Border Classes="card"
                Padding="16"
                Margin="0,12,0,0"
                IsVisible="{Binding HasRecentFiles}">
          <StackPanel Spacing="10">
            <DockPanel LastChildFill="False">
              <TextBlock Text="Recent files"
                         Classes="title"
                         VerticalAlignment="Center" />

              <Button Content="Clear"
                      DockPanel.Dock="Right"
                      Command="{Binding ClearRecentFilesCommand}" />
            </DockPanel>

            <ItemsControl ItemsSource="{Binding RecentFiles}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Classes="recent-file-button"
                          Command="{Binding $parent[Window].DataContext.OpenRecentFileCommand}"
                          CommandParameter="{Binding}"
                          HorizontalContentAlignment="Stretch">
                    <Border Classes="recent-file-item">
                      <StackPanel>
                        <TextBlock Text="{Binding FileName}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding DocumentType}"
                                   Classes="muted" />
                        <TextBlock Text="{Binding FilePath}"
                                   Classes="muted"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- Viewer -->
      <Grid Margin="24"
            Grid.Column="0"
            IsVisible="{Binding HasOpenDocument}">
        <Grid Margin="12"
              SizeChanged="OnDocumentViewerSizeChanged">
          <Grid IsVisible="{Binding IsImageAutoFitActive}">
              <Viewbox Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Grid x:Name="AutoFitDocumentInteractionLayer"
                      Width="{Binding DisplayedRenderedPageWidth}"
                      Height="{Binding DisplayedRenderedPageHeight}">
                  <Image Source="{Binding CurrentRenderedBitmap}"
                         Stretch="None"
                         Width="{Binding DisplayedRenderedPageWidth}"
                         Height="{Binding DisplayedRenderedPageHeight}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />

                  <ItemsControl ItemsSource="{Binding SearchHighlights}"
                                IsVisible="{Binding HasSearchHighlights}"
                                IsHitTestVisible="False">
                    <ItemsControl.Styles>
                      <Style Selector="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                      </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="search-highlight"
                                Width="{Binding Width}"
                                Height="{Binding Height}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <ItemsControl ItemsSource="{Binding TextSelectionHighlights}"
                                IsVisible="{Binding HasTextSelectionHighlights}"
                                IsHitTestVisible="False">
                    <ItemsControl.Styles>
                      <Style Selector="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                      </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="text-selection-highlight"
                                Width="{Binding Width}"
                                Height="{Binding Height}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <Border Background="Transparent"
                          PointerPressed="OnDocumentTextSelectionPointerPressed"
                          PointerMoved="OnDocumentTextSelectionPointerMoved"
                          PointerReleased="OnDocumentTextSelectionPointerReleased"
                          PointerCaptureLost="OnDocumentTextSelectionPointerCaptureLost" />
                </Grid>
              </Viewbox>
            </Grid>

          <ScrollViewer x:Name="DocumentScrollViewer"
                        IsVisible="{Binding IsScrollableViewerVisible}"
                        PointerWheelChanged="OnDocumentPointerWheelChanged"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
            <Grid x:Name="ScrollableDocumentInteractionLayer"
                  Width="{Binding DisplayedRenderedPageWidth}"
                  Height="{Binding DisplayedRenderedPageHeight}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top">
              <Image Source="{Binding CurrentRenderedBitmap}"
                     Stretch="None"
                     Width="{Binding DisplayedRenderedPageWidth}"
                     Height="{Binding DisplayedRenderedPageHeight}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top" />

              <ItemsControl ItemsSource="{Binding SearchHighlights}"
                            IsVisible="{Binding HasSearchHighlights}"
                            IsHitTestVisible="False">
                <ItemsControl.Styles>
                  <Style Selector="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                  </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <Canvas />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="search-highlight"
                            Width="{Binding Width}"
                            Height="{Binding Height}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <ItemsControl ItemsSource="{Binding TextSelectionHighlights}"
                            IsVisible="{Binding HasTextSelectionHighlights}"
                            IsHitTestVisible="False">
                <ItemsControl.Styles>
                  <Style Selector="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                  </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <Canvas />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="text-selection-highlight"
                            Width="{Binding Width}"
                            Height="{Binding Height}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Border Background="Transparent"
                      PointerPressed="OnDocumentTextSelectionPointerPressed"
                      PointerMoved="OnDocumentTextSelectionPointerMoved"
                      PointerReleased="OnDocumentTextSelectionPointerReleased"
                      PointerCaptureLost="OnDocumentTextSelectionPointerCaptureLost" />
            </Grid>
          </ScrollViewer>

          <Border Classes="banner"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Padding="12,10"
                  IsVisible="{Binding IsRendering}">
            <TextBlock Text="Rendering..."
                       Classes="muted" />
          </Border>
          </Grid>
      </Grid>

      <!-- Info panel -->
      <Border Grid.Column="1"
              Width="{Binding InfoPanelWidth}"
              Margin="0,24,24,24"
              Padding="18,16"
              Classes="card info-panel"
              Background="{DynamicResource Brush.Surface}"
              IsVisible="{Binding IsInfoPanelOpen}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="Informations"
                         Classes="title" />
              <TextBlock Text="{Binding CurrentDocumentName}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="{Binding CurrentDocumentType}"
                         Classes="muted" />
            </StackPanel>

            <Border Classes="banner"
                    Padding="10,8"
                    IsVisible="{Binding HasDocumentInfoWarning}">
              <TextBlock Text="{Binding DocumentInfoWarning}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </Border>

            <ItemsControl ItemsSource="{Binding DocumentInfoItems}"
                          IsVisible="{Binding HasDocumentInfo}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="96,*"
                        ColumnSpacing="12"
                        Margin="0,0,0,10">
                    <TextBlock Text="{Binding Label}"
                               Classes="metadata-label"
                               VerticalAlignment="Top" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Value}"
                               TextWrapping="Wrap" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Search panel -->
      <Border Grid.Column="1"
              Width="{Binding SearchPanelWidth}"
              Margin="0,24,24,24"
              Padding="18,16"
              Classes="card info-panel"
              Background="{DynamicResource Brush.Surface}"
              IsVisible="{Binding IsSearchPanelOpen}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
            <StackPanel Spacing="4">
              <TextBlock Text="Search"
                         Classes="title" />
              <TextBlock Text="{Binding CurrentDocumentName}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="Search inside the current document or recognize text locally when needed."
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Border Classes="banner"
                    Padding="10,8"
                    IsVisible="{Binding HasSearchPanelNotice}">
              <TextBlock Text="{Binding SearchPanelNotice}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </Border>

            <StackPanel Spacing="8">
              <TextBlock Text="Query"
                         Classes="metadata-label" />
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="8">
                <TextBox Classes="toolbar-input"
                         Grid.Column="0"
                         Watermark="Find text in this document"
                         Text="{Binding SearchQueryInput}" />

                <Button Grid.Column="1"
                        Content="Search"
                        Command="{Binding SearchTextCommand}" />
              </Grid>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <Button Content="Recognize text"
                      Command="{Binding RunSearchOcrCommand}"
                      IsVisible="{Binding CanRunDocumentOcr}" />
              <Button Content="Cancel analysis"
                      Command="{Binding CancelDocumentTextAnalysisCommand}"
                      IsVisible="{Binding CanCancelDocumentTextAnalysis}" />
            </StackPanel>

            <Border Classes="toolbar-group"
                    IsVisible="{Binding HasSearchResults}">
              <DockPanel LastChildFill="False"
                         Margin="0">
                <StackPanel DockPanel.Dock="Left"
                            Margin="4"
                            Spacing="0">
                  <TextBlock Text="{Binding SearchResultSummary}"
                             Classes="toolbar-metric-value" />
                  <TextBlock Text="{Binding SearchSelectionIndicator}"
                             Classes="toolbar-metric-label" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="4">
                  <Button Classes="toolbar-button"
                          Command="{Binding PreviousSearchResultCommand}"
                          ToolTip.Tip="Previous result">
                    <materialIcons:MaterialIcon Classes="toolbar-icon"
                                                Kind="ChevronUp"
                                                Width="20"
                                                Height="20"
                                                Foreground="{DynamicResource Brush.Icon}" />
                  </Button>

                  <Button Classes="toolbar-button"
                          Command="{Binding NextSearchResultCommand}"
                          ToolTip.Tip="Next result">
                    <materialIcons:MaterialIcon Classes="toolbar-icon"
                                                Kind="ChevronDown"
                                                Width="20"
                                                Height="20"
                                                Foreground="{DynamicResource Brush.Icon}" />
                  </Button>
                </StackPanel>
              </DockPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding SearchResults}"
                          IsVisible="{Binding HasSearchResults}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Classes="search-result-button"
                          Command="{Binding $parent[Window].DataContext.OpenSearchResultCommand}"
                          CommandParameter="{Binding}"
                          HorizontalContentAlignment="Stretch">
                    <Border Classes="search-result-item"
                            Classes.selected="{Binding IsSelected}">
                      <StackPanel Spacing="6">
                        <TextBlock Text="{Binding PageNumber, StringFormat=Page {0}}"
                                   Classes="metadata-label" />
                        <TextBlock Text="{Binding Excerpt}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Preferences panel -->
      <Border Grid.Column="1"
              Width="{Binding PreferencesPanelWidth}"
              Margin="0,24,24,24"
              Padding="18,16"
              Classes="card info-panel"
              Background="{DynamicResource Brush.Surface}"
              IsVisible="{Binding IsPreferencesPanelOpen}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
            <StackPanel Spacing="4">
              <TextBlock Text="Preferences"
                         Classes="title" />
              <TextBlock Text="Choose the default viewer behavior for the next documents you open."
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Theme"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding ThemePreferenceOptions}"
                        SelectedItem="{Binding SelectedThemePreference}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Default zoom"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding DefaultZoomPreferenceOptions}"
                        SelectedItem="{Binding SelectedDefaultZoomPreference}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Sidebar"
                         Classes="metadata-label" />
              <CheckBox Content="Show page thumbnails for PDF documents"
                        IsChecked="{Binding ShowThumbnailsPanelPreference}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Memory cache size"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding MemoryCacheEntryLimitOptions}"
                        SelectedItem="{Binding SelectedMemoryCacheEntryLimit}" />
              <TextBlock Text="0 disables the in-memory render cache."
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Print panel -->
      <Border Grid.Column="1"
              Width="{Binding PrintPanelWidth}"
              Margin="0,24,24,24"
              Padding="18,16"
              Classes="card info-panel"
              Background="{DynamicResource Brush.Surface}"
              IsVisible="{Binding IsPrintPanelOpen}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
            <StackPanel Spacing="4">
              <TextBlock Text="Print"
                         Classes="title" />
              <TextBlock Text="{Binding CurrentDocumentName}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="Choose a printer and the basic print options."
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Border Classes="banner"
                    Padding="10,8"
                    IsVisible="{Binding HasPrintPanelNotice}">
              <TextBlock Text="{Binding PrintPanelNotice}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </Border>

            <StackPanel Spacing="8">
              <DockPanel LastChildFill="False">
                <TextBlock Text="Printer"
                           Classes="metadata-label"
                           VerticalAlignment="Center" />
                <Button Content="Refresh"
                        DockPanel.Dock="Right"
                        Command="{Binding RefreshPrintDestinationsCommand}" />
              </DockPanel>

              <ComboBox Classes="preferences-input"
                        SelectedItem="{Binding SelectedPrintDestination}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
                <ComboBox.ItemsSource>
                  <Binding Path="PrintDestinations" />
                </ComboBox.ItemsSource>
              </ComboBox>
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Copies"
                         Classes="metadata-label" />
              <TextBox Classes="toolbar-input"
                       Text="{Binding PrintCopiesInput}" />
            </StackPanel>

            <StackPanel Spacing="8"
                        IsVisible="{Binding IsPrintPageRangeVisible}">
              <TextBlock Text="Pages"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding PrintPageRangeOptions}"
                        SelectedItem="{Binding SelectedPrintPageRangeOption}" />
              <TextBox Classes="toolbar-input"
                       Watermark="1-3,5"
                       Text="{Binding PrintCustomPageRange}"
                       IsVisible="{Binding IsCustomPrintRangeVisible}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Orientation"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding PrintOrientationOptions}"
                        SelectedItem="{Binding SelectedPrintOrientationOption}" />
            </StackPanel>

            <CheckBox Content="Scale content to fit the page"
                      IsChecked="{Binding PrintFitToPage}" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
              <Button Content="Cancel"
                      Command="{Binding PrintDocumentCommand}" />
              <Button Content="Print"
                      Command="{Binding SubmitPrintJobCommand}" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="12,8"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,1,0,0"
            Background="{DynamicResource Brush.Surface}">
      <TextBlock Text="{Binding StatusText}"
                 Classes="muted" />
    </Border>
  </Grid>
</Window>
