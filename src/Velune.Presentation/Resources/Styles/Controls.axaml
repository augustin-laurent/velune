<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource Brush.Background}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
    <Setter Property="FontSize" Value="{DynamicResource FontSize.Body}" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
  </Style>

  <Style Selector="Button:disabled">
    <Setter Property="Opacity" Value="0.45" />
    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
  </Style>

  <Style Selector="TextBlock.title">
    <Setter Property="FontSize" Value="{DynamicResource FontSize.Title}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.hero">
    <Setter Property="FontSize" Value="{DynamicResource FontSize.Hero}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundMuted}" />
  </Style>

   <Style Selector="Border.banner">
     <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
     <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
     <Setter Property="BorderThickness" Value="1" />
     <Setter Property="CornerRadius" Value="10" />
   </Style>

    <Style Selector="Border.recent-file-item">
      <Setter Property="Padding" Value="10" />
      <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style Selector="Button.recent-file-button">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Button.recent-file-button:pointerover /template/ ContentPresenter">
      <Setter Property="Opacity" Value="0.92" />
    </Style>

    <Style Selector="Border.thumbnail-hitbox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Border.thumbnail-item">
      <Setter Property="Padding" Value="10" />
      <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Margin" Value="0,0,0,10" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Opacity" Value="1" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.14" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.thumbnail-hitbox:pointerover Border.thumbnail-item">
      <Setter Property="Opacity" Value="0.92" />
    </Style>

    <Style Selector="Border.thumbnail-item.selected">
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="Border.thumbnail-item.dragging">
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Opacity" Value="0.16" />
    </Style>

    <Style Selector="Button.sidebar-action-button">
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="Border.thumbnail-image-host">
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="Border.thumbnail-drag-ghost">
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="Opacity" Value="0.985" />
    </Style>

    <Style Selector="Border.thumbnail-drag-preview-item">
      <Setter Property="Margin" Value="0" />
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="BoxShadow" Value="0 18 40 0 #22000000, 0 6 16 0 #16000000" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Border.thumbnail-drop-indicator">
      <Setter Property="Height" Value="5" />
      <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="Opacity" Value="0.96" />
      <Setter Property="BoxShadow" Value="0 0 0 1 #20FFFFFF, 0 6 16 0 #33256EFF" />
    </Style>

    <Style Selector="Border.toolbar-group">
      <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="4" />
    </Style>

    <Style Selector="Border.toolbar-divider">
      <Setter Property="Background" Value="{DynamicResource Brush.Border}" />
      <Setter Property="Width" Value="1" />
      <Setter Property="Margin" Value="6,8" />
    </Style>

    <Style Selector="Button.toolbar-button">
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="MinWidth" Value="38" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.Icon}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="Button.toolbar-button:pointerover">
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.Icon}" />
    </Style>

    <Style Selector="Button.toolbar-button:pressed">
      <Setter Property="Background" Value="{DynamicResource Brush.SurfaceStrong}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.Icon}" />
    </Style>

    <Style Selector="Button.toolbar-button:disabled">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundMuted}" />
      <Setter Property="Opacity" Value="0.36" />
    </Style>

    <Style Selector="Button.toolbar-primary-button">
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="MinWidth" Value="98" />
      <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.Surface}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="9" />
    </Style>

    <Style Selector="Button.toolbar-primary-button:pointerover">
      <Setter Property="Opacity" Value="0.94" />
    </Style>

    <Style Selector="Button.toolbar-primary-button:pressed">
      <Setter Property="Opacity" Value="0.88" />
    </Style>

    <Style Selector="Button.toolbar-primary-button:disabled">
      <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundMuted}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
    </Style>

    <Style Selector="materialIcons|MaterialIcon.toolbar-icon">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Icon}" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="materialIcons|MaterialIcon.toolbar-primary-icon">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Surface}" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.toolbar-primary-label">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.toolbar-metric">
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinHeight" Value="38" />
    </Style>

    <Style Selector="TextBlock.toolbar-metric-label">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundMuted}" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.toolbar-metric-value">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBox.toolbar-input">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.info-panel">
      <Setter Property="MinWidth" Value="280" />
      <Setter Property="MaxWidth" Value="320" />
    </Style>

    <Style Selector="ComboBox.preferences-input">
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8,0" />
    </Style>

    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
    </Style>

    <Style Selector="TextBlock.metadata-label">
      <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundMuted}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
</Styles>
