<Window
    x:Class="Velune.Presentation.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="1200"
    Height="800"
    MinWidth="900"
    MinHeight="600"
    Title="{Binding Title}">

  <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="260,*">

    <Border Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="16,12"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,0,1"
            Background="{DynamicResource Brush.Surface}">
      <DockPanel LastChildFill="False">
        <TextBlock Text="{Binding ApplicationTitle}"
                   Classes="title"
                   VerticalAlignment="Center" />

        <StackPanel Orientation="Horizontal"
                    Spacing="8"
                    DockPanel.Dock="Right">
          <Button Content="Open" />
          <Button Content="Zoom In" />
          <Button Content="Zoom Out" />
          <Button Content="Rotate Left" />
          <Button Content="Rotate Right" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="0"
            Padding="12"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,1,0"
            Background="{DynamicResource Brush.Surface}">
      <StackPanel Spacing="8">
        <TextBlock Text="{Binding SidebarTitle}"
                   Classes="title" />

        <Border Classes="card"
                Padding="12"
                Background="{DynamicResource Brush.SurfaceMuted}">
          <TextBlock Text="Thumbnails will appear here."
                     Classes="muted" />
        </Border>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="1"
            Padding="24"
            Background="{DynamicResource Brush.Background}">
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="12">
        <TextBlock Text="{Binding EmptyStateTitle}"
                   Classes="hero"
                   HorizontalAlignment="Center" />

        <TextBlock Text="{Binding EmptyStateDescription}"
                   Classes="muted"
                   FontSize="{DynamicResource FontSize.BodyLarge}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />

        <Button Content="Open a file"
                HorizontalAlignment="Center"
                Width="140" />
      </StackPanel>
    </Border>

    <Border Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="12,8"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,1,0,0"
            Background="{DynamicResource Brush.Surface}">
      <TextBlock Text="{Binding StatusText}"
                 Classes="muted" />
    </Border>
  </Grid>
</Window>
