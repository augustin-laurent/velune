<Window
    x:Class="Velune.Windows.WelcomeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:Velune.Windows.Services"
    xmlns:vm="using:Velune.Windows.ViewModels"
    xmlns:dto="using:Velune.Application.DTOs">

  <Window.SystemBackdrop>
    <MicaBackdrop Kind="BaseAlt" />
  </Window.SystemBackdrop>

  <Grid x:Name="Root"
        Background="{ThemeResource WelcomeBackgroundBrush}">

    <Grid.Resources>
      <ResourceDictionary>

        <services:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <services:RecentFilePdfVisibilityConverter x:Key="RecentFilePdfVisibility" />
        <services:RecentFileImageVisibilityConverter x:Key="RecentFileImageVisibility" />
        <services:RecentFileBrushConverter x:Key="RecentFileBrush" />
        <services:RecentFileOpenedAtConverter x:Key="RecentFileOpenedAt" />

        <Style x:Key="WelcomeButtonStyle" TargetType="Button">
          <Setter Property="Height" Value="34" />
          <Setter Property="MinWidth" Value="34" />
          <Setter Property="Padding" Value="13,0" />
          <Setter Property="Background" Value="{ThemeResource WelcomeButtonBgBrush}" />
          <Setter Property="BorderBrush" Value="{ThemeResource WelcomeButtonBorderBrush}" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="CornerRadius" Value="{StaticResource SmallCornerRadius}" />
          <Setter Property="Foreground" Value="{ThemeResource WelcomeButtonFgBrush}" />
          <Setter Property="FontSize" Value="13" />
          <Setter Property="HorizontalContentAlignment" Value="Center" />
          <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryWelcomeButtonStyle" TargetType="Button" BasedOn="{StaticResource WelcomeButtonStyle}">
          <Setter Property="Width" Value="173" />
          <Setter Property="Background" Value="{ThemeResource WelcomePrimaryBgBrush}" />
          <Setter Property="BorderBrush" Value="{ThemeResource WelcomePrimaryBorderBrush}" />
          <Setter Property="Foreground" Value="{ThemeResource WelcomePrimaryFgBrush}" />
        </Style>

        <Style x:Key="SecondaryWelcomeButtonStyle" TargetType="Button" BasedOn="{StaticResource WelcomeButtonStyle}">
          <Setter Property="Width" Value="179" />
        </Style>

        <Style x:Key="TopBarButtonStyle" TargetType="Button" BasedOn="{StaticResource WelcomeButtonStyle}">
          <Setter Property="Height" Value="35" />
          <Setter Property="Padding" Value="14,0" />
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource WelcomeButtonStyle}">
          <Setter Property="Width" Value="39" />
          <Setter Property="Height" Value="35" />
          <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="RecentListViewItemStyle" TargetType="ListViewItem">
          <Setter Property="MinHeight" Value="0" />
          <Setter Property="Padding" Value="0" />
          <Setter Property="Margin" Value="0,0,0,2" />
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="VerticalContentAlignment" Value="Stretch" />
          <Setter Property="UseSystemFocusVisuals" Value="False" />
          <Setter Property="CornerRadius" Value="{StaticResource MediumCornerRadius}" />
        </Style>

        <Style x:Key="ClearRecentButtonStyle" TargetType="Button">
          <Setter Property="Height" Value="26" />
          <Setter Property="Padding" Value="5,0" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderBrush" Value="Transparent" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="Foreground" Value="{ThemeResource WelcomeClearButtonFgBrush}" />
          <Setter Property="FontSize" Value="11" />
        </Style>
      </ResourceDictionary>
    </Grid.Resources>

    <Grid.RowDefinitions>
      <RowDefinition Height="45" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid x:Name="TitleBarDragRegion"
          Grid.Row="0"
          Padding="18,0,120,0"
          Background="{ThemeResource WelcomeTitleBarBrush}"
          BorderBrush="{ThemeResource WelcomeTitleBarBorderBrush}"
          BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal"
                  Spacing="10"
                  VerticalAlignment="Center">
        <Image Source="Assets/Brand/velune-app-icon.png"
               Width="26"
               Height="26" />
        <TextBlock Text="{x:Bind ViewModel.Labels.AppName}"
                   Foreground="{ThemeResource WelcomeTextPrimaryBrush}"
                   FontSize="13"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1"
          Width="1104"
          HorizontalAlignment="Center"
          Padding="0,19,0,26">
      <Grid.RowDefinitions>
        <RowDefinition Height="75" />
        <RowDefinition Height="14" />
        <RowDefinition Height="261" />
        <RowDefinition Height="21" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="90" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Image Source="Assets/Brand/velune-app-icon.png"
               Width="74"
               Height="74"
               HorizontalAlignment="Left"
               VerticalAlignment="Center" />

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="5">
          <TextBlock Text="{x:Bind ViewModel.Labels.AppName}"
                     Foreground="{ThemeResource WelcomeTextPrimaryBrush}"
                     FontSize="20"
                     FontWeight="SemiBold" />
          <TextBlock Text="{x:Bind ViewModel.Labels.WindowSubtitle}"
                     Style="{StaticResource BodyTextBlockStyle}"
                     Foreground="{ThemeResource WelcomeTextSecondaryBrush}" />
        </StackPanel>

        <Button Grid.Column="2"
                Style="{StaticResource IconButtonStyle}"
                VerticalAlignment="Center"
                Click="OnSettingsClicked"
                AutomationProperties.AutomationId="WelcomeSettingsButton"
                AutomationProperties.Name="{x:Bind ViewModel.Labels.Settings}">
          <FontIcon Glyph="&#xE713;"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="17" />
          <Button.Flyout>
            <MenuFlyout>
              <MenuFlyoutSubItem Text="{x:Bind ViewModel.Labels.PreferencesLanguage}">
                <RadioMenuFlyoutItem Text="{x:Bind ViewModel.Labels.PreferencesEnglish}" Click="OnLanguageClicked" Tag="en" GroupName="Language" x:Name="LanguageEnglishItem" />
                <RadioMenuFlyoutItem Text="{x:Bind ViewModel.Labels.PreferencesFrench}" Click="OnLanguageClicked" Tag="fr" GroupName="Language" x:Name="LanguageFrenchItem" />
                <RadioMenuFlyoutItem Text="{x:Bind ViewModel.Labels.PreferencesSpanish}" Click="OnLanguageClicked" Tag="es" GroupName="Language" x:Name="LanguageSpanishItem" />
              </MenuFlyoutSubItem>
              <MenuFlyoutSubItem Text="{x:Bind ViewModel.Labels.PreferencesTheme}">
                <RadioMenuFlyoutItem Text="{x:Bind ViewModel.Labels.PreferencesSystem}" Click="OnThemeClicked" Tag="System" GroupName="Theme" x:Name="ThemeSystemItem" />
                <RadioMenuFlyoutItem Text="{x:Bind ViewModel.Labels.PreferencesLight}" Click="OnThemeClicked" Tag="Light" GroupName="Theme" x:Name="ThemeLightItem" />
                <RadioMenuFlyoutItem Text="{x:Bind ViewModel.Labels.PreferencesDark}" Click="OnThemeClicked" Tag="Dark" GroupName="Theme" x:Name="ThemeDarkItem" />
              </MenuFlyoutSubItem>
            </MenuFlyout>
          </Button.Flyout>
        </Button>
      </Grid>

      <Grid Grid.Row="2"
            Background="Transparent"
            AllowDrop="True"
            DragOver="OnHomeDropZoneDragOver"
            Drop="OnHomeDropZoneDrop">
        <Rectangle RadiusX="6"
                   RadiusY="6"
                   Fill="Transparent"
                   Stroke="{ThemeResource WelcomeDropZoneStrokeBrush}"
                   StrokeDashArray="4,4"
                   StrokeThickness="1" />

        <StackPanel Width="376"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="9">
          <Canvas Width="56"
                  Height="70"
                  HorizontalAlignment="Center"
                  Margin="0,0,0,3">
            <Canvas.RenderTransform>
              <ScaleTransform ScaleX="0.8" ScaleY="0.8" />
            </Canvas.RenderTransform>
            <Path Data="M13,4 H43 L63,24 V82 H13 Z M43,4 V24 H63"
                  Stroke="{ThemeResource WelcomeDropIconBrush}"
                  StrokeThickness="3"
                  StrokeLineJoin="Round"
                  Fill="Transparent" />
            <Ellipse Canvas.Left="25"
                     Canvas.Top="37"
                     Width="9"
                     Height="9"
                     Stroke="{ThemeResource WelcomeDropIconBrush}"
                     StrokeThickness="3" />
            <Path Data="M16,67 L34,49 L45,60 L52,54 L64,67"
                  Stroke="{ThemeResource WelcomeDropIconBrush}"
                     StrokeThickness="3"
                  StrokeLineJoin="Round"
                  StrokeStartLineCap="Round"
                     StrokeEndLineCap="Round"
                     Fill="Transparent" />
          </Canvas>

          <TextBlock Text="{x:Bind ViewModel.Labels.WelcomeDropTitle}"
                     Style="{StaticResource SubtitleTextBlockStyle}"
                     Foreground="{ThemeResource WelcomeTextPrimaryBrush}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center" />

          <TextBlock Text="{x:Bind ViewModel.Labels.WelcomeSupportedFormats}"
                     Foreground="{ThemeResource WelcomeTextSubtleBrush}"
                     FontSize="13"
                     HorizontalAlignment="Center"
                     TextAlignment="Center" />

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="11"
                      Margin="0,6,0,0">
            <Button Click="OnOpenFilesClicked"
                    Style="{StaticResource PrimaryWelcomeButtonStyle}"
                    AutomationProperties.AutomationId="WelcomeOpenFilesButton"
                    AutomationProperties.Name="{x:Bind ViewModel.Labels.WelcomeOpenFiles}">
              <StackPanel Orientation="Horizontal"
                          Spacing="10"
                          VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8E5;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="17" />
                <TextBlock Text="{x:Bind ViewModel.Labels.WelcomeOpenFiles}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button Command="{x:Bind ViewModel.MergeCommand}"
                    Style="{StaticResource SecondaryWelcomeButtonStyle}"
                    AutomationProperties.AutomationId="WelcomeMergeButton"
                    AutomationProperties.Name="{x:Bind ViewModel.Labels.WelcomeMergePdf}">
              <StackPanel Orientation="Horizontal"
                          Spacing="10"
                          VerticalAlignment="Center">
                <FontIcon Glyph="&#xE8B7;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="17" />
                <TextBlock Text="{x:Bind ViewModel.Labels.WelcomeMergePdf}"
                           FontSize="13"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>

          <Button Click="OnOpenFilesClicked"
                  Margin="0,4,0,0"
                  Padding="3,2"
                  Background="Transparent"
                  BorderThickness="0"
                  HorizontalAlignment="Center"
                  Foreground="{ThemeResource WelcomeAccentTextBrush}"
                  AutomationProperties.AutomationId="WelcomeBrowseDeviceButton"
                  AutomationProperties.Name="{x:Bind ViewModel.Labels.WelcomeBrowseDevice}">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <FontIcon Glyph="&#xE838;"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="14"
                        Foreground="{ThemeResource WelcomeAccentTextBrush}" />
              <TextBlock Text="{x:Bind ViewModel.Labels.WelcomeBrowseDevice}"
                         FontSize="13"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <Grid Grid.Row="4"
            Visibility="{x:Bind ViewModel.ShowRecentFilesFooter, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
        <Grid.RowDefinitions>
          <RowDefinition Height="30" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{x:Bind ViewModel.Labels.RecentTitle}"
                   Foreground="{ThemeResource WelcomeTextPrimaryBrush}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />

        <Button Grid.Row="0"
                Style="{StaticResource ClearRecentButtonStyle}"
                HorizontalAlignment="Right"
                Command="{x:Bind ViewModel.ClearRecentFilesCommand}"
                AutomationProperties.AutomationId="WelcomeClearRecentButton"
                AutomationProperties.Name="{x:Bind ViewModel.Labels.RecentClear}">
          <StackPanel Orientation="Horizontal"
                      Spacing="6"
                      VerticalAlignment="Center">
            <FontIcon Glyph="&#xE74D;"
                      FontFamily="Segoe Fluent Icons"
                      FontSize="15" />
            <TextBlock Text="{x:Bind ViewModel.Labels.RecentClear}"
                       FontSize="11"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.RecentFiles, Mode=OneWay}"
                  ItemContainerStyle="{StaticResource RecentListViewItemStyle}"
                  IsItemClickEnabled="True"
                  ItemClick="OnRecentFileItemClick"
                  SelectionMode="None"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="0"
                  AutomationProperties.AutomationId="WelcomeRecentFilesList">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="dto:RecentFileItem">
              <Grid Height="58"
                    Margin="0,0,0,4"
                    PointerEntered="OnRecentFilePointerEntered"
                    PointerExited="OnRecentFilePointerExited">
                <Border Background="{ThemeResource WelcomeCardBgBrush}"
                        BorderBrush="{ThemeResource WelcomeCardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource MediumCornerRadius}" />
                <Rectangle x:Name="AccentBar"
                           Width="3"
                           Height="28"
                           RadiusX="1.5"
                           RadiusY="1.5"
                           Fill="{ThemeResource WelcomePrimaryBgBrush}"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0"
                           Opacity="0" />

                <Grid Padding="19,0,14,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="176" />
                    <ColumnDefinition Width="34" />
                  </Grid.ColumnDefinitions>

                  <Grid Grid.Column="0"
                        Width="28"
                        Height="26"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                    <Grid Visibility="{x:Bind FileName, Converter={StaticResource RecentFilePdfVisibility}}">
                      <Path Data="M5,1 H17 L24,8 V31 H5 Z M17,1 V8 H24"
                            Stroke="{ThemeResource PdfBadgeBrush}"
                            StrokeThickness="1.2"
                            StrokeLineJoin="Round"
                            Fill="Transparent" />
                      <Border Width="22"
                              Height="10"
                              Background="{ThemeResource PdfBadgeBrush}"
                              CornerRadius="2"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Bottom"
                              Margin="0,0,0,2">
                        <TextBlock Text="PDF"
                                   Foreground="{ThemeResource WelcomePrimaryFgBrush}"
                                   FontSize="6"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                      </Border>
                    </Grid>

                    <FontIcon Glyph="&#xEB9F;"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="{x:Bind FileName, Converter={StaticResource RecentFileBrush}}"
                              FontSize="22"
                              Width="22"
                              Height="22"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Visibility="{x:Bind FileName, Converter={StaticResource RecentFileImageVisibility}}" />
                  </Grid>

                  <StackPanel Grid.Column="1"
                              VerticalAlignment="Center"
                              Spacing="2">
                    <TextBlock Text="{x:Bind FileName}"
                               Foreground="{ThemeResource WelcomeTextPrimaryBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />
                    <TextBlock Text="{x:Bind DocumentType}"
                               Foreground="{ThemeResource WelcomeTextSecondaryBrush}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap" />
                  </StackPanel>

                  <TextBlock Grid.Column="2"
                             Text="{x:Bind OpenedAt, Converter={StaticResource RecentFileOpenedAt}}"
                             Foreground="{ThemeResource WelcomeTextSecondaryBrush}"
                             FontSize="12"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center" />

                  <FontIcon Grid.Column="3"
                            Glyph="&#xE712;"
                            FontFamily="Segoe Fluent Icons"
                            Foreground="{ThemeResource WelcomeTextPrimaryBrush}"
                            FontSize="15"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                </Grid>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>

      <TextBlock Grid.Row="4"
                 Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                 Foreground="{ThemeResource WelcomeTextSecondaryBrush}"
                 FontSize="12"
                 VerticalAlignment="Top"
                 Visibility="{x:Bind ViewModel.ShowStatusFooter, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
  </Grid>
</Window>
