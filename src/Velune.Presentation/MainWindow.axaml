<Window
    x:Class="Velune.Presentation.Views.MainWindow"
    x:Name="RootWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="1280"
    Height="860"
    MinWidth="1000"
    MinHeight="700"
    Icon="avares://Velune.Presentation/Assets/Brand/velune-app-icon.png"
    KeyDown="OnWindowKeyDown"
    SizeChanged="OnWindowSizeChanged"
    Title="{Binding Title}">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenCommand}" />
    <KeyBinding Gesture="Meta+O" Command="{Binding OpenCommand}" />
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveDocumentCommand}" />
    <KeyBinding Gesture="Meta+S" Command="{Binding SaveDocumentCommand}" />
    <KeyBinding Gesture="Ctrl+P" Command="{Binding PrintDocumentCommand}" />
    <KeyBinding Gesture="Meta+P" Command="{Binding PrintDocumentCommand}" />
    <KeyBinding Gesture="Ctrl+F" Command="{Binding ToggleSearchPanelCommand}" />
    <KeyBinding Gesture="Meta+F" Command="{Binding ToggleSearchPanelCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+A" Command="{Binding ToggleAnnotationsPanelCommand}" />
    <KeyBinding Gesture="Meta+Shift+A" Command="{Binding ToggleAnnotationsPanelCommand}" />
    <KeyBinding Gesture="Ctrl+Add" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Ctrl+OemPlus" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Meta+Add" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Meta+OemPlus" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Ctrl+Subtract" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Ctrl+OemMinus" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Meta+Subtract" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Meta+OemMinus" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+Up" Command="{Binding MoveCurrentPageEarlierCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+Down" Command="{Binding MoveCurrentPageLaterCommand}" />
    <KeyBinding Gesture="Meta+Shift+Up" Command="{Binding MoveCurrentPageEarlierCommand}" />
    <KeyBinding Gesture="Meta+Shift+Down" Command="{Binding MoveCurrentPageLaterCommand}" />
    <KeyBinding Gesture="Right" Command="{Binding NextPageCommand}" />
    <KeyBinding Gesture="Left" Command="{Binding PreviousPageCommand}" />
    <KeyBinding Gesture="PageDown" Command="{Binding NextPageCommand}" />
    <KeyBinding Gesture="PageUp" Command="{Binding PreviousPageCommand}" />
  </Window.KeyBindings>

  <NativeMenu.Menu>
    <NativeMenu>
      <NativeMenuItem Header="File">
        <NativeMenu>
          <NativeMenuItem Header="Open..."
                          Command="{Binding OpenCommand}"
                          Gesture="Meta+O" />
          <NativeMenuItem Header="Save"
                          Command="{Binding SaveDocumentCommand}"
                          Gesture="Meta+S" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Print..."
                          Command="{Binding PrintDocumentCommand}"
                          Gesture="Meta+P" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Close"
                          Command="{Binding CloseCommand}" />
        </NativeMenu>
      </NativeMenuItem>

      <NativeMenuItem Header="Page">
        <NativeMenu>
          <NativeMenuItem Header="Previous Page"
                          Command="{Binding PreviousPageCommand}" />
          <NativeMenuItem Header="Next Page"
                          Command="{Binding NextPageCommand}" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Rotate Left"
                          Command="{Binding RotateLeftCommand}" />
          <NativeMenuItem Header="Rotate Right"
                          Command="{Binding RotateRightCommand}" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Move Page Earlier"
                          Command="{Binding MoveCurrentPageEarlierCommand}" />
          <NativeMenuItem Header="Move Page Later"
                          Command="{Binding MoveCurrentPageLaterCommand}" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Extract Current Page"
                          Command="{Binding ExtractCurrentPageCommand}" />
          <NativeMenuItem Header="Delete Current Page"
                          Command="{Binding DeleteCurrentPageCommand}" />
        </NativeMenu>
      </NativeMenuItem>

      <NativeMenuItem Header="View">
        <NativeMenu>
          <NativeMenuItem Header="Show Pages Sidebar"
                          Command="{Binding ToggleSidebarCommand}" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Search"
                          Command="{Binding ToggleSearchPanelCommand}"
                          IsEnabled="{Binding IsSearchAvailableForCurrentDocument}"
                          Gesture="Meta+F" />
          <NativeMenuItem Header="Information"
                          Command="{Binding ToggleInfoPanelCommand}" />
          <NativeMenuItem Header="Preferences"
                          Command="{Binding TogglePreferencesPanelCommand}"
                          Gesture="Meta+OemComma" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Zoom In"
                          Command="{Binding ZoomInCommand}" />
          <NativeMenuItem Header="Zoom Out"
                          Command="{Binding ZoomOutCommand}" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Fit to Width"
                          Command="{Binding FitToWidthCommand}" />
          <NativeMenuItem Header="Fit to Page"
                          Command="{Binding FitToPageCommand}" />
        </NativeMenu>
      </NativeMenuItem>

      <NativeMenuItem Header="Annotate">
        <NativeMenu>
          <NativeMenuItem Header="Show Annotations"
                          Command="{Binding ToggleAnnotationsPanelCommand}"
                          Gesture="Meta+Shift+A" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Select Tool"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Select" />
          <NativeMenuItem Header="Highlight Selection"
                          Command="{Binding AddHighlightAnnotationFromSelectionCommand}"
                          IsEnabled="{Binding CanCreateHighlightAnnotation}" />
          <NativeMenuItem Header="Freehand"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Ink" />
          <NativeMenuItem Header="Rectangle"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Rectangle" />
          <NativeMenuItem Header="Text"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Text" />
          <NativeMenuItem Header="Note"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Note" />
          <NativeMenuItem Header="Stamp"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Stamp" />
          <NativeMenuItem Header="Signature"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Signature" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="Delete Selected Annotation"
                          Command="{Binding DeleteSelectedAnnotationCommand}" />
          <NativeMenuItem Header="Undo Annotation"
                          Command="{Binding UndoAnnotationsCommand}" />
          <NativeMenuItem Header="Redo Annotation"
                          Command="{Binding RedoAnnotationsCommand}" />
        </NativeMenu>
      </NativeMenuItem>
    </NativeMenu>
  </NativeMenu.Menu>

  <Grid RowDefinitions="Auto,Auto,*,Auto">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Menu Grid.Row="0"
          Grid.Column="0"
          Grid.ColumnSpan="2"
          IsVisible="{Binding ShowWindowMenuBar}">
      <MenuItem Header="_Velune">
        <MenuItem Header="_About Velune..."
                  Click="OnAboutMenuClicked" />
        <MenuItem Header="_Preferences"
                  Command="{Binding TogglePreferencesPanelCommand}" />
      </MenuItem>

      <MenuItem Header="_File">
        <MenuItem Header="_Open..."
                  Command="{Binding OpenCommand}" />
        <MenuItem Header="_Save"
                  Command="{Binding SaveDocumentCommand}" />
        <Separator />
        <MenuItem Header="_Print..."
                  Command="{Binding PrintDocumentCommand}" />
        <Separator />
        <MenuItem Header="_Close"
                  Command="{Binding CloseCommand}" />
      </MenuItem>

      <MenuItem Header="_Page">
        <MenuItem Header="_Previous Page"
                  Command="{Binding PreviousPageCommand}" />
        <MenuItem Header="_Next Page"
                  Command="{Binding NextPageCommand}" />
        <Separator />
        <MenuItem Header="Rotate _Left"
                  Command="{Binding RotateLeftCommand}" />
        <MenuItem Header="Rotate _Right"
                  Command="{Binding RotateRightCommand}" />
        <Separator />
        <MenuItem Header="Move Page _Earlier"
                  Command="{Binding MoveCurrentPageEarlierCommand}" />
        <MenuItem Header="Move Page _Later"
                  Command="{Binding MoveCurrentPageLaterCommand}" />
        <Separator />
        <MenuItem Header="_Extract Current Page"
                  Command="{Binding ExtractCurrentPageCommand}" />
        <MenuItem Header="_Delete Current Page"
                  Command="{Binding DeleteCurrentPageCommand}" />
      </MenuItem>

      <MenuItem Header="_View">
        <MenuItem Header="Show _Pages Sidebar"
                  Command="{Binding ToggleSidebarCommand}" />
        <Separator />
        <MenuItem Header="_Search"
                  Command="{Binding ToggleSearchPanelCommand}"
                  IsEnabled="{Binding IsSearchAvailableForCurrentDocument}" />
        <MenuItem Header="_Information"
                  Command="{Binding ToggleInfoPanelCommand}" />
        <MenuItem Header="_Preferences"
                  Command="{Binding TogglePreferencesPanelCommand}" />
        <Separator />
        <MenuItem Header="Zoom _In"
                  Command="{Binding ZoomInCommand}" />
        <MenuItem Header="Zoom _Out"
                  Command="{Binding ZoomOutCommand}" />
        <Separator />
        <MenuItem Header="Fit to _Width"
                  Command="{Binding FitToWidthCommand}" />
        <MenuItem Header="Fit to _Page"
                  Command="{Binding FitToPageCommand}" />
      </MenuItem>

      <MenuItem Header="_Annotate">
        <MenuItem Header="Show _Annotations"
                  Command="{Binding ToggleAnnotationsPanelCommand}" />
        <Separator />
        <MenuItem Header="_Select Tool"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Select" />
        <MenuItem Header="_Highlight Selection"
                  Command="{Binding AddHighlightAnnotationFromSelectionCommand}" />
        <MenuItem Header="_Freehand"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Ink" />
        <MenuItem Header="_Rectangle"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Rectangle" />
        <MenuItem Header="_Text"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Text" />
        <MenuItem Header="_Note"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Note" />
        <MenuItem Header="_Stamp"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Stamp" />
        <MenuItem Header="_Signature"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Signature" />
        <Separator />
        <MenuItem Header="_Delete Selected"
                  Command="{Binding DeleteSelectedAnnotationCommand}" />
        <MenuItem Header="_Undo"
                  Command="{Binding UndoAnnotationsCommand}" />
        <MenuItem Header="_Redo"
                  Command="{Binding RedoAnnotationsCommand}" />
      </MenuItem>
    </Menu>

    <!-- Header -->
    <Border x:Name="HeaderHostBorder"
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="18,14"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,0,1"
            Background="{DynamicResource Brush.Surface}">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Left"
                    Orientation="Horizontal"
                    VerticalAlignment="Top"
                    Spacing="14"
                    Margin="0,0,20,0">
          <Grid MaxWidth="{Binding HeaderTitleMaxWidth}"
                Width="{Binding HeaderTitleMaxWidth}"
                VerticalAlignment="Center">
            <StackPanel Spacing="2"
                        IsVisible="{Binding ShouldEmphasizeOpenAction}">
              <TextBlock Text="{Binding HeaderTitle}"
                         Classes="title"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Text="{Binding HeaderSubtitle}"
                         Classes="muted"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <StackPanel Spacing="2"
                        IsVisible="{Binding HasOpenDocument}">
              <TextBox x:Name="DocumentNameEditorTextBox"
                       Classes="header-title-input"
                       Text="{Binding EditableDocumentName}"
                       Watermark="Document name"
                       ToolTip.Tip="Click to edit the save name"
                       KeyDown="OnDocumentNameInputKeyDown"
                       GotFocus="OnDocumentNameInputGotFocus"
                       LostFocus="OnDocumentNameInputLostFocus" />
              <TextBlock Text="{Binding HeaderSubtitle}"
                         Classes="muted"
                         TextTrimming="CharacterEllipsis"
                         ToolTip.Tip="{Binding CurrentDocumentPath}" />
            </StackPanel>
          </Grid>

          <Button Classes="header-action-button sidebar-toggle-button"
                  Command="{Binding ToggleSidebarCommand}"
                  IsVisible="{Binding CanToggleSidebar}"
                  ToolTip.Tip="{Binding SidebarToggleLabel}">
            <materialIcons:MaterialIcon Classes="toolbar-icon"
                                        Kind="Menu"
                                        Width="18"
                                        Height="18" />
          </Button>

          <Border Classes="header-chip-group"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="toolbar-primary-button"
                      Command="{Binding OpenCommand}"
                      IsVisible="{Binding ShouldEmphasizeOpenAction}"
                      ToolTip.Tip="Open a document">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                  <materialIcons:MaterialIcon Classes="toolbar-primary-icon"
                                              Kind="FolderOpenOutline"
                                              Width="20"
                                              Height="20" />
                  <TextBlock Text="Open"
                             Classes="toolbar-primary-label" />
                </StackPanel>
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding OpenCommand}"
                      IsVisible="{Binding HasOpenDocument}"
                      ToolTip.Tip="Open another document">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                  <materialIcons:MaterialIcon Classes="toolbar-icon"
                                              Kind="FolderOpenOutline"
                                              Width="18"
                                              Height="18" />
                  <TextBlock Text="Open"
                             Classes="header-action-label" />
                </StackPanel>
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding PrintDocumentCommand}"
                      IsVisible="{Binding HasOpenDocument}"
                      ToolTip.Tip="Print the current document">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="PrinterOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding CloseCommand}"
                      IsVisible="{Binding HasOpenDocument}"
                      ToolTip.Tip="Close the current document">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="Close"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>

        <WrapPanel VerticalAlignment="Top">
          <Border Classes="header-pill header-flex-item"
                  IsVisible="{Binding IsPageNavigationVisible}">
            <StackPanel Orientation="Horizontal"
                        Spacing="6">
              <Button Classes="header-pill-button"
                      Command="{Binding PreviousPageCommand}"
                      ToolTip.Tip="Previous page">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="ChevronLeft"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Border Classes="header-pill-divider" />

              <TextBox Classes="header-page-input"
                       Width="46"
                       Text="{Binding GoToPageInput}"
                       IsEnabled="{Binding CanGoToPage}"
                       ToolTip.Tip="Enter a page number then press Enter"
                       KeyDown="OnGoToPageInputKeyDown" />

              <TextBlock Text="/"
                         Classes="header-pill-text header-pill-muted" />
              <TextBlock Text="{Binding TotalPages}"
                         Classes="header-pill-text" />

              <Border Classes="header-pill-divider" />

              <Button Classes="header-pill-button"
                      Command="{Binding NextPageCommand}"
                      ToolTip.Tip="Next page">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="ChevronRight"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>

          <Border Classes="header-pill header-flex-item"
                  IsVisible="{Binding HasOpenDocument}">
            <StackPanel Orientation="Horizontal"
                        Spacing="6">
              <Button Classes="header-pill-button"
                      Command="{Binding ZoomOutCommand}"
                      ToolTip.Tip="Zoom out">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="MagnifyMinusOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Border Classes="header-pill-divider" />

              <TextBlock Text="{Binding CurrentZoom}"
                         Classes="header-pill-text" />

              <Border Classes="header-pill-divider" />

              <Button Classes="header-pill-button"
                      Command="{Binding FitToWidthCommand}"
                      ToolTip.Tip="Fit to width">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="ArrowExpandHorizontal"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-pill-button"
                      Command="{Binding FitToPageCommand}"
                      ToolTip.Tip="Fit to page">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="FitToPageOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-pill-button"
                      Command="{Binding ZoomInCommand}"
                      ToolTip.Tip="Zoom in">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="MagnifyPlusOutline"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>

          <Border Classes="header-search-group header-flex-item"
                  IsVisible="{Binding UseInlineHeaderSearch}">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="8">
              <materialIcons:MaterialIcon Grid.Column="0"
                                          Classes="toolbar-icon"
                                          Kind="Magnify"
                                          Width="18"
                                          Height="18"
                                          VerticalAlignment="Center" />

              <TextBox Grid.Column="1"
                       Classes="header-search-input"
                       Width="156"
                       Watermark="Search in document"
                       Text="{Binding SearchQueryInput}"
                       KeyDown="OnSearchInputKeyDown" />

              <Button Grid.Column="2"
                      Classes="header-search-button"
                      Command="{Binding OpenSearchCommand}"
                      ToolTip.Tip="Search in document">
                <TextBlock Text="Search"
                           Classes="header-action-label" />
              </Button>
            </Grid>
          </Border>

          <Border Classes="header-chip-group header-flex-item"
                  IsVisible="{Binding HasOpenDocument}">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="header-action-button"
                      Command="{Binding RotateLeftCommand}"
                      ToolTip.Tip="Rotate left">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="RotateLeftVariant"
                                            Width="18"
                                            Height="18" />
              </Button>

              <TextBlock Text="{Binding CurrentRotation}"
                         Classes="header-chip-label" />

              <Button Classes="header-action-button"
                      Command="{Binding RotateRightCommand}"
                      ToolTip.Tip="Rotate right">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="RotateRightVariant"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>

          <Border Classes="header-chip-group header-flex-item"
                  IsVisible="{Binding HasOpenDocument}">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="header-action-button"
                      Command="{Binding ToggleSearchPanelCommand}"
                      IsVisible="{Binding UseCollapsedHeaderSearchButton}"
                      ToolTip.Tip="Open search">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="Magnify"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding ToggleInfoPanelCommand}"
                      ToolTip.Tip="Show file information">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="InformationCircleOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding ToggleAnnotationsPanelCommand}"
                      ToolTip.Tip="Show annotations">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="PencilOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding TogglePreferencesPanelCommand}"
                      ToolTip.Tip="Show preferences">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="CogOutline"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>
        </WrapPanel>
      </DockPanel>
    </Border>

    <!-- Sidebar -->
    <Border Grid.Row="2"
            Grid.Column="0"
            Width="{Binding SidebarWidth}"
            IsHitTestVisible="{Binding IsSidebarInteractive}"
            Padding="14"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,1,0"
            Background="{DynamicResource Brush.Surface}"
            ClipToBounds="True"
            IsVisible="{Binding SidebarHostVisible}">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Width" Duration="0:0:0.22" />
        </Transitions>
      </Border.Transitions>
      <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0"
                    Spacing="12"
                    Margin="0,0,0,12">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="8">
            <TextBlock Text="{Binding SidebarTitle}"
                       Classes="title"
                       VerticalAlignment="Center" />

            <TextBlock Grid.Column="1"
                       Text="Loading..."
                       Classes="muted"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsGeneratingThumbnails}" />
          </Grid>
        </StackPanel>

        <Grid x:Name="ThumbnailDragSurface"
              Grid.Row="1"
              Width="220"
              MaxWidth="220"
              ClipToBounds="False">
          <ScrollViewer x:Name="ThumbnailScrollViewer"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ThumbnailItemsControl"
                          ItemsSource="{Binding Thumbnails}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="thumbnail-hitbox"
                          ToolTip.Tip="Right-click for page actions"
                          PointerPressed="OnThumbnailPointerPressed"
                          PointerMoved="OnThumbnailPointerMoved"
                          PointerReleased="OnThumbnailPointerReleased"
                          PointerCaptureLost="OnThumbnailPointerCaptureLost"
                          Tapped="OnThumbnailTapped">
                    <Border.ContextMenu>
                      <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Open page"
                                  Command="{Binding DataContext.SelectThumbnailCommand, ElementName=RootWindow}"
                                  CommandParameter="{Binding}" />
                        <MenuItem Header="Extract this page"
                                  Command="{Binding DataContext.ExtractThumbnailPageCommand, ElementName=RootWindow}"
                                  CommandParameter="{Binding}" />
                        <MenuItem Header="Delete this page"
                                  Command="{Binding DataContext.DeleteThumbnailPageCommand, ElementName=RootWindow}"
                                  CommandParameter="{Binding}" />
                      </ContextMenu>
                    </Border.ContextMenu>

                    <Border Classes="thumbnail-item"
                            Classes.selected="{Binding IsSelected}"
                            Classes.dragging="{Binding IsDragging}"
                            Width="200"
                            MaxWidth="200"
                            MinHeight="120">
                      <StackPanel Spacing="8">
                        <Border Classes="thumbnail-image-host"
                                Width="176"
                                MaxWidth="176"
                                Height="154"
                                HorizontalAlignment="Center">
                          <Grid>
                            <Image Source="{Binding Thumbnail}"
                                   Stretch="Uniform"
                                   MaxWidth="170"
                                   MaxHeight="150"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="Loading..."
                                       Classes="muted"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding IsLoading}" />
                          </Grid>
                        </Border>

                        <TextBlock Text="{Binding DisplayPageNumber, StringFormat=Page {0}}"
                                   HorizontalAlignment="Center"
                                   FontWeight="SemiBold" />
                      </StackPanel>
                    </Border>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Canvas x:Name="ThumbnailDragOverlay"
                  IsHitTestVisible="False"
                  ClipToBounds="False">
            <Border x:Name="ThumbnailDropIndicator"
                    Classes="thumbnail-drop-indicator"
                    IsVisible="False" />
            <Border x:Name="ThumbnailDragGhostHost"
                    Classes="thumbnail-drag-ghost"
                    IsVisible="False">
              <Border Classes="thumbnail-item thumbnail-drag-preview-item"
                      Width="200"
                      MaxWidth="200"
                      MinHeight="120">
                <StackPanel Spacing="8">
                  <Border Classes="thumbnail-image-host"
                          Width="180"
                          MaxWidth="180"
                          Height="160"
                          HorizontalAlignment="Center">
                    <Grid>
                      <Image x:Name="ThumbnailDragGhostPreviewImage"
                             Stretch="Uniform"
                             MaxWidth="170"
                             MaxHeight="150"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                      <TextBlock x:Name="ThumbnailDragGhostLoadingText"
                                 Text="Loading..."
                                 Classes="muted"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 IsVisible="False" />
                    </Grid>
                  </Border>

                  <TextBlock x:Name="ThumbnailDragGhostPageLabel"
                             HorizontalAlignment="Center"
                             FontWeight="SemiBold" />
                </StackPanel>
              </Border>
            </Border>
          </Canvas>
        </Grid>
      </Grid>
    </Border>

    <!-- Main content -->
    <Grid Grid.Row="2"
          Grid.Column="1"
          ColumnDefinitions="*,Auto"
          Background="{DynamicResource Brush.Background}">

      <!-- Toast -->
      <Border Classes="banner"
              Grid.ColumnSpan="2"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="16"
              Padding="12,10"
              MinWidth="320"
              MaxWidth="460"
              ZIndex="10"
              IsVisible="{Binding HasUserMessage}">
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="Auto,*">
            <materialIcons:MaterialIcon Grid.Column="0"
                                        Kind="{Binding NotificationIconKind}"
                                        Width="18"
                                        Height="18"
                                        Foreground="{DynamicResource Brush.Accent}"
                                        VerticalAlignment="Top"
                                        Margin="0,1,10,0" />

            <StackPanel Grid.Column="1"
                        Spacing="4">
              <TextBlock Text="{Binding UserMessageTitle}"
                         FontWeight="SemiBold"
                         IsVisible="{Binding HasUserMessageTitle}" />

              <TextBlock Text="{Binding UserMessage}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <Button Content="{Binding NotificationSecondaryActionLabel}"
                    Command="{Binding NotificationSecondaryActionCommand}"
                    IsVisible="{Binding HasNotificationSecondaryAction}" />

            <Button Content="{Binding NotificationPrimaryActionLabel}"
                    Command="{Binding NotificationPrimaryActionCommand}"
                    IsVisible="{Binding HasNotificationPrimaryAction}" />

            <Button Content="Dismiss"
                    Command="{Binding DismissMessageCommand}"
                    IsVisible="{Binding CanDismissUserMessage}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Empty state -->
      <StackPanel HorizontalAlignment="Center"
                  Grid.ColumnSpan="2"
                  VerticalAlignment="Center"
                  Spacing="18"
                  MaxWidth="560"
                  IsVisible="{Binding IsEmptyStateVisible}">
        <Grid Width="286"
              Height="286"
              HorizontalAlignment="Center">
          <Ellipse Width="286"
                   Height="286"
                   Fill="{DynamicResource Brush.BrandHalo}" />

          <Border Classes="empty-state-brand-shell"
                  Width="248"
                  Height="248"
                  Padding="18"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
            <Image Source="avares://Velune.Presentation/Assets/Brand/velune-logo.png"
                   Stretch="Uniform"
                   Width="212"
                   Height="212"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
          </Border>
        </Grid>

        <TextBlock Text="{Binding EmptyStateTitle}"
                   Classes="hero"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />

        <TextBlock Text="{Binding EmptyStateDescription}"
                   Classes="muted"
                   FontSize="{DynamicResource FontSize.BodyLarge}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8">
          <Button Content="Open a file"
                  Width="140"
                  HorizontalAlignment="Center"
                  Command="{Binding OpenCommand}" />
        </StackPanel>

        <Border Classes="card"
                Padding="16"
                Margin="0,12,0,0"
                IsVisible="{Binding HasRecentFiles}">
          <StackPanel Spacing="10">
            <DockPanel LastChildFill="False">
              <TextBlock Text="Recent files"
                         Classes="title"
                         VerticalAlignment="Center" />

              <Button Content="Clear"
                      DockPanel.Dock="Right"
                      Command="{Binding ClearRecentFilesCommand}" />
            </DockPanel>

            <ItemsControl ItemsSource="{Binding RecentFiles}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Classes="recent-file-button"
                          Command="{Binding $parent[Window].DataContext.OpenRecentFileCommand}"
                          CommandParameter="{Binding}"
                          HorizontalContentAlignment="Stretch">
                    <Border Classes="recent-file-item">
                      <StackPanel>
                        <TextBlock Text="{Binding FileName}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding DocumentType}"
                                   Classes="muted" />
                        <TextBlock Text="{Binding FilePath}"
                                   Classes="muted"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- Viewer -->
      <Grid Margin="24"
            Grid.Column="0"
            IsVisible="{Binding HasOpenDocument}">
        <Grid Margin="12"
              SizeChanged="OnDocumentViewerSizeChanged">
          <Grid IsVisible="{Binding IsImageAutoFitActive}">
              <Viewbox Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Grid x:Name="AutoFitDocumentInteractionLayer"
                      Width="{Binding DisplayedRenderedPageWidth}"
                      Height="{Binding DisplayedRenderedPageHeight}">
                  <Image Source="{Binding CurrentRenderedBitmap}"
                         Stretch="None"
                         Width="{Binding DisplayedRenderedPageWidth}"
                         Height="{Binding DisplayedRenderedPageHeight}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />

                  <Image Source="{Binding CurrentAnnotationOverlayBitmap}"
                         Stretch="None"
                         Width="{Binding DisplayedRenderedPageWidth}"
                         Height="{Binding DisplayedRenderedPageHeight}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         IsHitTestVisible="False" />

                  <ItemsControl ItemsSource="{Binding SearchHighlights}"
                                IsVisible="{Binding HasSearchHighlights}"
                                IsHitTestVisible="False">
                    <ItemsControl.Styles>
                      <Style Selector="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                      </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="search-highlight"
                                Width="{Binding Width}"
                                Height="{Binding Height}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <ItemsControl ItemsSource="{Binding TextSelectionHighlights}"
                                IsVisible="{Binding HasTextSelectionHighlights}"
                                IsHitTestVisible="False">
                    <ItemsControl.Styles>
                      <Style Selector="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                      </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="text-selection-highlight"
                                Width="{Binding Width}"
                                Height="{Binding Height}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <Border Background="Transparent"
                          PointerPressed="OnDocumentTextSelectionPointerPressed"
                          PointerMoved="OnDocumentTextSelectionPointerMoved"
                          PointerReleased="OnDocumentTextSelectionPointerReleased"
                          PointerCaptureLost="OnDocumentTextSelectionPointerCaptureLost" />

                  <Border Background="Transparent"
                          IsHitTestVisible="{Binding IsAnnotationModeActive}"
                          PointerPressed="OnAnnotationPointerPressed"
                          PointerMoved="OnAnnotationPointerMoved"
                          PointerReleased="OnAnnotationPointerReleased"
                          PointerCaptureLost="OnAnnotationPointerCaptureLost" />
                </Grid>
              </Viewbox>
            </Grid>

          <ScrollViewer x:Name="DocumentScrollViewer"
                        IsVisible="{Binding IsScrollableViewerVisible}"
                        PointerWheelChanged="OnDocumentPointerWheelChanged"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
            <Grid x:Name="ScrollableDocumentInteractionLayer"
                  Width="{Binding DisplayedRenderedPageWidth}"
                  Height="{Binding DisplayedRenderedPageHeight}"
                  HorizontalAlignment="{Binding ScrollableDocumentHorizontalAlignment}"
                  VerticalAlignment="Top">
              <Image Source="{Binding CurrentRenderedBitmap}"
                     Stretch="None"
                     Width="{Binding DisplayedRenderedPageWidth}"
                     Height="{Binding DisplayedRenderedPageHeight}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top" />

              <Image Source="{Binding CurrentAnnotationOverlayBitmap}"
                     Stretch="None"
                     Width="{Binding DisplayedRenderedPageWidth}"
                     Height="{Binding DisplayedRenderedPageHeight}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top"
                     IsHitTestVisible="False" />

              <ItemsControl ItemsSource="{Binding SearchHighlights}"
                            IsVisible="{Binding HasSearchHighlights}"
                            IsHitTestVisible="False">
                <ItemsControl.Styles>
                  <Style Selector="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                  </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <Canvas />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="search-highlight"
                            Width="{Binding Width}"
                            Height="{Binding Height}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <ItemsControl ItemsSource="{Binding TextSelectionHighlights}"
                            IsVisible="{Binding HasTextSelectionHighlights}"
                            IsHitTestVisible="False">
                <ItemsControl.Styles>
                  <Style Selector="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                  </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <Canvas />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="text-selection-highlight"
                            Width="{Binding Width}"
                            Height="{Binding Height}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Border Background="Transparent"
                      PointerPressed="OnDocumentTextSelectionPointerPressed"
                      PointerMoved="OnDocumentTextSelectionPointerMoved"
                      PointerReleased="OnDocumentTextSelectionPointerReleased"
                      PointerCaptureLost="OnDocumentTextSelectionPointerCaptureLost" />

              <Border Background="Transparent"
                      IsHitTestVisible="{Binding IsAnnotationModeActive}"
                      PointerPressed="OnAnnotationPointerPressed"
                      PointerMoved="OnAnnotationPointerMoved"
                      PointerReleased="OnAnnotationPointerReleased"
                      PointerCaptureLost="OnAnnotationPointerCaptureLost" />
            </Grid>
          </ScrollViewer>

          <Border Classes="banner"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Padding="12,10"
                  IsVisible="{Binding ShowRenderingBanner}">
            <TextBlock Text="Rendering..."
                       Classes="muted" />
          </Border>
          </Grid>
      </Grid>

      <!-- Info panel -->
      <Border Grid.Column="1"
              Width="{Binding InfoPanelWidth}"
              IsHitTestVisible="{Binding IsInfoPanelInteractive}"
              Margin="0,24,24,24"
              Padding="18,16"
              Classes="card info-panel"
              Background="{DynamicResource Brush.Surface}"
              ClipToBounds="True"
              IsVisible="{Binding IsInfoPanelOpen}">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.22" />
          </Transitions>
        </Border.Transitions>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="Informations"
                         Classes="title" />
              <TextBlock Text="{Binding CurrentDocumentName}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="{Binding CurrentDocumentType}"
                         Classes="muted" />
            </StackPanel>

            <Border Classes="banner"
                    Padding="10,8"
                    IsVisible="{Binding HasDocumentInfoWarning}">
              <TextBlock Text="{Binding DocumentInfoWarning}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </Border>

            <ItemsControl ItemsSource="{Binding DocumentInfoItems}"
                          IsVisible="{Binding HasDocumentInfo}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="96,*"
                        ColumnSpacing="12"
                        Margin="0,0,0,10">
                    <TextBlock Text="{Binding Label}"
                               Classes="metadata-label"
                               VerticalAlignment="Top" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Value}"
                               TextWrapping="Wrap" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Search panel -->
      <Border Grid.Column="1"
              Width="{Binding SearchPanelWidth}"
              IsHitTestVisible="{Binding IsSearchPanelInteractive}"
              Margin="0,24,24,24"
              Padding="0"
              Classes="card info-panel"
              Background="{DynamicResource Brush.Surface}"
              ClipToBounds="True"
              IsVisible="{Binding IsSearchPanelOpen}">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.22" />
          </Transitions>
        </Border.Transitions>
        <Grid RowDefinitions="Auto,*">
          <Grid Grid.Row="0"
                ColumnDefinitions="*,Auto"
                ColumnSpacing="8"
                Margin="18,16,18,0">
            <StackPanel Grid.Column="0"
                        Spacing="4">
              <TextBlock Text="Search"
                         Classes="title" />
              <TextBlock Text="{Binding CurrentDocumentName}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="Search inside the current document or recognize text locally when needed."
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Button Grid.Column="1"
                    Classes="panel-close-button"
                    Command="{Binding ToggleSearchPanelCommand}"
                    ToolTip.Tip="Close search">
              <materialIcons:MaterialIcon Classes="toolbar-icon"
                                          Kind="Close"
                                          Width="18"
                                          Height="18" />
            </Button>
          </Grid>

          <ScrollViewer Grid.Row="1"
                        Margin="0,14,0,0"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <Border Padding="18,0,12,16">
              <StackPanel Spacing="18">
                <Border Classes="banner"
                        Padding="10,8"
                        IsVisible="{Binding HasSearchPanelNotice}">
                  <TextBlock Text="{Binding SearchPanelNotice}"
                             Classes="muted"
                             TextWrapping="Wrap" />
                </Border>

                <StackPanel Spacing="8">
                  <TextBlock Text="Query"
                             Classes="metadata-label" />
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="8">
                    <TextBox Classes="toolbar-input"
                             Grid.Column="0"
                             Watermark="Find text in this document"
                             Text="{Binding SearchQueryInput}" />

                    <Button Grid.Column="1"
                            Content="Search"
                            Command="{Binding SearchTextCommand}" />
                  </Grid>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <Button Content="Recognize text"
                          Command="{Binding RunSearchOcrCommand}"
                          IsVisible="{Binding CanRunDocumentOcr}" />
                  <Button Content="Cancel analysis"
                          Command="{Binding CancelDocumentTextAnalysisCommand}"
                          IsVisible="{Binding CanCancelDocumentTextAnalysis}" />
                </StackPanel>

                <Border Classes="toolbar-group"
                        IsVisible="{Binding HasSearchResults}">
                  <DockPanel LastChildFill="False"
                             Margin="0">
                    <StackPanel DockPanel.Dock="Left"
                                Margin="4"
                                Spacing="0">
                      <TextBlock Text="{Binding SearchResultSummary}"
                                 Classes="toolbar-metric-value" />
                      <TextBlock Text="{Binding SearchSelectionIndicator}"
                                 Classes="toolbar-metric-label" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                Spacing="4">
                      <Button Classes="toolbar-button"
                              Command="{Binding PreviousSearchResultCommand}"
                              ToolTip.Tip="Previous result">
                        <materialIcons:MaterialIcon Classes="toolbar-icon"
                                                    Kind="ChevronUp"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{DynamicResource Brush.Icon}" />
                      </Button>

                      <Button Classes="toolbar-button"
                              Command="{Binding NextSearchResultCommand}"
                              ToolTip.Tip="Next result">
                        <materialIcons:MaterialIcon Classes="toolbar-icon"
                                                    Kind="ChevronDown"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{DynamicResource Brush.Icon}" />
                      </Button>
                    </StackPanel>
                  </DockPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding SearchResults}"
                              IsVisible="{Binding HasSearchResults}">
                  <ItemsControl.Styles>
                    <Style Selector="ContentPresenter">
                      <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style>
                  </ItemsControl.Styles>

                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Classes="search-result-button"
                              Command="{Binding $parent[Window].DataContext.OpenSearchResultCommand}"
                              CommandParameter="{Binding}"
                              HorizontalContentAlignment="Stretch">
                        <Border Classes="search-result-item"
                                Classes.selected="{Binding IsSelected}">
                          <StackPanel Spacing="6">
                            <TextBlock Text="{Binding PageNumber, StringFormat=Page {0}}"
                                       Classes="metadata-label" />
                            <TextBlock Text="{Binding Excerpt}"
                                       TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- Preferences panel -->
      <Border Grid.Column="1"
              Width="{Binding PreferencesPanelWidth}"
              IsHitTestVisible="{Binding IsPreferencesPanelInteractive}"
              Margin="0,24,24,24"
              Padding="18,16"
              Classes="card info-panel"
              Background="{DynamicResource Brush.Surface}"
              ClipToBounds="True"
              IsVisible="{Binding IsPreferencesPanelOpen}">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.22" />
          </Transitions>
        </Border.Transitions>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
            <StackPanel Spacing="4">
              <TextBlock Text="Preferences"
                         Classes="title" />
              <TextBlock Text="Choose the default viewer behavior for the next documents you open."
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Theme"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding ThemePreferenceOptions}"
                        SelectedItem="{Binding SelectedThemePreference}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Default zoom"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding DefaultZoomPreferenceOptions}"
                        SelectedItem="{Binding SelectedDefaultZoomPreference}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Sidebar"
                         Classes="metadata-label" />
              <CheckBox Content="Show page thumbnails for PDF documents"
                        IsChecked="{Binding ShowThumbnailsPanelPreference}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Memory cache size"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding MemoryCacheEntryLimitOptions}"
                        SelectedItem="{Binding SelectedMemoryCacheEntryLimit}" />
              <TextBlock Text="0 disables the in-memory render cache."
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Print panel -->
      <Border Grid.Column="1"
              Width="{Binding PrintPanelWidth}"
              IsHitTestVisible="{Binding IsPrintPanelInteractive}"
              Margin="0,24,24,24"
              Padding="18,16"
              Classes="card info-panel"
              Background="{DynamicResource Brush.Surface}"
              ClipToBounds="True"
              IsVisible="{Binding IsPrintPanelOpen}">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.22" />
          </Transitions>
        </Border.Transitions>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
            <StackPanel Spacing="4">
              <TextBlock Text="Print"
                         Classes="title" />
              <TextBlock Text="{Binding CurrentDocumentName}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="Choose a printer and the basic print options."
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Border Classes="banner"
                    Padding="10,8"
                    IsVisible="{Binding HasPrintPanelNotice}">
              <TextBlock Text="{Binding PrintPanelNotice}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </Border>

            <StackPanel Spacing="8">
              <DockPanel LastChildFill="False">
                <TextBlock Text="Printer"
                           Classes="metadata-label"
                           VerticalAlignment="Center" />
                <Button Content="Refresh"
                        DockPanel.Dock="Right"
                        Command="{Binding RefreshPrintDestinationsCommand}" />
              </DockPanel>

              <ComboBox Classes="preferences-input"
                        SelectedItem="{Binding SelectedPrintDestination}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
                <ComboBox.ItemsSource>
                  <Binding Path="PrintDestinations" />
                </ComboBox.ItemsSource>
              </ComboBox>
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Copies"
                         Classes="metadata-label" />
              <TextBox Classes="toolbar-input"
                       Text="{Binding PrintCopiesInput}" />
            </StackPanel>

            <StackPanel Spacing="8"
                        IsVisible="{Binding IsPrintPageRangeVisible}">
              <TextBlock Text="Pages"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding PrintPageRangeOptions}"
                        SelectedItem="{Binding SelectedPrintPageRangeOption}" />
              <TextBox Classes="toolbar-input"
                       Watermark="1-3,5"
                       Text="{Binding PrintCustomPageRange}"
                       IsVisible="{Binding IsCustomPrintRangeVisible}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Orientation"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding PrintOrientationOptions}"
                        SelectedItem="{Binding SelectedPrintOrientationOption}" />
            </StackPanel>

            <CheckBox Content="Scale content to fit the page"
                      IsChecked="{Binding PrintFitToPage}" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
              <Button Content="Cancel"
                      Command="{Binding PrintDocumentCommand}" />
              <Button Content="Print"
                      Command="{Binding SubmitPrintJobCommand}" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Annotations panel -->
      <Border Grid.Column="1"
              Width="{Binding AnnotationsPanelWidth}"
              IsHitTestVisible="{Binding IsAnnotationsPanelInteractive}"
              Margin="0,24,24,24"
              Padding="18,16"
              Classes="card info-panel"
              Background="{DynamicResource Brush.Surface}"
              ClipToBounds="True"
              IsVisible="{Binding IsAnnotationsPanelOpen}">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.22" />
          </Transitions>
        </Border.Transitions>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="Annotations"
                         Classes="title" />
              <TextBlock Text="Annotate the current page, add a simple signature, then save the updated document."
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Border Classes="banner"
                    Padding="10,8"
                    IsVisible="{Binding HasAnnotationsPanelNotice}">
              <TextBlock Text="{Binding AnnotationsPanelNotice}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </Border>

            <WrapPanel Classes="annotation-tools-wrap"
                       ItemWidth="128"
                       ItemHeight="40">
              <Button Classes="annotation-tool-button"
                      Command="{Binding SelectAnnotationToolCommand}"
                      CommandParameter="Select"
                      Content="Select" />
              <Button Classes="annotation-tool-button"
                      Command="{Binding AddHighlightAnnotationFromSelectionCommand}"
                      IsEnabled="{Binding CanCreateHighlightAnnotation}"
                      Content="Highlight" />
              <Button Classes="annotation-tool-button"
                      Command="{Binding SelectAnnotationToolCommand}"
                      CommandParameter="Ink"
                      Content="Ink" />
              <Button Classes="annotation-tool-button"
                      Command="{Binding SelectAnnotationToolCommand}"
                      CommandParameter="Rectangle"
                      Content="Rectangle" />
              <Button Classes="annotation-tool-button"
                      Command="{Binding SelectAnnotationToolCommand}"
                      CommandParameter="Text"
                      Content="Text" />
              <Button Classes="annotation-tool-button"
                      Command="{Binding SelectAnnotationToolCommand}"
                      CommandParameter="Note"
                      Content="Note" />
              <Button Classes="annotation-tool-button"
                      Command="{Binding SelectAnnotationToolCommand}"
                      CommandParameter="Stamp"
                      Content="Stamp" />
              <Button Classes="annotation-tool-button"
                      Command="{Binding SelectAnnotationToolCommand}"
                      CommandParameter="Signature"
                      Content="Signature" />
            </WrapPanel>

            <StackPanel Spacing="8"
                        IsVisible="{Binding ShowAnnotationTextEditor}">
              <TextBlock Text="Annotation text"
                         Classes="metadata-label" />
              <TextBox Classes="toolbar-input"
                       Text="{Binding AnnotationTextDraft}"
                       Watermark="Text, note or stamp label" />
            </StackPanel>

            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,Auto,Auto"
                    ColumnSpacing="8">
                <TextBlock Grid.Column="0"
                           Text="Signature library"
                           Classes="metadata-label"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Import image"
                        Command="{Binding ImportSignatureAssetCommand}" />
                <Button Grid.Column="2"
                        Classes="annotation-list-delete-button"
                        CommandParameter="{Binding SelectedSignatureAssetId}"
                        Command="{Binding DeleteSelectedSignatureAssetCommand}"
                        ToolTip.Tip="Delete selected signature">
                  <materialIcons:MaterialIcon Classes="toolbar-icon"
                                              Kind="TrashCanOutline"
                                              Width="16"
                                              Height="16" />
                </Button>
              </Grid>

              <ItemsControl ItemsSource="{Binding SignatureAssets}"
                            IsVisible="{Binding HasSignatureAssets}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="annotation-list-item">
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Classes="annotation-list-button"
                                Command="{Binding $parent[Window].DataContext.SelectSignatureAssetCommand}"
                                CommandParameter="{Binding Id}"
                                HorizontalContentAlignment="Stretch">
                          <StackPanel Spacing="2">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding FilePath}"
                                       Classes="muted"
                                       TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                        </Button>

                        <Button Grid.Column="1"
                                Classes="annotation-list-delete-button"
                                Command="{Binding $parent[Window].DataContext.DeleteSelectedSignatureAssetCommand}"
                                CommandParameter="{Binding Id}"
                                ToolTip.Tip="Delete selected signature">
                          <materialIcons:MaterialIcon Classes="toolbar-icon"
                                                      Kind="TrashCanOutline"
                                                      Width="16"
                                                      Height="16" />
                        </Button>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <StackPanel Spacing="8">
                <TextBlock Text="Draw a new signature"
                           Classes="metadata-label" />
                <TextBox Classes="toolbar-input"
                         Text="{Binding SignatureAssetNameInput}"
                         Watermark="Signature name" />

                <Grid>
                  <Image Source="{Binding SignaturePadPreviewBitmap}"
                         Width="248"
                         Height="124"
                         Stretch="Fill" />
                  <Border x:Name="SignaturePadInteractionLayer"
                          Width="248"
                          Height="124"
                          Background="Transparent"
                          PointerPressed="OnSignaturePadPointerPressed"
                          PointerMoved="OnSignaturePadPointerMoved"
                          PointerReleased="OnSignaturePadPointerReleased"
                          PointerCaptureLost="OnSignaturePadPointerCaptureLost" />
                </Grid>

                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <Button Content="Clear drawing"
                          Command="{Binding ClearSignatureCaptureCommand}" />
                  <Button Content="Save signature"
                          Command="{Binding SaveDrawnSignatureAssetCommand}" />
                </StackPanel>
              </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <Button Content="Undo"
                      Command="{Binding UndoAnnotationsCommand}" />
              <Button Content="Redo"
                      Command="{Binding RedoAnnotationsCommand}" />
              <Button Content="Delete selected"
                      Command="{Binding DeleteSelectedAnnotationCommand}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="Current page annotations"
                         Classes="metadata-label" />

              <ItemsControl ItemsSource="{Binding CurrentPageAnnotations}"
                            IsVisible="{Binding HasCurrentPageAnnotations}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Classes="annotation-list-button"
                            Command="{Binding $parent[Window].DataContext.SelectCurrentPageAnnotationCommand}"
                            CommandParameter="{Binding}"
                            HorizontalContentAlignment="Stretch">
                      <Border Classes="annotation-list-item">
                        <StackPanel Spacing="4">
                          <TextBlock Text="{Binding Kind}"
                                     FontWeight="SemiBold" />
                          <TextBlock Text="{Binding Text}"
                                     Classes="muted"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="3"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="12,8"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,1,0,0"
            Background="{DynamicResource Brush.Surface}">
      <TextBlock Text="{Binding StatusText}"
                 Classes="muted" />
    </Border>
  </Grid>
</Window>
