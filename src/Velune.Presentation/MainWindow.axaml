<Window
    x:Class="Velune.Presentation.Views.MainWindow"
    x:Name="RootWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:loc="clr-namespace:Velune.Presentation.Localization"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="1280"
    Height="860"
    MinWidth="1000"
    MinHeight="700"
    Icon="avares://Velune.Presentation/Assets/Brand/velune-app-icon.png"
    KeyDown="OnWindowKeyDown"
    SizeChanged="OnWindowSizeChanged"
    Title="{Binding Title}">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenCommand}" />
    <KeyBinding Gesture="Meta+O" Command="{Binding OpenCommand}" />
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveDocumentCommand}" />
    <KeyBinding Gesture="Meta+S" Command="{Binding SaveDocumentCommand}" />
    <KeyBinding Gesture="Ctrl+P" Command="{Binding PrintDocumentCommand}" />
    <KeyBinding Gesture="Meta+P" Command="{Binding PrintDocumentCommand}" />
    <KeyBinding Gesture="Ctrl+F" Command="{Binding ToggleSearchPanelCommand}" />
    <KeyBinding Gesture="Meta+F" Command="{Binding ToggleSearchPanelCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+A" Command="{Binding ToggleAnnotationsPanelCommand}" />
    <KeyBinding Gesture="Meta+Shift+A" Command="{Binding ToggleAnnotationsPanelCommand}" />
    <KeyBinding Gesture="Ctrl+Add" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Ctrl+OemPlus" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Meta+Add" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Meta+OemPlus" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Ctrl+Subtract" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Ctrl+OemMinus" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Meta+Subtract" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Meta+OemMinus" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+Up" Command="{Binding MoveCurrentPageEarlierCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+Down" Command="{Binding MoveCurrentPageLaterCommand}" />
    <KeyBinding Gesture="Meta+Shift+Up" Command="{Binding MoveCurrentPageEarlierCommand}" />
    <KeyBinding Gesture="Meta+Shift+Down" Command="{Binding MoveCurrentPageLaterCommand}" />
    <KeyBinding Gesture="Right" Command="{Binding NextPageCommand}" />
    <KeyBinding Gesture="Left" Command="{Binding PreviousPageCommand}" />
    <KeyBinding Gesture="PageDown" Command="{Binding NextPageCommand}" />
    <KeyBinding Gesture="PageUp" Command="{Binding PreviousPageCommand}" />
    <KeyBinding Gesture="Ctrl+R" Command="{Binding RotateRightCommand}" />
    <KeyBinding Gesture="Meta+R" Command="{Binding RotateRightCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+R" Command="{Binding RotateLeftCommand}" />
    <KeyBinding Gesture="Meta+Shift+R" Command="{Binding RotateLeftCommand}" />
    <KeyBinding Gesture="Ctrl+D0" Command="{Binding FitToPageCommand}" />
    <KeyBinding Gesture="Meta+D0" Command="{Binding FitToPageCommand}" />
    <KeyBinding Gesture="Ctrl+D1" Command="{Binding FitToWidthCommand}" />
    <KeyBinding Gesture="Meta+D1" Command="{Binding FitToWidthCommand}" />
  </Window.KeyBindings>

  <NativeMenu.Menu>
    <NativeMenu>
      <NativeMenuItem Header="{loc:NativeLoc app.menu.file}">
        <NativeMenu>
          <NativeMenuItem Header="{loc:NativeLoc app.menu.open}"
                          Command="{Binding OpenCommand}"
                          Gesture="Meta+O" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.save}"
                          Command="{Binding SaveDocumentCommand}"
                          Gesture="Meta+S" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.print}"
                          Command="{Binding PrintDocumentCommand}"
                          Gesture="Meta+P" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.close}"
                          Command="{Binding CloseCommand}" />
        </NativeMenu>
      </NativeMenuItem>

      <NativeMenuItem Header="{loc:NativeLoc app.menu.page}">
        <NativeMenu>
          <NativeMenuItem Header="{loc:NativeLoc app.menu.page.previous}"
                          Command="{Binding PreviousPageCommand}" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.page.next}"
                          Command="{Binding NextPageCommand}" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.page.rotate_left}"
                          Command="{Binding RotateLeftCommand}" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.page.rotate_right}"
                          Command="{Binding RotateRightCommand}" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.page.move_earlier}"
                          Command="{Binding MoveCurrentPageEarlierCommand}" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.page.move_later}"
                          Command="{Binding MoveCurrentPageLaterCommand}" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.page.extract}"
                          Command="{Binding ExtractCurrentPageCommand}" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.page.delete}"
                          Command="{Binding DeleteCurrentPageCommand}" />
        </NativeMenu>
      </NativeMenuItem>

      <NativeMenuItem Header="{loc:NativeLoc app.menu.view}">
        <NativeMenu>
          <NativeMenuItem Header="{loc:NativeLoc app.menu.view.sidebar}"
                          Command="{Binding ToggleSidebarCommand}" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.view.search}"
                          Command="{Binding ToggleSearchPanelCommand}"
                          IsEnabled="{Binding IsSearchAvailableForCurrentDocument}"
                          Gesture="Meta+F" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.view.info}"
                          Command="{Binding ToggleInfoPanelCommand}" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.view.preferences}"
                          Command="{Binding TogglePreferencesPanelCommand}"
                          Gesture="Meta+OemComma" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.view.zoom_in}"
                          Command="{Binding ZoomInCommand}" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.view.zoom_out}"
                          Command="{Binding ZoomOutCommand}" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.view.fit_width}"
                          Command="{Binding FitToWidthCommand}" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.view.fit_page}"
                          Command="{Binding FitToPageCommand}" />
        </NativeMenu>
      </NativeMenuItem>

      <NativeMenuItem Header="{loc:NativeLoc app.menu.annotate}">
        <NativeMenu>
          <NativeMenuItem Header="{loc:NativeLoc app.menu.annotate.show}"
                          Command="{Binding ToggleAnnotationsPanelCommand}"
                          Gesture="Meta+Shift+A" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.annotate.select}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Select" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.annotate.highlight}"
                          Command="{Binding AddHighlightAnnotationFromSelectionCommand}"
                          IsEnabled="{Binding CanCreateHighlightAnnotation}" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.annotate.freehand}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Ink" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.annotate.rectangle}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Rectangle" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.annotate.text}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Text" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.annotate.note}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Note" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.annotate.stamp}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Stamp" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.annotate.signature}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Signature" />
          <NativeMenuItemSeparator />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.annotate.delete}"
                          Command="{Binding DeleteSelectedAnnotationCommand}" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.annotate.undo}"
                          Command="{Binding UndoAnnotationsCommand}" />
          <NativeMenuItem Header="{loc:NativeLoc app.menu.annotate.redo}"
                          Command="{Binding RedoAnnotationsCommand}" />
        </NativeMenu>
      </NativeMenuItem>
    </NativeMenu>
  </NativeMenu.Menu>

  <Grid RowDefinitions="Auto,Auto,*,Auto">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border x:Name="WindowsTitleBar"
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Classes="windows-titlebar"
            IsVisible="{Binding IsWindowsShellVisible}"
            PointerPressed="OnWindowsTitleBarPointerPressed">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto"
            ColumnSpacing="10">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Margin="12,0,4,0">
          <Image Source="avares://Velune.Presentation/Assets/Brand/velune-app-icon.png"
                 Width="22"
                 Height="22"
                 Stretch="UniformToFill" />
          <TextBlock Text="{Binding ApplicationTitle}"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
        </StackPanel>

        <ItemsControl Grid.Column="1"
                      ItemsSource="{Binding DocumentTabs}"
                      VerticalAlignment="Stretch">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Classes="windows-tab"
                      Classes.active="{Binding IsActive}"
                      Command="{Binding $parent[Window].DataContext.ActivateDocumentTabCommand}"
                      CommandParameter="{Binding}"
                      ToolTip.Tip="{Binding FilePath}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8"
                      Width="220">
                  <TextBlock Grid.Column="0"
                             Text="•"
                             Classes="windows-tab-dirty"
                             IsVisible="{Binding IsDirty}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Title}"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="2"
                          Classes="windows-tab-close"
                          Command="{Binding $parent[Window].DataContext.CloseDocumentTabCommand}"
                          CommandParameter="{Binding}"
                          ToolTip.Tip="{loc:Loc tabs.close}">
                    <materialIcons:MaterialIcon Kind="Close"
                                                Width="14"
                                                Height="14" />
                  </Button>
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Grid.Column="2"
                Classes="windows-new-tab"
                Command="{Binding OpenCommand}"
                HorizontalAlignment="Left"
                ToolTip.Tip="{loc:Loc toolbar.open.tooltip}">
          <materialIcons:MaterialIcon Kind="Plus"
                                      Width="18"
                                      Height="18" />
        </Button>

        <StackPanel Grid.Column="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
          <Button Classes="windows-window-button"
                  Click="OnWindowsMinimizeClicked"
                  ToolTip.Tip="{loc:Loc window.minimize}">
            <materialIcons:MaterialIcon Kind="WindowMinimize"
                                        Width="16"
                                        Height="16" />
          </Button>
          <Button Classes="windows-window-button"
                  Click="OnWindowsMaximizeRestoreClicked"
                  ToolTip.Tip="{loc:Loc window.maximize}">
            <materialIcons:MaterialIcon Kind="WindowMaximize"
                                        Width="16"
                                        Height="16" />
          </Button>
          <Button Classes="windows-window-button close"
                  Click="OnWindowsCloseClicked"
                  ToolTip.Tip="{loc:Loc window.close}">
            <materialIcons:MaterialIcon Kind="Close"
                                        Width="16"
                                        Height="16" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Menu Grid.Row="0"
          Grid.Column="0"
          Grid.ColumnSpan="2"
          IsVisible="{Binding ShowWindowMenuBar}">
      <MenuItem Header="{loc:Loc app.menu.app.mnemonic}">
        <MenuItem Header="{loc:Loc app.menu.about.mnemonic}"
                  Click="OnAboutMenuClicked" />
        <MenuItem Header="{loc:Loc app.menu.preferences.mnemonic}"
                  Command="{Binding TogglePreferencesPanelCommand}" />
      </MenuItem>

      <MenuItem Header="{loc:Loc app.menu.file.mnemonic}">
        <MenuItem Header="{loc:Loc app.menu.open.mnemonic}"
                  Command="{Binding OpenCommand}" />
        <MenuItem Header="{loc:Loc app.menu.save.mnemonic}"
                  Command="{Binding SaveDocumentCommand}" />
        <Separator />
        <MenuItem Header="{loc:Loc app.menu.print.mnemonic}"
                  Command="{Binding PrintDocumentCommand}" />
        <Separator />
        <MenuItem Header="{loc:Loc app.menu.close.mnemonic}"
                  Command="{Binding CloseCommand}" />
      </MenuItem>

      <MenuItem Header="{loc:Loc app.menu.page.mnemonic}">
        <MenuItem Header="{loc:Loc app.menu.page.previous.mnemonic}"
                  Command="{Binding PreviousPageCommand}" />
        <MenuItem Header="{loc:Loc app.menu.page.next.mnemonic}"
                  Command="{Binding NextPageCommand}" />
        <Separator />
        <MenuItem Header="{loc:Loc app.menu.page.rotate_left.mnemonic}"
                  Command="{Binding RotateLeftCommand}" />
        <MenuItem Header="{loc:Loc app.menu.page.rotate_right.mnemonic}"
                  Command="{Binding RotateRightCommand}" />
        <Separator />
        <MenuItem Header="{loc:Loc app.menu.page.move_earlier.mnemonic}"
                  Command="{Binding MoveCurrentPageEarlierCommand}" />
        <MenuItem Header="{loc:Loc app.menu.page.move_later.mnemonic}"
                  Command="{Binding MoveCurrentPageLaterCommand}" />
        <Separator />
        <MenuItem Header="{loc:Loc app.menu.page.extract.mnemonic}"
                  Command="{Binding ExtractCurrentPageCommand}" />
        <MenuItem Header="{loc:Loc app.menu.page.delete.mnemonic}"
                  Command="{Binding DeleteCurrentPageCommand}" />
      </MenuItem>

      <MenuItem Header="{loc:Loc app.menu.view.mnemonic}">
        <MenuItem Header="{loc:Loc app.menu.view.sidebar.mnemonic}"
                  Command="{Binding ToggleSidebarCommand}" />
        <Separator />
        <MenuItem Header="{loc:Loc app.menu.view.search.mnemonic}"
                  Command="{Binding ToggleSearchPanelCommand}"
                  IsEnabled="{Binding IsSearchAvailableForCurrentDocument}" />
        <MenuItem Header="{loc:Loc app.menu.view.info.mnemonic}"
                  Command="{Binding ToggleInfoPanelCommand}" />
        <MenuItem Header="{loc:Loc app.menu.view.preferences.mnemonic}"
                  Command="{Binding TogglePreferencesPanelCommand}" />
        <Separator />
        <MenuItem Header="{loc:Loc app.menu.view.zoom_in.mnemonic}"
                  Command="{Binding ZoomInCommand}" />
        <MenuItem Header="{loc:Loc app.menu.view.zoom_out.mnemonic}"
                  Command="{Binding ZoomOutCommand}" />
        <Separator />
        <MenuItem Header="{loc:Loc app.menu.view.fit_width.mnemonic}"
                  Command="{Binding FitToWidthCommand}" />
        <MenuItem Header="{loc:Loc app.menu.view.fit_page.mnemonic}"
                  Command="{Binding FitToPageCommand}" />
      </MenuItem>

      <MenuItem Header="{loc:Loc app.menu.annotate.mnemonic}">
        <MenuItem Header="{loc:Loc app.menu.annotate.show.mnemonic}"
                  Command="{Binding ToggleAnnotationsPanelCommand}" />
        <Separator />
        <MenuItem Header="{loc:Loc app.menu.annotate.select.mnemonic}"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Select" />
        <MenuItem Header="{loc:Loc app.menu.annotate.highlight.mnemonic}"
                  Command="{Binding AddHighlightAnnotationFromSelectionCommand}" />
        <MenuItem Header="{loc:Loc app.menu.annotate.freehand.mnemonic}"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Ink" />
        <MenuItem Header="{loc:Loc app.menu.annotate.rectangle.mnemonic}"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Rectangle" />
        <MenuItem Header="{loc:Loc app.menu.annotate.text.mnemonic}"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Text" />
        <MenuItem Header="{loc:Loc app.menu.annotate.note.mnemonic}"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Note" />
        <MenuItem Header="{loc:Loc app.menu.annotate.stamp.mnemonic}"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Stamp" />
        <MenuItem Header="{loc:Loc app.menu.annotate.signature.mnemonic}"
                  Command="{Binding SelectAnnotationToolCommand}"
                  CommandParameter="Signature" />
        <Separator />
        <MenuItem Header="{loc:Loc app.menu.annotate.delete.mnemonic}"
                  Command="{Binding DeleteSelectedAnnotationCommand}" />
        <MenuItem Header="{loc:Loc app.menu.annotate.undo.mnemonic}"
                  Command="{Binding UndoAnnotationsCommand}" />
        <MenuItem Header="{loc:Loc app.menu.annotate.redo.mnemonic}"
                  Command="{Binding RedoAnnotationsCommand}" />
      </MenuItem>
    </Menu>

    <Border Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Classes="windows-ribbon"
            IsVisible="{Binding IsWindowsShellVisible}">
      <Grid RowDefinitions="Auto,Auto">
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="4"
                    Margin="14,0,14,0">
          <Button Classes="windows-ribbon-tab"
                  Classes.active="{Binding IsWindowsRibbonFileSelected}"
                  Command="{Binding SelectWindowsRibbonSectionCommand}"
                  CommandParameter="File"
                  Content="{loc:Loc ribbon.file}" />
          <Button Classes="windows-ribbon-tab"
                  Classes.active="{Binding IsWindowsRibbonHomeSelected}"
                  Command="{Binding SelectWindowsRibbonSectionCommand}"
                  CommandParameter="Home"
                  Content="{loc:Loc ribbon.home}" />
          <Button Classes="windows-ribbon-tab"
                  Classes.active="{Binding IsWindowsRibbonViewSelected}"
                  Command="{Binding SelectWindowsRibbonSectionCommand}"
                  CommandParameter="View"
                  Content="{loc:Loc ribbon.view}" />
          <Button Classes="windows-ribbon-tab"
                  Classes.active="{Binding IsWindowsRibbonAnnotateSelected}"
                  Command="{Binding SelectWindowsRibbonSectionCommand}"
                  CommandParameter="Annotate"
                  Content="{loc:Loc ribbon.annotate}" />
          <Button Classes="windows-ribbon-tab"
                  Classes.active="{Binding IsWindowsRibbonHelpSelected}"
                  Command="{Binding SelectWindowsRibbonSectionCommand}"
                  CommandParameter="Help"
                  Content="{loc:Loc ribbon.help}" />
        </StackPanel>

        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto"
              ColumnSpacing="14"
              Margin="12,6,12,10">
          <StackPanel Grid.Column="0"
                      Classes="windows-ribbon-group"
                      Orientation="Horizontal"
                      Spacing="6"
                      IsVisible="{Binding ShowWindowsRibbonFileCommands}">
            <Button Classes="windows-command-button"
                    Command="{Binding OpenCommand}"
                    ToolTip.Tip="{loc:Loc toolbar.open.tooltip}">
              <StackPanel Orientation="Horizontal"
                          Spacing="6">
                <materialIcons:MaterialIcon Kind="FolderOpenOutline"
                                            Width="18"
                                            Height="18" />
                <TextBlock Text="{loc:Loc toolbar.open.label}" />
              </StackPanel>
            </Button>
            <Button Classes="windows-command-button"
                    Command="{Binding MergePdfDocumentsCommand}"
                    ToolTip.Tip="{loc:Loc toolbar.merge.tooltip}">
              <StackPanel Orientation="Horizontal"
                          Spacing="6">
                <materialIcons:MaterialIcon Kind="FileDocumentMultipleOutline"
                                            Width="18"
                                            Height="18" />
                <TextBlock Text="{loc:Loc toolbar.merge.label}" />
              </StackPanel>
            </Button>
            <Button Classes="windows-command-button"
                    Command="{Binding PrintDocumentCommand}"
                    ToolTip.Tip="{loc:Loc toolbar.print.tooltip}">
              <StackPanel Orientation="Horizontal"
                          Spacing="6">
                <materialIcons:MaterialIcon Kind="PrinterOutline"
                                            Width="18"
                                            Height="18" />
                <TextBlock Text="{loc:Loc toolbar.print.label}" />
              </StackPanel>
            </Button>
          </StackPanel>

          <StackPanel Grid.Column="1"
                      Classes="windows-ribbon-group"
                      Orientation="Horizontal"
                      Spacing="6"
                      IsVisible="{Binding ShowWindowsRibbonNavigationCommands}">
            <Button Classes="windows-icon-button"
                    Command="{Binding PreviousPageCommand}"
                    ToolTip.Tip="{loc:Loc toolbar.page.previous}">
              <materialIcons:MaterialIcon Kind="ChevronLeft"
                                          Width="20"
                                          Height="20" />
            </Button>
            <TextBox Classes="windows-page-input"
                     Text="{Binding GoToPageInput}"
                     HorizontalContentAlignment="Center" />
            <TextBlock Text="{Binding PageIndicator}"
                       Classes="windows-page-indicator"
                       VerticalAlignment="Center" />
            <Button Classes="windows-icon-button"
                    Command="{Binding GoToPageCommand}"
                    ToolTip.Tip="{loc:Loc toolbar.page.input.tooltip}">
              <materialIcons:MaterialIcon Kind="ArrowRight"
                                          Width="18"
                                          Height="18" />
            </Button>
            <Button Classes="windows-icon-button"
                    Command="{Binding NextPageCommand}"
                    ToolTip.Tip="{loc:Loc toolbar.page.next}">
              <materialIcons:MaterialIcon Kind="ChevronRight"
                                          Width="20"
                                          Height="20" />
            </Button>
          </StackPanel>

          <StackPanel Grid.Column="2"
                      Classes="windows-ribbon-group"
                      Orientation="Horizontal"
                      Spacing="6"
                      IsVisible="{Binding ShowWindowsRibbonZoomCommands}">
            <Button Classes="windows-icon-button"
                    Command="{Binding ZoomOutCommand}"
                    ToolTip.Tip="{loc:Loc toolbar.zoom.out}">
              <materialIcons:MaterialIcon Kind="Minus"
                                          Width="18"
                                          Height="18" />
            </Button>
            <TextBlock Text="{Binding CurrentZoom}"
                       Classes="windows-page-indicator"
                       VerticalAlignment="Center" />
            <Button Classes="windows-icon-button"
                    Command="{Binding ZoomInCommand}"
                    ToolTip.Tip="{loc:Loc toolbar.zoom.in}">
              <materialIcons:MaterialIcon Kind="Plus"
                                          Width="18"
                                          Height="18" />
            </Button>
            <Button Classes="windows-command-button"
                    Command="{Binding FitToPageCommand}"
                    ToolTip.Tip="{loc:Loc toolbar.zoom.fit_page}">
              <StackPanel Orientation="Horizontal"
                          Spacing="6">
                <materialIcons:MaterialIcon Kind="FitToPageOutline"
                                            Width="18"
                                            Height="18" />
                <TextBlock Text="{loc:Loc toolbar.fit_page.short}" />
              </StackPanel>
            </Button>
          </StackPanel>

          <TextBox Grid.Column="4"
                   Classes="windows-search"
                   Text="{Binding SearchQueryInput}"
                   Watermark="{loc:Loc toolbar.search.placeholder}"
                   IsVisible="{Binding ShowWindowsRibbonSearchCommands}" />

          <StackPanel Grid.Column="5"
                      Classes="windows-ribbon-group"
                      Orientation="Horizontal"
                      Spacing="6"
                      IsVisible="{Binding ShowWindowsRibbonViewCommands}">
            <Button Classes="windows-icon-button"
                    Command="{Binding ToggleSidebarCommand}"
                    ToolTip.Tip="{Binding SidebarToggleLabel}">
              <materialIcons:MaterialIcon Kind="PageLayoutSidebarLeft"
                                          Width="20"
                                          Height="20" />
            </Button>
            <Button Classes="windows-icon-button"
                    Command="{Binding ToggleSearchPanelCommand}"
                    ToolTip.Tip="{loc:Loc panel.search.title}">
              <materialIcons:MaterialIcon Kind="Magnify"
                                          Width="20"
                                          Height="20" />
            </Button>
            <Button Classes="windows-icon-button"
                    Command="{Binding ToggleInfoPanelCommand}"
                    ToolTip.Tip="{loc:Loc panel.info.title}">
              <materialIcons:MaterialIcon Kind="InformationOutline"
                                          Width="20"
                                          Height="20" />
            </Button>
            <Button Classes="windows-icon-button"
                    Command="{Binding TogglePreferencesPanelCommand}"
                    ToolTip.Tip="{loc:Loc panel.preferences.title}">
              <materialIcons:MaterialIcon Kind="CogOutline"
                                          Width="20"
                                          Height="20" />
            </Button>
          </StackPanel>

          <StackPanel Grid.Column="6"
                      Classes="windows-ribbon-group"
                      Orientation="Horizontal"
                      Spacing="6"
                      IsVisible="{Binding ShowWindowsRibbonAnnotationCommands}">
            <Button Classes="windows-icon-button"
                    Classes.accent="{Binding IsAnnotationsPanelOpen}"
                    Command="{Binding ToggleAnnotationsPanelCommand}"
                    ToolTip.Tip="{loc:Loc panel.annotations.title}">
              <materialIcons:MaterialIcon Kind="PencilOutline"
                                          Width="20"
                                          Height="20" />
            </Button>
            <Button Classes="windows-icon-button"
                    Command="{Binding SelectAnnotationToolCommand}"
                    CommandParameter="Note"
                    ToolTip.Tip="{loc:Loc annotation.tool.note}">
              <materialIcons:MaterialIcon Kind="CommentTextOutline"
                                          Width="20"
                                          Height="20" />
            </Button>
            <Button Classes="windows-icon-button"
                    Command="{Binding SelectAnnotationToolCommand}"
                    CommandParameter="Text"
                    ToolTip.Tip="{loc:Loc annotation.tool.text}">
              <materialIcons:MaterialIcon Kind="FormatText"
                                          Width="20"
                                          Height="20" />
            </Button>
          </StackPanel>
        </Grid>
      </Grid>
    </Border>

    <!-- Header -->
    <Border x:Name="HeaderHostBorder"
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            IsVisible="{Binding ShowClassicHeader}"
            Padding="18,14"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,0,1"
            Background="{DynamicResource Brush.Surface}">
      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="18"
            ClipToBounds="True">
        <Grid Grid.Column="0"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="14"
              VerticalAlignment="Center"
              MinWidth="0">
          <Grid Grid.Column="0"
                MinWidth="0"
                MaxWidth="{Binding HeaderTitleMaxWidth}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center">
            <StackPanel Spacing="2"
                        MinWidth="0"
                        IsVisible="{Binding ShouldEmphasizeOpenAction}">
              <TextBlock Text="{Binding HeaderTitle}"
                         Classes="title"
                         TextWrapping="NoWrap"
                         TextTrimming="CharacterEllipsis"
                         ToolTip.Tip="{Binding CurrentDocumentPath}" />
              <TextBlock Text="{Binding HeaderSubtitle}"
                         Classes="muted"
                         TextWrapping="NoWrap"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <StackPanel Spacing="2"
                        MinWidth="0"
                        IsVisible="{Binding HasOpenDocument}">
              <TextBox x:Name="DocumentNameEditorTextBox"
                       Classes="header-title-input"
                       HorizontalAlignment="Stretch"
                       Text="{Binding EditableDocumentName}"
                       Watermark="{loc:Loc toolbar.document_name.placeholder}"
                       ToolTip.Tip="{loc:Loc toolbar.document_name.tooltip}"
                       KeyDown="OnDocumentNameInputKeyDown"
                       GotFocus="OnDocumentNameInputGotFocus"
                       LostFocus="OnDocumentNameInputLostFocus" />
              <TextBlock Text="{Binding HeaderSubtitle}"
                         Classes="muted"
                         TextWrapping="NoWrap"
                         TextTrimming="CharacterEllipsis"
                         ToolTip.Tip="{Binding CurrentDocumentPath}" />
            </StackPanel>
          </Grid>

          <Button Grid.Column="1"
                  Classes="header-action-button sidebar-toggle-button"
                  Command="{Binding ToggleSidebarCommand}"
                  IsVisible="{Binding CanToggleSidebar}"
                  ToolTip.Tip="{Binding SidebarToggleLabel}">
            <materialIcons:MaterialIcon Classes="toolbar-icon"
                                        Kind="Menu"
                                        Width="18"
                                        Height="18" />
          </Button>

          <Border Grid.Column="2"
                  Classes="header-chip-group"
                  VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="toolbar-primary-button"
                      Command="{Binding OpenCommand}"
                      IsVisible="{Binding ShouldEmphasizeOpenAction}"
                      ToolTip.Tip="{loc:Loc toolbar.open.tooltip}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                  <materialIcons:MaterialIcon Classes="toolbar-primary-icon"
                                              Kind="FolderOpenOutline"
                                              Width="20"
                                              Height="20" />
                  <TextBlock Text="{loc:Loc toolbar.open.label}"
                             Classes="toolbar-primary-label" />
                </StackPanel>
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding OpenCommand}"
                      IsVisible="{Binding HasOpenDocument}"
                      ToolTip.Tip="{loc:Loc toolbar.open_another.tooltip}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                  <materialIcons:MaterialIcon Classes="toolbar-icon"
                                              Kind="FolderOpenOutline"
                                              Width="18"
                                              Height="18" />
                  <TextBlock Text="{loc:Loc toolbar.open.label}"
                             Classes="header-action-label" />
                </StackPanel>
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding MergePdfDocumentsCommand}"
                      IsVisible="{Binding HasOpenDocument}"
                      ToolTip.Tip="{loc:Loc toolbar.merge.tooltip}">
                <TextBlock Text="{loc:Loc toolbar.merge.label}"
                           Classes="header-action-label" />
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding PrintDocumentCommand}"
                      IsVisible="{Binding HasOpenDocument}"
                      ToolTip.Tip="{loc:Loc toolbar.print.tooltip}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="PrinterOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding CloseCommand}"
                      IsVisible="{Binding HasOpenDocument}"
                      ToolTip.Tip="{loc:Loc toolbar.close.tooltip}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="Close"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>
        </Grid>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Spacing="0">
          <Border Classes="header-pill header-flex-item"
                  IsVisible="{Binding IsPageNavigationVisible}">
            <StackPanel Orientation="Horizontal"
                        Spacing="6">
              <Button Classes="header-pill-button"
                      Command="{Binding PreviousPageCommand}"
                      ToolTip.Tip="{loc:Loc toolbar.page.previous}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="ChevronLeft"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Border Classes="header-pill-divider" />

              <TextBox Classes="header-page-input"
                       Width="46"
                       Text="{Binding GoToPageInput}"
                       IsEnabled="{Binding CanGoToPage}"
                       ToolTip.Tip="{loc:Loc toolbar.page.input.tooltip}"
                       KeyDown="OnGoToPageInputKeyDown" />

              <TextBlock Text="/"
                         Classes="header-pill-text header-pill-muted" />
              <TextBlock Text="{Binding TotalPages}"
                         Classes="header-pill-text" />

              <Border Classes="header-pill-divider" />

              <Button Classes="header-pill-button"
                      Command="{Binding NextPageCommand}"
                      ToolTip.Tip="{loc:Loc toolbar.page.next}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="ChevronRight"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>

          <Border Classes="header-pill header-flex-item"
                  IsVisible="{Binding HasOpenDocument}">
            <StackPanel Orientation="Horizontal"
                        Spacing="6">
              <Button Classes="header-pill-button"
                      Command="{Binding ZoomOutCommand}"
                      ToolTip.Tip="{loc:Loc toolbar.zoom.out}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="MagnifyMinusOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Border Classes="header-pill-divider" />

              <TextBlock Text="{Binding CurrentZoom}"
                         Classes="header-pill-text" />

              <Border Classes="header-pill-divider" />

              <Button Classes="header-pill-button"
                      Command="{Binding FitToWidthCommand}"
                      ToolTip.Tip="{loc:Loc toolbar.zoom.fit_width}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="ArrowExpandHorizontal"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-pill-button"
                      Command="{Binding FitToPageCommand}"
                      ToolTip.Tip="{loc:Loc toolbar.zoom.fit_page}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="FitToPageOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-pill-button"
                      Command="{Binding ZoomInCommand}"
                      ToolTip.Tip="{loc:Loc toolbar.zoom.in}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="MagnifyPlusOutline"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>

          <Border Classes="header-search-group header-flex-item"
                  IsVisible="{Binding UseInlineHeaderSearch}">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="8">
              <materialIcons:MaterialIcon Grid.Column="0"
                                          Classes="toolbar-icon"
                                          Kind="Magnify"
                                          Width="18"
                                          Height="18"
                                          VerticalAlignment="Center" />

              <TextBox Grid.Column="1"
                       Classes="header-search-input"
                       Width="156"
                       Watermark="{loc:Loc toolbar.search.placeholder}"
                       Text="{Binding SearchQueryInput}"
                       KeyDown="OnSearchInputKeyDown" />

              <Button Grid.Column="2"
                      Classes="header-search-button"
                      Command="{Binding OpenSearchCommand}"
                      ToolTip.Tip="{loc:Loc toolbar.search.tooltip}">
                <TextBlock Text="{loc:Loc toolbar.search.label}"
                           Classes="header-action-label" />
              </Button>
            </Grid>
          </Border>

          <Border Classes="header-chip-group header-flex-item"
                  IsVisible="{Binding HasOpenDocument}">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="header-action-button"
                      Command="{Binding RotateLeftCommand}"
                      ToolTip.Tip="{loc:Loc toolbar.rotate.left}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="RotateLeftVariant"
                                            Width="18"
                                            Height="18" />
              </Button>

              <TextBlock Text="{Binding CurrentRotation}"
                         Classes="header-chip-label" />

              <Button Classes="header-action-button"
                      Command="{Binding RotateRightCommand}"
                      ToolTip.Tip="{loc:Loc toolbar.rotate.right}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="RotateRightVariant"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>

          <Border Classes="header-chip-group header-flex-item"
                  IsVisible="{Binding HasOpenDocument}">
            <StackPanel Orientation="Horizontal"
                        Spacing="4">
              <Button Classes="header-action-button"
                      Command="{Binding ToggleSearchPanelCommand}"
                      IsVisible="{Binding UseCollapsedHeaderSearchButton}"
                      ToolTip.Tip="{loc:Loc toolbar.search.open}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="Magnify"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding ToggleInfoPanelCommand}"
                      ToolTip.Tip="{loc:Loc toolbar.info.open}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="InformationCircleOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding ToggleAnnotationsPanelCommand}"
                      ToolTip.Tip="{loc:Loc toolbar.annotations.open}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="PencilOutline"
                                            Width="18"
                                            Height="18" />
              </Button>

              <Button Classes="header-action-button"
                      Command="{Binding TogglePreferencesPanelCommand}"
                      ToolTip.Tip="{loc:Loc toolbar.preferences.open}">
                <materialIcons:MaterialIcon Classes="toolbar-icon"
                                            Kind="CogOutline"
                                            Width="18"
                                            Height="18" />
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Sidebar -->
    <Border Grid.Row="2"
            Grid.Column="0"
            Width="{Binding SidebarWidth}"
            IsHitTestVisible="{Binding IsSidebarInteractive}"
            Padding="14"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,1,0"
            Background="{DynamicResource Brush.Surface}"
            ClipToBounds="True"
            IsVisible="{Binding SidebarHostVisible}">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Width" Duration="0:0:0.22" />
        </Transitions>
      </Border.Transitions>
      <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0"
                    Spacing="12"
                    Margin="0,0,0,12">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="8">
            <TextBlock Text="{Binding SidebarTitle}"
                       Classes="title"
                       VerticalAlignment="Center" />

            <TextBlock Grid.Column="1"
                       Text="{loc:Loc app.loading}"
                       Classes="muted"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsGeneratingThumbnails}" />
          </Grid>
        </StackPanel>

        <Grid x:Name="ThumbnailDragSurface"
              Grid.Row="1"
              Width="220"
              MaxWidth="220"
              ClipToBounds="False"
              DragDrop.AllowDrop="True"
              DragDrop.DragOver="OnThumbnailExternalDragOver"
              DragDrop.DragLeave="OnThumbnailExternalDragLeave"
              DragDrop.Drop="OnThumbnailExternalDrop">
          <ScrollViewer x:Name="ThumbnailScrollViewer"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ThumbnailItemsControl"
                          ItemsSource="{Binding Thumbnails}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="thumbnail-hitbox"
                          ToolTip.Tip="{loc:Loc sidebar.page.actions}"
                          PointerPressed="OnThumbnailPointerPressed"
                          PointerMoved="OnThumbnailPointerMoved"
                          PointerReleased="OnThumbnailPointerReleased"
                          PointerCaptureLost="OnThumbnailPointerCaptureLost"
                          Tapped="OnThumbnailTapped">
                    <Border.ContextMenu>
                      <ContextMenu Classes="thumbnail-context-menu"
                                   DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                   Opened="OnThumbnailContextMenuOpened">
                        <MenuItem Classes="thumbnail-context-title"
                                  IsEnabled="False" />
                        <Separator Classes="thumbnail-context-separator" />
                        <MenuItem Classes="thumbnail-context-menu-item thumbnail-open-action"
                                  Header="{loc:Loc sidebar.page.open}"
                                  Click="OnThumbnailContextOpenClick">
                          <MenuItem.Icon>
                            <materialIcons:MaterialIcon Classes="context-menu-icon"
                                                        Kind="Magnify"
                                                        Width="16"
                                                        Height="16" />
                          </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Classes="thumbnail-context-menu-item thumbnail-extract-action"
                                  Header="{loc:Loc sidebar.page.extract}"
                                  Click="OnThumbnailContextExtractClick">
                          <MenuItem.Icon>
                            <materialIcons:MaterialIcon Classes="context-menu-icon"
                                                        Kind="ArrowExpandHorizontal"
                                                        Width="16"
                                                        Height="16" />
                          </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Classes="thumbnail-context-menu-item thumbnail-delete-action destructive"
                                  Header="{loc:Loc sidebar.page.delete}"
                                  Click="OnThumbnailContextDeleteClick">
                          <MenuItem.Icon>
                            <materialIcons:MaterialIcon Classes="context-menu-icon destructive"
                                                        Kind="TrashCanOutline"
                                                        Width="16"
                                                        Height="16" />
                          </MenuItem.Icon>
                        </MenuItem>
                      </ContextMenu>
                    </Border.ContextMenu>

                    <Border Classes="thumbnail-item"
                            Classes.selected="{Binding IsSelected}"
                            Classes.dragging="{Binding IsDragging}"
                            Width="200"
                            MaxWidth="200"
                            MinHeight="120">
                      <StackPanel Spacing="8">
                        <Border Classes="thumbnail-image-host"
                                Width="176"
                                MaxWidth="176"
                                Height="154"
                                HorizontalAlignment="Center">
                          <Grid>
                            <Image Source="{Binding Thumbnail}"
                                   Stretch="Uniform"
                                   MaxWidth="170"
                                   MaxHeight="150"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="{loc:Loc app.loading}"
                                       Classes="muted"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding IsLoading}" />
                          </Grid>
                        </Border>

                        <TextBlock Text="{Binding PageLabel}"
                                   HorizontalAlignment="Center"
                                   FontWeight="SemiBold" />
                      </StackPanel>
                    </Border>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Canvas x:Name="ThumbnailDragOverlay"
                  IsHitTestVisible="False"
                  ClipToBounds="False">
            <Border x:Name="ThumbnailDropIndicator"
                    Classes="thumbnail-drop-indicator"
                    IsVisible="False" />
            <Border x:Name="ThumbnailDragGhostHost"
                    Classes="thumbnail-drag-ghost"
                    IsVisible="False">
              <Border Classes="thumbnail-item thumbnail-drag-preview-item"
                      Width="200"
                      MaxWidth="200"
                      MinHeight="120">
                <StackPanel Spacing="8">
                  <Border Classes="thumbnail-image-host"
                          Width="180"
                          MaxWidth="180"
                          Height="160"
                          HorizontalAlignment="Center">
                    <Grid>
                      <Image x:Name="ThumbnailDragGhostPreviewImage"
                             Stretch="Uniform"
                             MaxWidth="170"
                             MaxHeight="150"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                      <TextBlock x:Name="ThumbnailDragGhostLoadingText"
                                 Text="{loc:Loc app.loading}"
                                 Classes="muted"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 IsVisible="False" />
                    </Grid>
                  </Border>

                  <TextBlock x:Name="ThumbnailDragGhostPageLabel"
                             HorizontalAlignment="Center"
                             FontWeight="SemiBold" />
                </StackPanel>
              </Border>
            </Border>
          </Canvas>
        </Grid>
      </Grid>
    </Border>

    <!-- Main content -->
    <Grid Grid.Row="2"
          Grid.Column="1"
          ColumnDefinitions="*,Auto"
          Background="{DynamicResource Brush.Background}">

      <!-- Toast -->
      <Border Classes="banner"
              Grid.ColumnSpan="2"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="16"
              Padding="12,10"
              MinWidth="320"
              MaxWidth="460"
              ZIndex="10"
              IsVisible="{Binding HasUserMessage}">
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="Auto,*">
            <materialIcons:MaterialIcon Grid.Column="0"
                                        Kind="{Binding NotificationIconKind}"
                                        Width="18"
                                        Height="18"
                                        Foreground="{DynamicResource Brush.Accent}"
                                        VerticalAlignment="Top"
                                        Margin="0,1,10,0" />

            <StackPanel Grid.Column="1"
                        Spacing="4">
              <TextBlock Text="{Binding UserMessageTitle}"
                         FontWeight="SemiBold"
                         IsVisible="{Binding HasUserMessageTitle}" />

              <TextBlock Text="{Binding UserMessage}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>

          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="8">
            <Button Content="{Binding NotificationSecondaryActionLabel}"
                    Command="{Binding NotificationSecondaryActionCommand}"
                    IsVisible="{Binding HasNotificationSecondaryAction}" />

            <Button Content="{Binding NotificationPrimaryActionLabel}"
                    Command="{Binding NotificationPrimaryActionCommand}"
                    IsVisible="{Binding HasNotificationPrimaryAction}" />

            <Button Content="{loc:Loc app.dismiss}"
                    Command="{Binding DismissMessageCommand}"
                    IsVisible="{Binding CanDismissUserMessage}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Empty state -->
      <Grid Grid.ColumnSpan="2"
            Margin="84,34,84,28"
            RowDefinitions="Auto,Auto,Auto,*"
            IsVisible="{Binding IsEmptyStateVisible}">
        <StackPanel Grid.Row="0"
                    Classes="home-brand"
                    HorizontalAlignment="Center">
          <Grid Width="172"
                Height="172"
                HorizontalAlignment="Center">
            <Ellipse Width="172"
                     Height="172"
                     Fill="{DynamicResource Brush.BrandHalo}" />
            <Border Classes="empty-state-brand-shell home-logo-shell"
                    Width="134"
                    Height="134"
                    Padding="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
              <Image Source="avares://Velune.Presentation/Assets/Brand/velune-logo.png"
                     Stretch="Uniform"
                     Width="108"
                     Height="108"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
            </Border>
          </Grid>

          <TextBlock Text="{loc:Loc app.name}"
                     Classes="home-brand-title"
                     HorizontalAlignment="Center"
                     TextAlignment="Center" />

          <TextBlock Text="{loc:Loc app.window.subtitle}"
                     Classes="muted home-brand-subtitle"
                     HorizontalAlignment="Center"
                     TextAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1"
                Classes="home-drop-zone"
                DragDrop.AllowDrop="True"
                DragDrop.DragOver="OnHomeDropZoneDragOver"
                DragDrop.Drop="OnHomeDropZoneDrop">
          <Grid Classes="home-drop-content"
                RowDefinitions="44,28,36"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <TextBlock Grid.Row="0"
                       Text="{loc:Loc app.empty.drop_title}"
                       Classes="home-drop-title"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="NoWrap" />

            <TextBlock Grid.Row="1"
                       Text="{loc:Loc app.empty.or}"
                       Classes="home-drop-separator"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center" />

            <Button Grid.Row="2"
                    Classes="home-link-button"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Command="{Binding OpenCommand}">
              <TextBlock Text="{loc:Loc app.empty.open_link}"
                         FontSize="17"
                         FontWeight="SemiBold"
                         TextDecorations="Underline" />
            </Button>
          </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Classes="home-action-row"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="64">
          <Button Classes="home-action-button"
                  Command="{Binding OpenCommand}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">
              <materialIcons:MaterialIcon Kind="FolderOpenOutline"
                                          Width="24"
                                          Height="24" />
              <TextBlock Text="{loc:Loc app.open.button}"
                         Classes="home-action-label" />
            </StackPanel>
          </Button>

          <Button Classes="home-action-button"
                  Command="{Binding MergePdfDocumentsCommand}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">
              <materialIcons:MaterialIcon Kind="ArrowExpandHorizontal"
                                          Width="24"
                                          Height="24" />
              <TextBlock Text="{loc:Loc app.merge.button}"
                         Classes="home-action-label" />
            </StackPanel>
          </Button>
        </StackPanel>

      </Grid>

      <!-- Viewer -->
      <Grid Margin="24"
            Grid.Column="0"
            IsVisible="{Binding HasOpenDocument}">
        <Grid Margin="12"
              SizeChanged="OnDocumentViewerSizeChanged">
          <Grid IsVisible="{Binding IsImageAutoFitActive}">
              <Viewbox Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Grid x:Name="AutoFitDocumentInteractionLayer"
                      Width="{Binding DisplayedRenderedPageWidth}"
                      Height="{Binding DisplayedRenderedPageHeight}">
                  <Image Source="{Binding CurrentRenderedBitmap}"
                         Stretch="None"
                         Width="{Binding DisplayedRenderedPageWidth}"
                         Height="{Binding DisplayedRenderedPageHeight}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />

                  <Image Source="{Binding CurrentAnnotationOverlayBitmap}"
                         Stretch="None"
                         Width="{Binding DisplayedRenderedPageWidth}"
                         Height="{Binding DisplayedRenderedPageHeight}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         IsHitTestVisible="False" />

                  <ItemsControl ItemsSource="{Binding SearchHighlights}"
                                IsVisible="{Binding HasSearchHighlights}"
                                IsHitTestVisible="False">
                    <ItemsControl.Styles>
                      <Style Selector="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                      </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="search-highlight"
                                Width="{Binding Width}"
                                Height="{Binding Height}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <ItemsControl ItemsSource="{Binding TextSelectionHighlights}"
                                IsVisible="{Binding HasTextSelectionHighlights}"
                                IsHitTestVisible="False">
                    <ItemsControl.Styles>
                      <Style Selector="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding Left}" />
                        <Setter Property="Canvas.Top" Value="{Binding Top}" />
                      </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="text-selection-highlight"
                                Width="{Binding Width}"
                                Height="{Binding Height}" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <Border Background="Transparent"
                          PointerPressed="OnDocumentTextSelectionPointerPressed"
                          PointerMoved="OnDocumentTextSelectionPointerMoved"
                          PointerReleased="OnDocumentTextSelectionPointerReleased"
                          PointerCaptureLost="OnDocumentTextSelectionPointerCaptureLost" />

                  <Border Background="Transparent"
                          IsHitTestVisible="{Binding IsAnnotationModeActive}"
                          PointerPressed="OnAnnotationPointerPressed"
                          PointerMoved="OnAnnotationPointerMoved"
                          PointerReleased="OnAnnotationPointerReleased"
                          PointerCaptureLost="OnAnnotationPointerCaptureLost" />
                </Grid>
              </Viewbox>
            </Grid>

          <ScrollViewer x:Name="DocumentScrollViewer"
                        IsVisible="{Binding IsScrollableViewerVisible}"
                        PointerWheelChanged="OnDocumentPointerWheelChanged"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
            <Grid x:Name="ScrollableDocumentInteractionLayer"
                  Width="{Binding DisplayedRenderedPageWidth}"
                  Height="{Binding DisplayedRenderedPageHeight}"
                  HorizontalAlignment="{Binding ScrollableDocumentHorizontalAlignment}"
                  VerticalAlignment="Top">
              <Image Source="{Binding CurrentRenderedBitmap}"
                     Stretch="None"
                     Width="{Binding DisplayedRenderedPageWidth}"
                     Height="{Binding DisplayedRenderedPageHeight}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top" />

              <Image Source="{Binding CurrentAnnotationOverlayBitmap}"
                     Stretch="None"
                     Width="{Binding DisplayedRenderedPageWidth}"
                     Height="{Binding DisplayedRenderedPageHeight}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top"
                     IsHitTestVisible="False" />

              <ItemsControl ItemsSource="{Binding SearchHighlights}"
                            IsVisible="{Binding HasSearchHighlights}"
                            IsHitTestVisible="False">
                <ItemsControl.Styles>
                  <Style Selector="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                  </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <Canvas />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="search-highlight"
                            Width="{Binding Width}"
                            Height="{Binding Height}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <ItemsControl ItemsSource="{Binding TextSelectionHighlights}"
                            IsVisible="{Binding HasTextSelectionHighlights}"
                            IsHitTestVisible="False">
                <ItemsControl.Styles>
                  <Style Selector="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding Left}" />
                    <Setter Property="Canvas.Top" Value="{Binding Top}" />
                  </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <Canvas />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="text-selection-highlight"
                            Width="{Binding Width}"
                            Height="{Binding Height}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Border Background="Transparent"
                      PointerPressed="OnDocumentTextSelectionPointerPressed"
                      PointerMoved="OnDocumentTextSelectionPointerMoved"
                      PointerReleased="OnDocumentTextSelectionPointerReleased"
                      PointerCaptureLost="OnDocumentTextSelectionPointerCaptureLost" />

              <Border Background="Transparent"
                      IsHitTestVisible="{Binding IsAnnotationModeActive}"
                      PointerPressed="OnAnnotationPointerPressed"
                      PointerMoved="OnAnnotationPointerMoved"
                      PointerReleased="OnAnnotationPointerReleased"
                      PointerCaptureLost="OnAnnotationPointerCaptureLost" />
            </Grid>
          </ScrollViewer>

          <Border Classes="banner"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Padding="12,10"
                  IsVisible="{Binding ShowRenderingBanner}">
            <TextBlock Text="{loc:Loc app.rendering}"
                       Classes="muted" />
          </Border>
          </Grid>
      </Grid>

      <!-- Info panel -->
      <Border Grid.Column="1"
              Width="{Binding InfoPanelWidth}"
              IsHitTestVisible="{Binding IsInfoPanelInteractive}"
              Margin="0,24,24,24"
              Padding="18,16"
              Classes="card info-panel"
              Background="{DynamicResource Brush.Surface}"
              ClipToBounds="True"
              IsVisible="{Binding IsInfoPanelOpen}">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.22" />
          </Transitions>
        </Border.Transitions>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="{loc:Loc panel.info.title}"
                         Classes="title" />
              <TextBlock Text="{Binding CurrentDocumentName}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="{Binding CurrentDocumentType}"
                         Classes="muted" />
            </StackPanel>

            <Border Classes="banner"
                    Padding="10,8"
                    IsVisible="{Binding HasDocumentInfoWarning}">
              <TextBlock Text="{Binding DocumentInfoWarning}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </Border>

            <ItemsControl ItemsSource="{Binding DocumentInfoItems}"
                          IsVisible="{Binding HasDocumentInfo}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="96,*"
                        ColumnSpacing="12"
                        Margin="0,0,0,10">
                    <TextBlock Text="{Binding Label}"
                               Classes="metadata-label"
                               VerticalAlignment="Top" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Value}"
                               TextWrapping="Wrap" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Search panel -->
      <Border Grid.Column="1"
              Width="{Binding SearchPanelWidth}"
              IsHitTestVisible="{Binding IsSearchPanelInteractive}"
              Margin="0,24,24,24"
              Padding="0"
              Classes="card info-panel annotation-panel"
              Background="{DynamicResource Brush.Surface}"
              ClipToBounds="True"
              IsVisible="{Binding IsSearchPanelOpen}">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.22" />
          </Transitions>
        </Border.Transitions>
        <Grid RowDefinitions="Auto,*">
          <Grid Grid.Row="0"
                ColumnDefinitions="*,Auto"
                ColumnSpacing="8"
                Margin="18,16,18,0">
            <StackPanel Grid.Column="0"
                        Spacing="4">
              <TextBlock Text="{loc:Loc panel.search.title}"
                         Classes="title" />
              <TextBlock Text="{Binding CurrentDocumentName}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="{loc:Loc panel.search.description}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Button Grid.Column="1"
                    Classes="panel-close-button"
                    Command="{Binding CloseSearchPanelCommand}"
                    ToolTip.Tip="{loc:Loc panel.search.close}">
              <materialIcons:MaterialIcon Classes="toolbar-icon"
                                          Kind="Close"
                                          Width="18"
                                          Height="18" />
            </Button>
          </Grid>

          <ScrollViewer Grid.Row="1"
                        Margin="0,14,0,0"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <Border Padding="18,0,12,16">
              <StackPanel Spacing="18">
                <Border Classes="banner"
                        Padding="10,8"
                        IsVisible="{Binding HasSearchPanelNotice}">
                  <TextBlock Text="{Binding SearchPanelNotice}"
                             Classes="muted"
                             TextWrapping="Wrap" />
                </Border>

                <StackPanel Spacing="8">
                  <TextBlock Text="{loc:Loc panel.search.query}"
                             Classes="metadata-label" />
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="8">
                    <TextBox Classes="toolbar-input"
                             Grid.Column="0"
                             Watermark="{loc:Loc panel.search.query.placeholder}"
                             Text="{Binding SearchQueryInput}" />

                    <Button Grid.Column="1"
                            Content="{loc:Loc toolbar.search.label}"
                            Command="{Binding SearchTextCommand}" />
                  </Grid>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                  <Button Content="{loc:Loc panel.search.recognize}"
                          Command="{Binding RunSearchOcrCommand}"
                          IsVisible="{Binding CanRunDocumentOcr}" />
                  <Button Content="{loc:Loc panel.search.cancel_analysis}"
                          Command="{Binding CancelDocumentTextAnalysisCommand}"
                          IsVisible="{Binding CanCancelDocumentTextAnalysis}" />
                </StackPanel>

                <Border Classes="toolbar-group"
                        IsVisible="{Binding HasSearchResults}">
                  <DockPanel LastChildFill="False"
                             Margin="0">
                    <StackPanel DockPanel.Dock="Left"
                                Margin="4"
                                Spacing="0">
                      <TextBlock Text="{Binding SearchResultSummary}"
                                 Classes="toolbar-metric-value" />
                      <TextBlock Text="{Binding SearchSelectionIndicator}"
                                 Classes="toolbar-metric-label" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                Spacing="4">
                      <Button Classes="toolbar-button"
                              Command="{Binding PreviousSearchResultCommand}"
                              ToolTip.Tip="{loc:Loc search.result.previous}">
                        <materialIcons:MaterialIcon Classes="toolbar-icon"
                                                    Kind="ChevronUp"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{DynamicResource Brush.Icon}" />
                      </Button>

                      <Button Classes="toolbar-button"
                              Command="{Binding NextSearchResultCommand}"
                              ToolTip.Tip="{loc:Loc search.result.next}">
                        <materialIcons:MaterialIcon Classes="toolbar-icon"
                                                    Kind="ChevronDown"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{DynamicResource Brush.Icon}" />
                      </Button>
                    </StackPanel>
                  </DockPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding SearchResults}"
                              IsVisible="{Binding HasSearchResults}">
                  <ItemsControl.Styles>
                    <Style Selector="ContentPresenter">
                      <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style>
                  </ItemsControl.Styles>

                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Classes="search-result-button"
                              Command="{Binding $parent[Window].DataContext.OpenSearchResultCommand}"
                              CommandParameter="{Binding}"
                              HorizontalContentAlignment="Stretch">
                        <Border Classes="search-result-item"
                                Classes.selected="{Binding IsSelected}">
                          <StackPanel Spacing="6">
                            <TextBlock Text="{Binding PageLabel}"
                                       Classes="metadata-label" />
                            <TextBlock Text="{Binding Excerpt}"
                                       TextWrapping="Wrap" />
                          </StackPanel>
                        </Border>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- Preferences panel -->
      <Border Grid.Column="1"
              Width="{Binding PreferencesPanelWidth}"
              IsHitTestVisible="{Binding IsPreferencesPanelInteractive}"
              Margin="0,24,24,24"
              Padding="18,16"
              Classes="card info-panel"
              Background="{DynamicResource Brush.Surface}"
              ClipToBounds="True"
              IsVisible="{Binding IsPreferencesPanelOpen}">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.22" />
          </Transitions>
        </Border.Transitions>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
            <StackPanel Spacing="4">
              <TextBlock Text="{loc:Loc panel.preferences.title}"
                         Classes="title" />
              <TextBlock Text="{loc:Loc panel.preferences.description}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="{loc:Loc panel.preferences.language}"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding LanguagePreferenceOptions}"
                        SelectedItem="{Binding SelectedLanguagePreference}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="{loc:Loc panel.preferences.theme}"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding ThemePreferenceOptions}"
                        SelectedItem="{Binding SelectedThemePreference}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="{loc:Loc panel.preferences.default_zoom}"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding DefaultZoomPreferenceOptions}"
                        SelectedItem="{Binding SelectedDefaultZoomPreference}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="{loc:Loc panel.preferences.sidebar}"
                         Classes="metadata-label" />
              <CheckBox Content="{loc:Loc panel.preferences.show_thumbnails}"
                        IsChecked="{Binding ShowThumbnailsPanelPreference}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="{loc:Loc panel.preferences.cache_size}"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding MemoryCacheEntryLimitOptions}"
                        SelectedItem="{Binding SelectedMemoryCacheEntryLimit}" />
              <TextBlock Text="{loc:Loc panel.preferences.cache_help}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Print panel -->
      <Border Grid.Column="1"
              Width="{Binding PrintPanelWidth}"
              IsHitTestVisible="{Binding IsPrintPanelInteractive}"
              Margin="0,24,24,24"
              Padding="18,16"
              Classes="card info-panel"
              Background="{DynamicResource Brush.Surface}"
              ClipToBounds="True"
              IsVisible="{Binding IsPrintPanelOpen}">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.22" />
          </Transitions>
        </Border.Transitions>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="18">
            <StackPanel Spacing="4">
              <TextBlock Text="{loc:Loc panel.print.title}"
                         Classes="title" />
              <TextBlock Text="{Binding CurrentDocumentName}"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <TextBlock Text="{loc:Loc panel.print.description}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Border Classes="banner"
                    Padding="10,8"
                    IsVisible="{Binding HasPrintPanelNotice}">
              <TextBlock Text="{Binding PrintPanelNotice}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </Border>

            <StackPanel Spacing="8">
              <DockPanel LastChildFill="False">
                <TextBlock Text="{loc:Loc panel.print.printer}"
                           Classes="metadata-label"
                           VerticalAlignment="Center" />
                <Button Content="{loc:Loc panel.print.refresh}"
                        DockPanel.Dock="Right"
                        Command="{Binding RefreshPrintDestinationsCommand}" />
              </DockPanel>

              <ComboBox Classes="preferences-input"
                        SelectedItem="{Binding SelectedPrintDestination}">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
                <ComboBox.ItemsSource>
                  <Binding Path="PrintDestinations" />
                </ComboBox.ItemsSource>
              </ComboBox>
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="{loc:Loc panel.print.copies}"
                         Classes="metadata-label" />
              <TextBox Classes="toolbar-input"
                       Text="{Binding PrintCopiesInput}" />
            </StackPanel>

            <StackPanel Spacing="8"
                        IsVisible="{Binding IsPrintPageRangeVisible}">
              <TextBlock Text="{loc:Loc panel.print.pages}"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding PrintPageRangeOptions}"
                        SelectedItem="{Binding SelectedPrintPageRangeOption}" />
              <TextBox Classes="toolbar-input"
                       Watermark="{loc:Loc panel.print.pages.placeholder}"
                       Text="{Binding PrintCustomPageRange}"
                       IsVisible="{Binding IsCustomPrintRangeVisible}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="{loc:Loc panel.print.orientation}"
                         Classes="metadata-label" />
              <ComboBox Classes="preferences-input"
                        ItemsSource="{Binding PrintOrientationOptions}"
                        SelectedItem="{Binding SelectedPrintOrientationOption}" />
            </StackPanel>

            <CheckBox Content="{loc:Loc panel.print.fit}"
                      IsChecked="{Binding PrintFitToPage}" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
              <Button Content="{loc:Loc app.cancel}"
                      Command="{Binding PrintDocumentCommand}" />
              <Button Content="{loc:Loc panel.print.print}"
                      Command="{Binding SubmitPrintJobCommand}" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Annotations panel -->
      <Border Grid.Column="1"
              Width="{Binding AnnotationsPanelWidth}"
              IsHitTestVisible="{Binding IsAnnotationsPanelInteractive}"
              Margin="0,24,24,24"
              Padding="18,16"
              Classes="card info-panel"
              Background="{DynamicResource Brush.Surface}"
              ClipToBounds="True"
              IsVisible="{Binding IsAnnotationsPanelOpen}">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Width" Duration="0:0:0.22" />
          </Transitions>
        </Border.Transitions>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Classes="annotation-panel-content"
                      Spacing="12">
            <StackPanel Spacing="3">
              <TextBlock Text="{loc:Loc panel.annotations.title}"
                         Classes="title annotation-panel-title" />
              <TextBlock Text="{loc:Loc panel.annotations.description}"
                         Classes="muted annotation-panel-description"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Border Classes="annotation-tabs">
              <Grid ColumnDefinitions="*,*,*">
                <Border Grid.Column="0"
                        Classes="annotation-tab selected">
                  <TextBlock Text="{loc:Loc panel.annotations.tab.tools}"
                             TextAlignment="Center" />
                </Border>
                <Border Grid.Column="1"
                        Classes="annotation-tab">
                  <TextBlock Text="{loc:Loc panel.annotations.tab.style}"
                             TextAlignment="Center" />
                </Border>
                <Border Grid.Column="2"
                        Classes="annotation-tab">
                  <TextBlock Text="{loc:Loc panel.annotations.tab.comments}"
                             TextAlignment="Center" />
                </Border>
              </Grid>
            </Border>

            <Border Classes="annotation-notice"
                    IsVisible="{Binding HasAnnotationsPanelNotice}">
              <TextBlock Text="{Binding AnnotationsPanelNotice}"
                         Classes="muted"
                         TextWrapping="Wrap" />
            </Border>

            <Border Classes="annotation-section-card">
              <StackPanel Spacing="10">
                <TextBlock Text="{loc:Loc panel.annotations.section.add}"
                           Classes="annotation-section-title" />

                <Grid Classes="annotation-tools-grid"
                      ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto,Auto,Auto">
                  <Button Grid.Row="0"
                          Grid.Column="0"
                          Classes="annotation-tool-button"
                          Classes.selected="{Binding IsSelectAnnotationToolSelected}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Select">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                      <materialIcons:MaterialIcon Grid.Column="0"
                                                  Kind="CursorDefaultClickOutline"
                                                  Width="17"
                                                  Height="17" />
                      <TextBlock Grid.Column="1"
                                 Text="{loc:Loc annotation.tool.select}"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Button>

                  <Button Grid.Row="0"
                          Grid.Column="1"
                          Classes="annotation-tool-button annotation-tool-highlight"
                          Command="{Binding AddHighlightAnnotationFromSelectionCommand}"
                          IsEnabled="{Binding CanCreateHighlightAnnotation}">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                      <materialIcons:MaterialIcon Grid.Column="0"
                                                  Kind="FormatColorHighlight"
                                                  Width="17"
                                                  Height="17" />
                      <TextBlock Grid.Column="1"
                                 Text="{loc:Loc annotation.tool.highlight}"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Button>

                  <Button Grid.Row="1"
                          Grid.Column="0"
                          Classes="annotation-tool-button"
                          Classes.selected="{Binding IsInkAnnotationToolSelected}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Ink">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                      <materialIcons:MaterialIcon Grid.Column="0"
                                                  Kind="DrawPen"
                                                  Width="17"
                                                  Height="17" />
                      <TextBlock Grid.Column="1"
                                 Text="{loc:Loc annotation.tool.ink}"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Button>

                  <Button Grid.Row="1"
                          Grid.Column="1"
                          Classes="annotation-tool-button"
                          Classes.selected="{Binding IsTextAnnotationToolSelected}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Text">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                      <materialIcons:MaterialIcon Grid.Column="0"
                                                  Kind="FormatColorText"
                                                  Width="17"
                                                  Height="17" />
                      <TextBlock Grid.Column="1"
                                 Text="{loc:Loc annotation.tool.text}"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Button>

                  <Button Grid.Row="2"
                          Grid.Column="0"
                          Classes="annotation-tool-button"
                          Classes.selected="{Binding IsNoteAnnotationToolSelected}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Note">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                      <materialIcons:MaterialIcon Grid.Column="0"
                                                  Kind="StickyNoteTextOutline"
                                                  Width="17"
                                                  Height="17" />
                      <TextBlock Grid.Column="1"
                                 Text="{loc:Loc annotation.tool.note}"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Button>

                  <Button Grid.Row="2"
                          Grid.Column="1"
                          Classes="annotation-tool-button"
                          Classes.selected="{Binding IsRectangleAnnotationToolSelected}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Rectangle">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                      <materialIcons:MaterialIcon Grid.Column="0"
                                                  Kind="VectorRectangle"
                                                  Width="17"
                                                  Height="17" />
                      <TextBlock Grid.Column="1"
                                 Text="{loc:Loc annotation.tool.rectangle}"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Button>

                  <Button Grid.Row="3"
                          Grid.Column="0"
                          Classes="annotation-tool-button"
                          Classes.selected="{Binding IsSignatureAnnotationToolSelected}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Signature">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                      <materialIcons:MaterialIcon Grid.Column="0"
                                                  Kind="SignatureFreehand"
                                                  Width="17"
                                                  Height="17" />
                      <TextBlock Grid.Column="1"
                                 Text="{loc:Loc annotation.tool.signature}"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Button>

                  <Button Grid.Row="3"
                          Grid.Column="1"
                          Classes="annotation-tool-button"
                          Classes.selected="{Binding IsStampAnnotationToolSelected}"
                          Command="{Binding SelectAnnotationToolCommand}"
                          CommandParameter="Stamp">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">
                      <materialIcons:MaterialIcon Grid.Column="0"
                                                  Kind="Stamper"
                                                  Width="17"
                                                  Height="17" />
                      <TextBlock Grid.Column="1"
                                 Text="{loc:Loc annotation.tool.stamp}"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Button>
                </Grid>
              </StackPanel>
            </Border>

            <Border Classes="annotation-section-card">
              <StackPanel Spacing="10">
                <TextBlock Text="{loc:Loc panel.annotations.section.properties}"
                           Classes="annotation-section-title" />

                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">
                  <TextBlock Grid.Column="0"
                             Text="{loc:Loc panel.annotations.color}"
                             Classes="metadata-label"
                             VerticalAlignment="Center" />
                  <WrapPanel Grid.Column="1"
                             Classes="annotation-color-row">
                    <Button Classes="annotation-color-button"
                            Classes.selected="{Binding IsAnnotationColorRedSelected}"
                            Background="#E95058"
                            Command="{Binding SelectAnnotationColorCommand}"
                            CommandParameter="#E95058" />
                    <Button Classes="annotation-color-button"
                            Classes.selected="{Binding IsAnnotationColorYellowSelected}"
                            Background="#F2C94C"
                            Command="{Binding SelectAnnotationColorCommand}"
                            CommandParameter="#F2C94C" />
                    <Button Classes="annotation-color-button"
                            Classes.selected="{Binding IsAnnotationColorGreenSelected}"
                            Background="#58C874"
                            Command="{Binding SelectAnnotationColorCommand}"
                            CommandParameter="#58C874" />
                    <Button Classes="annotation-color-button"
                            Classes.selected="{Binding IsAnnotationColorCyanSelected}"
                            Background="#1CB6D8"
                            Command="{Binding SelectAnnotationColorCommand}"
                            CommandParameter="#1CB6D8" />
                    <Button Classes="annotation-color-button"
                            Classes.selected="{Binding IsAnnotationColorPurpleSelected}"
                            Background="#7B61FF"
                            Command="{Binding SelectAnnotationColorCommand}"
                            CommandParameter="#7B61FF" />
                    <Button Classes="annotation-color-button"
                            Classes.selected="{Binding IsAnnotationColorPinkSelected}"
                            Background="#E04DA5"
                            Command="{Binding SelectAnnotationColorCommand}"
                            CommandParameter="#E04DA5" />
                  </WrapPanel>
                </Grid>

                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="12">
                  <TextBlock Grid.Column="0"
                             Text="{loc:Loc panel.annotations.thickness}"
                             Classes="metadata-label"
                             VerticalAlignment="Center" />
                  <StackPanel Grid.Column="1"
                              Orientation="Horizontal"
                              Spacing="6">
                    <Button Classes="annotation-stroke-button"
                            Classes.selected="{Binding IsAnnotationThicknessTwoSelected}"
                            Content="2 px"
                            Command="{Binding SelectAnnotationThicknessCommand}"
                            CommandParameter="2" />
                    <Button Classes="annotation-stroke-button"
                            Classes.selected="{Binding IsAnnotationThicknessFourSelected}"
                            Content="4 px"
                            Command="{Binding SelectAnnotationThicknessCommand}"
                            CommandParameter="4" />
                    <Button Classes="annotation-stroke-button"
                            Classes.selected="{Binding IsAnnotationThicknessEightSelected}"
                            Content="8 px"
                            Command="{Binding SelectAnnotationThicknessCommand}"
                            CommandParameter="8" />
                  </StackPanel>
                </Grid>

                <StackPanel Spacing="8"
                            IsVisible="{Binding ShowAnnotationTextEditor}">
                  <TextBlock Text="{loc:Loc panel.annotations.text}"
                             Classes="metadata-label" />
                  <TextBox Classes="toolbar-input annotation-input"
                           Text="{Binding AnnotationTextDraft}"
                           Watermark="{loc:Loc panel.annotations.text.placeholder}" />
                </StackPanel>

                <StackPanel Spacing="10"
                            IsVisible="{Binding ShowSignatureControls}">
                  <Grid ColumnDefinitions="*,Auto,Auto"
                        ColumnSpacing="8">
                    <TextBlock Grid.Column="0"
                               Text="{loc:Loc panel.annotations.signature_library}"
                               Classes="metadata-label"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Classes="annotation-compact-button"
                            Content="{loc:Loc panel.annotations.import_image}"
                            Command="{Binding ImportSignatureAssetCommand}" />
                    <Button Grid.Column="2"
                            Classes="annotation-list-delete-button"
                            CommandParameter="{Binding SelectedSignatureAssetId}"
                            Command="{Binding DeleteSelectedSignatureAssetCommand}"
                            ToolTip.Tip="{loc:Loc panel.annotations.delete_signature}">
                      <materialIcons:MaterialIcon Classes="toolbar-icon"
                                                  Kind="TrashCanOutline"
                                                  Width="16"
                                                  Height="16" />
                    </Button>
                  </Grid>

                  <ItemsControl ItemsSource="{Binding SignatureAssets}"
                                IsVisible="{Binding HasSignatureAssets}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="annotation-list-item compact">
                          <Grid ColumnDefinitions="*,Auto"
                                ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Classes="annotation-list-button"
                                    Command="{Binding $parent[Window].DataContext.SelectSignatureAssetCommand}"
                                    CommandParameter="{Binding Id}"
                                    HorizontalContentAlignment="Stretch">
                              <StackPanel Spacing="2">
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding FilePath}"
                                           Classes="muted"
                                           TextTrimming="CharacterEllipsis" />
                              </StackPanel>
                            </Button>

                            <Button Grid.Column="1"
                                    Classes="annotation-list-delete-button"
                                    Command="{Binding $parent[Window].DataContext.DeleteSelectedSignatureAssetCommand}"
                                    CommandParameter="{Binding Id}"
                                    ToolTip.Tip="{loc:Loc panel.annotations.delete_signature}">
                              <materialIcons:MaterialIcon Classes="toolbar-icon"
                                                          Kind="TrashCanOutline"
                                                          Width="16"
                                                          Height="16" />
                            </Button>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <TextBlock Text="{loc:Loc panel.annotations.draw_signature}"
                             Classes="metadata-label" />
                  <TextBox Classes="toolbar-input annotation-input"
                           Text="{Binding SignatureAssetNameInput}"
                           Watermark="{loc:Loc panel.annotations.signature_name.placeholder}" />

                  <Border Classes="signature-pad-card">
                    <Grid HorizontalAlignment="Center">
                      <Image Source="{Binding SignaturePadPreviewBitmap}"
                             Width="248"
                             Height="124"
                             Stretch="Fill" />
                      <Border x:Name="SignaturePadInteractionLayer"
                              Width="248"
                              Height="124"
                              Background="Transparent"
                              PointerPressed="OnSignaturePadPointerPressed"
                              PointerMoved="OnSignaturePadPointerMoved"
                              PointerReleased="OnSignaturePadPointerReleased"
                              PointerCaptureLost="OnSignaturePadPointerCaptureLost" />
                    </Grid>
                  </Border>

                  <StackPanel Orientation="Horizontal"
                              HorizontalAlignment="Right"
                              Spacing="8">
                    <Button Classes="annotation-compact-button"
                            Content="{loc:Loc panel.annotations.clear_drawing}"
                            Command="{Binding ClearSignatureCaptureCommand}" />
                    <Button Classes="annotation-compact-button primary"
                            Content="{loc:Loc panel.annotations.save_signature}"
                            Command="{Binding SaveDrawnSignatureAssetCommand}" />
                  </StackPanel>
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Classes="annotation-section-card">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                  <TextBlock Grid.Column="0"
                             Text="{loc:Loc panel.annotations.section.page}"
                             Classes="annotation-section-title"
                             VerticalAlignment="Center" />
                  <StackPanel Grid.Column="1"
                              Orientation="Horizontal"
                              Spacing="6">
                    <Button Classes="annotation-icon-action-button"
                            Command="{Binding UndoAnnotationsCommand}"
                            ToolTip.Tip="{loc:Loc panel.annotations.undo}">
                      <materialIcons:MaterialIcon Kind="UndoVariant"
                                                  Width="15"
                                                  Height="15" />
                    </Button>
                    <Button Classes="annotation-icon-action-button"
                            Command="{Binding RedoAnnotationsCommand}"
                            ToolTip.Tip="{loc:Loc panel.annotations.redo}">
                      <materialIcons:MaterialIcon Kind="Redo"
                                                  Width="15"
                                                  Height="15" />
                    </Button>
                    <Button Classes="annotation-icon-action-button danger"
                            Command="{Binding DeleteSelectedAnnotationCommand}"
                            ToolTip.Tip="{loc:Loc panel.annotations.delete_selected}">
                      <materialIcons:MaterialIcon Kind="TrashCanOutline"
                                                  Width="15"
                                                  Height="15" />
                    </Button>
                  </StackPanel>
                </Grid>

                <TextBlock Text="{loc:Loc panel.annotations.empty_page}"
                           Classes="muted"
                           TextWrapping="Wrap"
                           IsVisible="{Binding HasNoCurrentPageAnnotations}" />

                <ItemsControl ItemsSource="{Binding CurrentPageAnnotations}"
                              IsVisible="{Binding HasCurrentPageAnnotations}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Classes="annotation-list-item">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                          <Button Grid.Column="0"
                                  Classes="annotation-list-button"
                                  Command="{Binding $parent[Window].DataContext.SelectCurrentPageAnnotationCommand}"
                                  CommandParameter="{Binding}"
                                  HorizontalContentAlignment="Stretch">
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="10">
                              <Border Grid.Column="0"
                                      Classes="annotation-list-avatar">
                                <materialIcons:MaterialIcon Kind="PencilOutline"
                                                            Width="15"
                                                            Height="15" />
                              </Border>
                              <StackPanel Grid.Column="1"
                                          Spacing="3">
                                <TextBlock Text="{Binding KindLabel}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Text}"
                                           Classes="muted"
                                           TextWrapping="Wrap" />
                              </StackPanel>
                            </Grid>
                          </Button>

                          <Button Grid.Column="1"
                                  Classes="annotation-list-delete-button"
                                  Command="{Binding $parent[Window].DataContext.DeleteCurrentPageAnnotationCommand}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="{loc:Loc panel.annotations.delete_selected}">
                            <materialIcons:MaterialIcon Kind="TrashCanOutline"
                                                        Width="15"
                                                        Height="15" />
                          </Button>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="3"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="12,8"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,1,0,0"
            Background="{DynamicResource Brush.Surface}">
      <Grid>
        <TextBlock Text="{Binding StatusText}"
                   Classes="muted"
                   IsVisible="{Binding ShowStatusFooter}" />

        <DockPanel LastChildFill="True"
                   IsVisible="{Binding ShowRecentFilesFooter}">
          <TextBlock Text="{loc:Loc app.recent.title}"
                     Classes="footer-recent-title"
                     DockPanel.Dock="Left"
                     VerticalAlignment="Center"
                     Margin="4,0,14,0" />

          <Button Content="{loc:Loc app.recent.clear}"
                  Classes="footer-clear-button"
                  DockPanel.Dock="Right"
                  Command="{Binding ClearRecentFilesCommand}" />

          <ScrollViewer HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding RecentFiles}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Classes="recent-file-button footer-recent-button"
                          Command="{Binding $parent[Window].DataContext.OpenRecentFileCommand}"
                          CommandParameter="{Binding}"
                          ToolTip.Tip="{Binding FilePath}">
                    <Border Classes="footer-recent-file-card">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="8"
                                  VerticalAlignment="Center">
                        <materialIcons:MaterialIcon Kind="FolderOpenOutline"
                                                    Classes="footer-recent-icon"
                                                    Width="18"
                                                    Height="18" />
                        <StackPanel Width="150">
                          <TextBlock Text="{Binding FileName}"
                                     FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis"
                                     TextWrapping="NoWrap" />
                          <TextBlock Text="{Binding DocumentType}"
                                     Classes="muted"
                                     FontSize="11"
                                     TextTrimming="CharacterEllipsis"
                                     TextWrapping="NoWrap" />
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </DockPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
