<Window
    x:Class="Velune.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:Velune.Windows.Services">

  <Grid x:Name="Root"
        Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">

    <Grid.KeyboardAccelerators>
      <KeyboardAccelerator Key="C"
                           Modifiers="Control"
                           Invoked="OnCopySelectedTextKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="F"
                           Modifiers="Control"
                           Invoked="OnSearchKeyboardAcceleratorInvoked" />
      <KeyboardAccelerator Key="S"
                           Modifiers="Control"
                           Invoked="OnSaveKeyboardAcceleratorInvoked" />
    </Grid.KeyboardAccelerators>

    <Grid.Resources>
      <ResourceDictionary>
        <services:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <services:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <services:AnnotationToolBackgroundConverter x:Key="AnnotationToolBackground" />
        <services:BoolToSelectedToolBackgroundConverter x:Key="BoolToSelectedToolBackground" />

        <Style x:Key="TitleBarIconButtonStyle" TargetType="Button">
          <Setter Property="Width" Value="42" />
          <Setter Property="Height" Value="42" />
          <Setter Property="MinWidth" Value="42" />
          <Setter Property="Padding" Value="0" />
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="RibbonIconButtonStyle" TargetType="Button">
          <Setter Property="Width" Value="40" />
          <Setter Property="Height" Value="40" />
          <Setter Property="MinWidth" Value="40" />
          <Setter Property="Padding" Value="0" />
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="RibbonTextButtonStyle" TargetType="Button">
          <Setter Property="Height" Value="40" />
          <Setter Property="MinWidth" Value="40" />
          <Setter Property="Padding" Value="10,0" />
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="TopNavButtonStyle" TargetType="Button">
          <Setter Property="Height" Value="38" />
          <Setter Property="Padding" Value="14,0" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
          <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="RibbonLabelStyle" TargetType="TextBlock">
          <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
          <Setter Property="FontSize" Value="12" />
          <Setter Property="HorizontalAlignment" Value="Center" />
          <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <Style x:Key="RibbonSeparatorStyle" TargetType="Rectangle">
          <Setter Property="Width" Value="1" />
          <Setter Property="Height" Value="64" />
          <Setter Property="Fill" Value="{ThemeResource DividerBrush}" />
          <Setter Property="Opacity" Value="0.55" />
          <Setter Property="VerticalAlignment" Value="Center" />
          <Setter Property="HorizontalAlignment" Value="Center" />
          <Setter Property="Margin" Value="14,0" />
        </Style>

        <Style x:Key="RibbonPillBorderStyle" TargetType="Border">
          <Setter Property="Padding" Value="1" />
          <Setter Property="Background" Value="{ThemeResource InputBrush}" />
          <Setter Property="BorderBrush" Value="{ThemeResource InputBorderBrush}" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RibbonPillButtonStyle" TargetType="Button">
          <Setter Property="Height" Value="36" />
          <Setter Property="MinWidth" Value="40" />
          <Setter Property="Padding" Value="12,0" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderBrush" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
          <Setter Property="HorizontalContentAlignment" Value="Center" />
          <Setter Property="VerticalContentAlignment" Value="Center" />
          <Setter Property="VerticalAlignment" Value="Center" />
          <Setter Property="UseSystemFocusVisuals" Value="True" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="Button">
                <Grid x:Name="TemplateRoot"
                      MinWidth="{TemplateBinding MinWidth}"
                      Height="{TemplateBinding Height}"
                      Background="Transparent">
                  <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup x:Name="CommonStates">
                      <VisualState x:Name="Normal" />

                      <VisualState x:Name="PointerOver">
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                           Storyboard.TargetProperty="Opacity"
                                           To="1"
                                           Duration="0:0:0.08" />
                        </Storyboard>
                      </VisualState>

                      <VisualState x:Name="Pressed">
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetName="PressedLayer"
                                           Storyboard.TargetProperty="Opacity"
                                           To="1"
                                           Duration="0:0:0.03" />
                        </Storyboard>
                      </VisualState>

                      <VisualState x:Name="Disabled">
                        <Storyboard>
                          <DoubleAnimation Storyboard.TargetName="DisabledLayer"
                                           Storyboard.TargetProperty="Opacity"
                                           To="1"
                                           Duration="0:0:0" />
                          <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                           Storyboard.TargetProperty="Opacity"
                                           To="0.45"
                                           Duration="0:0:0" />
                        </Storyboard>
                      </VisualState>
                    </VisualStateGroup>
                  </VisualStateManager.VisualStateGroups>

                  <Border x:Name="BaseLayer"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{TemplateBinding CornerRadius}" />

                  <Border x:Name="HoverLayer"
                          Background="{ThemeResource ActiveToolBrush}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Opacity="0" />

                  <Border x:Name="PressedLayer"
                          Background="{ThemeResource ActiveToolBorderBrush}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Opacity="0" />

                  <Border x:Name="DisabledLayer"
                          Background="#10FFFFFF"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Opacity="0" />

                  <ContentPresenter x:Name="ContentPresenter"
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    Padding="{TemplateBinding Padding}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>

        <Style x:Key="RibbonPillIconButtonStyle" TargetType="Button" BasedOn="{StaticResource RibbonPillButtonStyle}">
          <Setter Property="Width" Value="38" />
          <Setter Property="MinWidth" Value="38" />
          <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="RibbonPillDividerStyle" TargetType="Rectangle">
          <Setter Property="Width" Value="1" />
          <Setter Property="Height" Value="22" />
          <Setter Property="Fill" Value="{ThemeResource DividerBrush}" />
          <Setter Property="Opacity" Value="0.5" />
          <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
          <Setter Property="FontSize" Value="17" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PanelLabelStyle" TargetType="TextBlock">
          <Setter Property="Foreground" Value="{ThemeResource PanelLabelBrush}" />
          <Setter Property="FontSize" Value="12" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="AnnotationToolStyle" TargetType="Button">
          <Setter Property="Width" Value="78" />
          <Setter Property="Height" Value="58" />
          <Setter Property="Margin" Value="0" />
          <Setter Property="CornerRadius" Value="4" />
          <Setter Property="Background" Value="{ThemeResource CardBrush}" />
          <Setter Property="BorderBrush" Value="{ThemeResource ButtonBorderBrush}" />
          <Setter Property="BorderThickness" Value="1" />
          <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
          <Setter Property="HorizontalAlignment" Value="Center" />
          <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

      </ResourceDictionary>
    </Grid.Resources>

    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="RibbonAdaptiveStates">
        <VisualState x:Name="RibbonCompact">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="SearchBoxBorder.MinWidth" Value="420" />
            <Setter Target="SearchBoxBorder.MaxWidth" Value="1200" />
            <Setter Target="AnnotateBtnNote.Visibility" Value="Collapsed" />
            <Setter Target="AnnotateBtnStamp.Visibility" Value="Collapsed" />
            <Setter Target="AnnotateBtnInk.Visibility" Value="Collapsed" />
            <Setter Target="AnnotateBtnErase.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>

        <VisualState x:Name="RibbonMedium">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1550" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="SearchBoxBorder.MinWidth" Value="520" />
            <Setter Target="SearchBoxBorder.MaxWidth" Value="1200" />
            <Setter Target="AnnotateBtnNote.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnStamp.Visibility" Value="Collapsed" />
            <Setter Target="AnnotateBtnInk.Visibility" Value="Collapsed" />
            <Setter Target="AnnotateBtnErase.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>

        <VisualState x:Name="RibbonWide">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1750" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="SearchBoxBorder.MinWidth" Value="640" />
            <Setter Target="SearchBoxBorder.MaxWidth" Value="1400" />
            <Setter Target="AnnotateBtnNote.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnStamp.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnInk.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnErase.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>

        <VisualState x:Name="RibbonExtraWide">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1950" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="SearchBoxBorder.MinWidth" Value="760" />
            <Setter Target="SearchBoxBorder.MaxWidth" Value="1800" />
            <Setter Target="AnnotateBtnNote.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnStamp.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnInk.Visibility" Value="Visible" />
            <Setter Target="AnnotateBtnErase.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <Grid.RowDefinitions>
      <RowDefinition Height="50" />
      <RowDefinition Height="40" />
      <RowDefinition Height="106" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid x:Name="TitleBarDragRegion"
          Grid.Row="0"
          Padding="18,0,150,0"
          Background="{ThemeResource TitleBarBgBrush}">

      <Border x:Name="TitleBarDragHandle"
              Margin="-18,0,-150,0"
              Background="{ThemeResource TitleBarBgBrush}" />

      <StackPanel x:Name="TitleBarInteractiveRegion"
                  Orientation="Horizontal"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Bottom"
                  Spacing="4">
        <ItemsControl ItemsSource="{Binding DocumentTabs}"
                      Height="46"
                      VerticalAlignment="Bottom">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <ItemsStackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Width="250"
                      Height="36"
                      Margin="2,0"
                      Background="{Binding TabBackground, Mode=OneWay}"
                      BorderBrush="{Binding TabBorderBrush, Mode=OneWay}"
                      BorderThickness="1"
                      CornerRadius="6"
                      PointerEntered="OnTabPointerEntered"
                      PointerExited="OnTabPointerExited">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <FontIcon Glyph="&#xE8A5;"
                            FontFamily="Segoe Fluent Icons"
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            FontSize="14"
                            Margin="12,0,8,0"
                            VerticalAlignment="Center" />

                  <TextBlock Grid.Column="1"
                             Text="{Binding Title}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontSize="13"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center" />

                  <Button Grid.Column="0"
                          Grid.ColumnSpan="2"
                          MinWidth="0"
                          Padding="0"
                          Background="Transparent"
                          BorderThickness="0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Click="OnTabClicked" />

                  <Button Grid.Column="2"
                          Width="30"
                          Height="30"
                          Margin="4,0,8,0"
                          Padding="0"
                          Background="Transparent"
                          BorderThickness="0"
                          Click="OnCloseTabClicked"
                          ToolTipService.ToolTip="{Binding DataContext.Labels.CloseTab, ElementName=Root}"
                          AutomationProperties.Name="{Binding DataContext.Labels.CloseTab, ElementName=Root}"
                          VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE8BB;"
                              FontFamily="Segoe Fluent Icons"
                              FontSize="10" />
                  </Button>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Style="{StaticResource TitleBarIconButtonStyle}"
                Command="{Binding OpenCommand}"
                ToolTipService.ToolTip="{Binding Labels.Open}"
                AutomationProperties.Name="{Binding Labels.Open}">
          <FontIcon Glyph="&#xE710;"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="16" />
        </Button>
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1"
          Background="{ThemeResource MenuBarBrush}"
          BorderBrush="{ThemeResource MenuBarBorderBrush}"
          BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal"
                  Padding="18,0,0,0"
                  Spacing="4"
                  VerticalAlignment="Center">
        <Button Content="{Binding Labels.File}"
                Style="{StaticResource TopNavButtonStyle}">
          <Button.Flyout>
            <MenuFlyout>
              <MenuFlyoutItem Text="{Binding Labels.Open}" Command="{Binding OpenCommand}" />
              <MenuFlyoutItem Text="{Binding Labels.Save}" Command="{Binding SaveDocumentCommand}" />
              <MenuFlyoutItem Text="{Binding Labels.SaveAs}" Command="{Binding SaveDocumentAsCommand}" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{Binding Labels.Merge}" Command="{Binding MergeCommand}" />
              <MenuFlyoutItem Text="{Binding Labels.Print}" Command="{Binding PrintCommand}" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{Binding Labels.CloseTab}" Click="OnCloseActiveTabMenuClicked" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>

        <Grid>
          <Button Content="{Binding Labels.RibbonHome}"
                  Style="{StaticResource TopNavButtonStyle}" />
          <Rectangle Height="3"
                     Fill="{ThemeResource AccentBrush}"
                     VerticalAlignment="Bottom"
                     Margin="14,0"
                     RadiusX="1"
                     RadiusY="1" />
        </Grid>

        <Button Content="{Binding Labels.View}"
                Style="{StaticResource TopNavButtonStyle}">
          <Button.Flyout>
            <MenuFlyout>
              <MenuFlyoutItem Text="{Binding Labels.Pages}" Command="{Binding TogglePagesPanelCommand}" />
              <MenuFlyoutItem Text="{Binding Labels.Info}" Command="{Binding ToggleInfoPanelCommand}" />
              <MenuFlyoutItem Text="{Binding Labels.Search}" Command="{Binding OpenSearchCommand}" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{Binding Labels.PageOrganizer}" Click="OnOpenPageOrganizerClicked" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{Binding Labels.ZoomFit}" Command="{Binding FitPageCommand}" />
              <MenuFlyoutItem Text="{Binding Labels.ZoomActual}" Command="{Binding ActualSizeCommand}" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>

        <Button Content="{Binding Labels.MenuSelection}"
                Style="{StaticResource TopNavButtonStyle}">
          <Button.Flyout>
            <MenuFlyout>
              <MenuFlyoutItem Text="{Binding Labels.PageRotateLeft}" Click="OnRibbonRotateLeftClick">
                <MenuFlyoutItem.Icon>
                  <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" RenderTransformOrigin="0.5,0.5">
                    <FontIcon.RenderTransform>
                      <ScaleTransform ScaleX="-1" />
                    </FontIcon.RenderTransform>
                  </FontIcon>
                </MenuFlyoutItem.Icon>
              </MenuFlyoutItem>
              <MenuFlyoutItem Text="{Binding Labels.PageRotateRight}" Click="OnRibbonRotateRightClick">
                <MenuFlyoutItem.Icon>
                  <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" />
                </MenuFlyoutItem.Icon>
              </MenuFlyoutItem>
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{Binding Labels.PageMoveUp}" Click="OnThumbnailMoveUpClick">
                <MenuFlyoutItem.Icon>
                  <FontIcon Glyph="&#xE74A;" FontFamily="Segoe Fluent Icons" />
                </MenuFlyoutItem.Icon>
              </MenuFlyoutItem>
              <MenuFlyoutItem Text="{Binding Labels.PageMoveDown}" Click="OnThumbnailMoveDownClick">
                <MenuFlyoutItem.Icon>
                  <FontIcon Glyph="&#xE74B;" FontFamily="Segoe Fluent Icons" />
                </MenuFlyoutItem.Icon>
              </MenuFlyoutItem>
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{Binding Labels.PageDelete}" Click="OnThumbnailDeleteClick">
                <MenuFlyoutItem.Icon>
                  <FontIcon Glyph="&#xE107;" FontFamily="Segoe Fluent Icons" />
                </MenuFlyoutItem.Icon>
              </MenuFlyoutItem>
            </MenuFlyout>
          </Button.Flyout>
        </Button>

        <Button Content="{Binding Labels.Annotate}"
                Style="{StaticResource TopNavButtonStyle}">
          <Button.Flyout>
            <MenuFlyout>
              <MenuFlyoutItem Text="{Binding Labels.Select}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Select" />
              <MenuFlyoutItem Text="{Binding Labels.Highlight}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Highlight" />
              <MenuFlyoutItem Text="{Binding Labels.Ink}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Ink" />
              <MenuFlyoutItem Text="{Binding Labels.Text}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Text" />
              <MenuFlyoutItem Text="{Binding Labels.Note}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Note" />
              <MenuFlyoutItem Text="{Binding Labels.Rectangle}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Rectangle" />
              <MenuFlyoutItem Text="{Binding Labels.Signature}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Signature" />
              <MenuFlyoutItem Text="{Binding Labels.Stamp}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Stamp" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="{Binding Labels.Annotations}" Command="{Binding ToggleAnnotationsPanelCommand}" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>

        <Button Content="{Binding Labels.RibbonHelp}"
                Style="{StaticResource TopNavButtonStyle}">
          <Button.Flyout>
            <MenuFlyout>
              <MenuFlyoutItem Text="{Binding Labels.Settings}" Command="{Binding ToggleSettingsPanelCommand}" />
              <MenuFlyoutItem Text="{Binding Labels.Info}" Command="{Binding ToggleInfoPanelCommand}" />
            </MenuFlyout>
          </Button.Flyout>
        </Button>
      </StackPanel>
    </Grid>

    <Border Grid.Row="2"
            Margin="8,6,8,6"
            Background="{ThemeResource RibbonBrush}"
            BorderBrush="{ThemeResource RibbonBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Translation="0,0,32">
      <Border.Shadow>
        <ThemeShadow />
      </Border.Shadow>
      <Grid Padding="18,8,18,7">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
            <Border Style="{StaticResource RibbonPillBorderStyle}">
              <StackPanel Orientation="Horizontal" Spacing="0">
                <Button Style="{StaticResource RibbonPillButtonStyle}"
                        Command="{Binding OpenCommand}"
                        ToolTipService.ToolTip="{Binding Labels.Open}"
                        AutomationProperties.Name="{Binding Labels.Open}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE838;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                    <TextBlock Text="{Binding Labels.Open}" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>

                <Button Style="{StaticResource RibbonPillButtonStyle}"
                        Command="{Binding MergeCommand}"
                        ToolTipService.ToolTip="{Binding Labels.Merge}"
                        AutomationProperties.Name="{Binding Labels.Merge}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8A5;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                    <TextBlock Text="{Binding Labels.Merge}" VerticalAlignment="Center" />
                  </StackPanel>
                </Button>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource RibbonPillBorderStyle}">
              <Button Style="{StaticResource RibbonPillButtonStyle}"
                      Command="{Binding PrintCommand}"
                      ToolTipService.ToolTip="{Binding Labels.Print}"
                      AutomationProperties.Name="{Binding Labels.Print}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <FontIcon Glyph="&#xE749;" FontFamily="Segoe Fluent Icons" FontSize="16" />
                  <TextBlock Text="{Binding Labels.Print}" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </Border>
          </StackPanel>

          <TextBlock Text="{Binding Labels.RibbonFileGroup}"
                     Style="{StaticResource RibbonLabelStyle}" />
        </StackPanel>

        <Rectangle Grid.Column="1" Style="{StaticResource RibbonSeparatorStyle}" />

        <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    Command="{Binding PreviousPageCommand}"
                    ToolTipService.ToolTip="{Binding Labels.PreviousPage}"
                    AutomationProperties.Name="{Binding Labels.PreviousPage}">
              <FontIcon Glyph="&#xE76B;" FontFamily="Segoe Fluent Icons" />
            </Button>

            <Border Height="40"
                    MinWidth="74"
                    Padding="14,0"
                    Background="{ThemeResource InputBrush}"
                    BorderBrush="{ThemeResource InputBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
              <TextBlock Text="{Binding ActiveDocumentTab.PageText}"
                         Foreground="{ThemeResource TextPrimaryBrush}"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center" />
            </Border>

            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    Command="{Binding NextPageCommand}"
                    ToolTipService.ToolTip="{Binding Labels.NextPage}"
                    AutomationProperties.Name="{Binding Labels.NextPage}">
              <FontIcon Glyph="&#xE76C;" FontFamily="Segoe Fluent Icons" />
            </Button>

            <Rectangle Width="1" Height="24" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="4,0" />

            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    Click="OnRibbonRotateLeftClick"
                    ToolTipService.ToolTip="{Binding Labels.PageRotateLeft}"
                    AutomationProperties.Name="{Binding Labels.PageRotateLeft}">
              <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" RenderTransformOrigin="0.5,0.5">
                <FontIcon.RenderTransform>
                  <ScaleTransform ScaleX="-1" />
                </FontIcon.RenderTransform>
              </FontIcon>
            </Button>

            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    Click="OnRibbonRotateRightClick"
                    ToolTipService.ToolTip="{Binding Labels.PageRotateRight}"
                    AutomationProperties.Name="{Binding Labels.PageRotateRight}">
              <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" />
            </Button>
          </StackPanel>

          <TextBlock Text="{Binding Labels.RibbonNavigation}"
                     Style="{StaticResource RibbonLabelStyle}" />
        </StackPanel>

        <Rectangle Grid.Column="3" Style="{StaticResource RibbonSeparatorStyle}" />

        <StackPanel Grid.Column="4" Spacing="4" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    Command="{Binding ZoomOutCommand}"
                    ToolTipService.ToolTip="{Binding Labels.ZoomOut}"
                    AutomationProperties.Name="{Binding Labels.ZoomOut}">
              <FontIcon Glyph="&#xE738;" FontFamily="Segoe Fluent Icons" FontSize="16" />
            </Button>

            <Button Height="40"
                    MinWidth="92"
                    Padding="14,0"
                    Background="{ThemeResource InputBrush}"
                    BorderBrush="{ThemeResource InputBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
              <Button.Flyout>
                <MenuFlyout>
                  <MenuFlyoutItem Text="50%" Command="{Binding SetZoomCommand}" CommandParameter="0.5" />
                  <MenuFlyoutItem Text="75%" Command="{Binding SetZoomCommand}" CommandParameter="0.75" />
                  <MenuFlyoutItem Text="100%" Command="{Binding SetZoomCommand}" CommandParameter="1.0" />
                  <MenuFlyoutItem Text="125%" Command="{Binding SetZoomCommand}" CommandParameter="1.25" />
                  <MenuFlyoutItem Text="135%" Command="{Binding SetZoomCommand}" CommandParameter="1.35" />
                  <MenuFlyoutItem Text="150%" Command="{Binding SetZoomCommand}" CommandParameter="1.5" />
                  <MenuFlyoutItem Text="200%" Command="{Binding SetZoomCommand}" CommandParameter="2.0" />
                  <MenuFlyoutItem Text="300%" Command="{Binding SetZoomCommand}" CommandParameter="3.0" />
                  <MenuFlyoutSeparator />
                  <MenuFlyoutItem Text="{Binding Labels.ZoomFit}" Command="{Binding FitPageCommand}" />
                  <MenuFlyoutItem Text="{Binding Labels.ZoomActual}" Command="{Binding ActualSizeCommand}" />
                </MenuFlyout>
              </Button.Flyout>
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{Binding ActiveDocumentTab.ZoomText}" VerticalAlignment="Center" />
                <FontIcon Glyph="&#xE70D;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="10"
                          Foreground="{ThemeResource TextSecondaryBrush}" />
              </StackPanel>
            </Button>

            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    Command="{Binding ZoomInCommand}"
                    ToolTipService.ToolTip="{Binding Labels.ZoomIn}"
                    AutomationProperties.Name="{Binding Labels.ZoomIn}">
              <FontIcon Glyph="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="16" />
            </Button>

            <Button Style="{StaticResource RibbonTextButtonStyle}"
                    Command="{Binding FitPageCommand}"
                    ToolTipService.ToolTip="{Binding Labels.ZoomFit}"
                    AutomationProperties.Name="{Binding Labels.ZoomFit}">
              <StackPanel Spacing="2">
                <FontIcon Glyph="&#xE9A6;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="16"
                          HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Labels.ZoomFit}"
                           FontSize="12"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button Style="{StaticResource RibbonTextButtonStyle}"
                    Command="{Binding ActualSizeCommand}"
                    ToolTipService.ToolTip="{Binding Labels.ZoomActual}"
                    AutomationProperties.Name="{Binding Labels.ZoomActual}">
              <StackPanel Spacing="2">
                <FontIcon Glyph="&#xE740;"
                          FontFamily="Segoe Fluent Icons"
                          FontSize="16"
                          HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Labels.ZoomActual}" FontSize="12" />
              </StackPanel>
            </Button>
          </StackPanel>

          <TextBlock Text="{Binding Labels.RibbonZoom}"
                     Style="{StaticResource RibbonLabelStyle}" />
        </StackPanel>

        <Rectangle Grid.Column="5" Style="{StaticResource RibbonSeparatorStyle}" />

        <Grid Grid.Column="6"
              Margin="24,0"
              VerticalAlignment="Center"
              HorizontalAlignment="Stretch">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Border x:Name="SearchBoxBorder"
                  Grid.Row="0"
                  Height="40"
                  MinWidth="200"
                  MaxWidth="1200"
                  HorizontalAlignment="Stretch"
                  Background="{ThemeResource SearchBrush}"
                  BorderBrush="{ThemeResource InputBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="8">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <FontIcon Glyph="&#xE721;"
                        FontFamily="Segoe Fluent Icons"
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        Margin="12,0,8,0"
                        VerticalAlignment="Center" />

              <TextBox Grid.Column="1"
                       Background="Transparent"
                       BorderThickness="0"
                       VerticalAlignment="Center"
                       VerticalContentAlignment="Center"
                       PlaceholderText="{Binding Labels.SearchPlaceholder}"
                       Text="{Binding ActiveDocumentTab.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       KeyDown="OnSearchBoxKeyDown" />

              <TextBlock Grid.Column="2"
                         Text="Ctrl+F"
                         Foreground="{ThemeResource TextSecondaryBrush}"
                         FontSize="11"
                         Margin="8,0,12,0"
                         VerticalAlignment="Center" />
            </Grid>
          </Border>

          <TextBlock Grid.Row="1"
                     Text="{Binding Labels.Search}"
                     Style="{StaticResource RibbonLabelStyle}" />
        </Grid>

        <Rectangle Grid.Column="7" Style="{StaticResource RibbonSeparatorStyle}" />

        <StackPanel Grid.Column="8" Spacing="6" VerticalAlignment="Center">
          <Border Style="{StaticResource RibbonPillBorderStyle}">
            <StackPanel Orientation="Horizontal" Spacing="0">
              <Button Style="{StaticResource RibbonPillIconButtonStyle}"
                      Command="{Binding TogglePagesPanelCommand}"
                      ToolTipService.ToolTip="{Binding Labels.Pages}"
                      AutomationProperties.Name="{Binding Labels.Pages}">
                <FontIcon Glyph="&#xE8FE;" FontFamily="Segoe Fluent Icons" />
              </Button>

              <Button Style="{StaticResource RibbonPillIconButtonStyle}"
                      Command="{Binding ToggleInfoPanelCommand}"
                      ToolTipService.ToolTip="{Binding Labels.Info}"
                      AutomationProperties.Name="{Binding Labels.Info}">
                <FontIcon Glyph="&#xE946;" FontFamily="Segoe Fluent Icons" />
              </Button>
            </StackPanel>
          </Border>

          <TextBlock Text="{Binding Labels.RibbonDisplay}"
                     Style="{StaticResource RibbonLabelStyle}" />
        </StackPanel>

        <Rectangle Grid.Column="9" Style="{StaticResource RibbonSeparatorStyle}" />

        <StackPanel Grid.Column="10" Spacing="6" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <Border Style="{StaticResource RibbonPillBorderStyle}">
              <StackPanel Orientation="Horizontal" Spacing="0">
                <Button x:Name="AnnotateBtnSelect"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Background="{Binding ActiveDocumentTab.SelectedAnnotationTool, Converter={StaticResource AnnotationToolBackground}, ConverterParameter=Select}"
                        Command="{Binding SelectAnnotationToolCommand}"
                        CommandParameter="Select"
                        ToolTipService.ToolTip="{Binding Labels.Select}"
                        AutomationProperties.Name="{Binding Labels.Select}">
                  <FontIcon Glyph="&#xE8B3;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnHighlight"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Background="{Binding ActiveDocumentTab.SelectedAnnotationTool, Converter={StaticResource AnnotationToolBackground}, ConverterParameter=Highlight}"
                        Command="{Binding SelectAnnotationToolCommand}"
                        CommandParameter="Highlight"
                        ToolTipService.ToolTip="{Binding Labels.Highlight}"
                        AutomationProperties.Name="{Binding Labels.Highlight}">
                  <FontIcon Glyph="&#xE891;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnText"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Background="{Binding ActiveDocumentTab.SelectedAnnotationTool, Converter={StaticResource AnnotationToolBackground}, ConverterParameter=Text}"
                        Command="{Binding SelectAnnotationToolCommand}"
                        CommandParameter="Text"
                        ToolTipService.ToolTip="{Binding Labels.Text}"
                        AutomationProperties.Name="{Binding Labels.Text}">
                  <FontIcon Glyph="&#xE8D2;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnNote"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Background="{Binding ActiveDocumentTab.SelectedAnnotationTool, Converter={StaticResource AnnotationToolBackground}, ConverterParameter=Note}"
                        Command="{Binding SelectAnnotationToolCommand}"
                        CommandParameter="Note"
                        ToolTipService.ToolTip="{Binding Labels.Note}"
                        AutomationProperties.Name="{Binding Labels.Note}">
                  <FontIcon Glyph="&#xE90A;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnStamp"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Visibility="Collapsed"
                        Background="{Binding ActiveDocumentTab.SelectedAnnotationTool, Converter={StaticResource AnnotationToolBackground}, ConverterParameter=Stamp}"
                        Command="{Binding SelectAnnotationToolCommand}"
                        CommandParameter="Stamp"
                        ToolTipService.ToolTip="{Binding Labels.Stamp}"
                        AutomationProperties.Name="{Binding Labels.Stamp}">
                  <FontIcon Glyph="&#xE945;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnInk"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Visibility="Collapsed"
                        Background="{Binding ActiveDocumentTab.SelectedAnnotationTool, Converter={StaticResource AnnotationToolBackground}, ConverterParameter=Ink}"
                        Command="{Binding SelectAnnotationToolCommand}"
                        CommandParameter="Ink"
                        ToolTipService.ToolTip="{Binding Labels.Ink}"
                        AutomationProperties.Name="{Binding Labels.Ink}">
                  <FontIcon Glyph="&#xE70F;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnErase"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Visibility="Collapsed"
                        Command="{Binding SelectAnnotationToolCommand}"
                        CommandParameter="Erase"
                        ToolTipService.ToolTip="{Binding Labels.Erase}"
                        AutomationProperties.Name="{Binding Labels.Erase}">
                  <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" />
                </Button>

                <Button x:Name="AnnotateBtnPanel"
                        Style="{StaticResource RibbonPillIconButtonStyle}"
                        Command="{Binding ToggleAnnotationsPanelCommand}"
                        ToolTipService.ToolTip="{Binding Labels.Annotations}"
                        AutomationProperties.Name="{Binding Labels.Annotations}">
                  <FontIcon Glyph="&#xE924;" FontFamily="Segoe Fluent Icons" />
                </Button>
              </StackPanel>
            </Border>

            <Button Style="{StaticResource RibbonIconButtonStyle}"
                    ToolTipService.ToolTip="{Binding Labels.Settings}"
                    AutomationProperties.Name="{Binding Labels.Settings}">
              <Button.Flyout>
                <MenuFlyout>
                  <MenuFlyoutItem Text="{Binding Labels.Settings}"
                                  Command="{Binding ToggleSettingsPanelCommand}">
                    <MenuFlyoutItem.Icon>
                      <FontIcon Glyph="&#xE713;" FontFamily="Segoe Fluent Icons" />
                    </MenuFlyoutItem.Icon>
                  </MenuFlyoutItem>
                </MenuFlyout>
              </Button.Flyout>
              <FontIcon Glyph="&#xE712;" FontFamily="Segoe Fluent Icons" />
            </Button>
          </StackPanel>

          <TextBlock Text="{Binding Labels.RibbonAnnotateGroup}"
                     Style="{StaticResource RibbonLabelStyle}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="3" Margin="8,0,8,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Width="180"
              Background="{ThemeResource PanelDeepBrush}"
              BorderBrush="{ThemeResource PanelLineBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Visibility="{Binding DataContext.IsPagesPanelVisible, ElementName=Root, Mode=OneWay, FallbackValue=Collapsed, Converter={StaticResource BoolToVisibility}}">
        <Grid Padding="10,12,10,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Grid Margin="4,0,4,8">
            <TextBlock Text="{Binding DataContext.Labels.Pages, ElementName=Root}"
                       Style="{StaticResource PanelTitleStyle}"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal"
                        Spacing="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
              <Button Width="28"
                      Height="28"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      ToolTipService.ToolTip="Page Organizer"
                      Click="OnOpenPageOrganizerClicked">
                <FontIcon Glyph="&#xE8FD;"
                          FontFamily="Segoe Fluent Icons"
                          Foreground="{ThemeResource TextSecondaryBrush}"
                          FontSize="14" />
              </Button>
              <Button Width="28"
                      Height="28"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      ToolTipService.ToolTip="Filter">
                <FontIcon Glyph="&#xE71C;"
                          FontFamily="Segoe Fluent Icons"
                          Foreground="{ThemeResource TextSecondaryBrush}"
                          FontSize="14" />
              </Button>
              <Button Width="28"
                      Height="28"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      Command="{Binding DataContext.TogglePagesPanelCommand, ElementName=Root}"
                      ToolTipService.ToolTip="{Binding DataContext.Labels.CloseTab, ElementName=Root}">
                <FontIcon Glyph="&#xE8BB;"
                          FontFamily="Segoe Fluent Icons"
                          Foreground="{ThemeResource TextSecondaryBrush}"
                          FontSize="14" />
              </Button>
            </StackPanel>
          </Grid>

          <Grid x:Name="ThumbnailDragSurface"
                Grid.Row="1"
                Background="Transparent"
                AllowDrop="True"
                DragOver="OnThumbnailExternalDragOver"
                DragLeave="OnThumbnailExternalDragLeave"
                Drop="OnThumbnailExternalDrop">
            <ScrollViewer x:Name="ThumbnailScrollViewer"
                           VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
              <ItemsControl x:Name="ThumbnailListView"
                            ItemsSource="{Binding DataContext.ActiveDocumentTab.Thumbnails, ElementName=Root, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Padding="0,4"
                          HorizontalAlignment="Stretch"
                          PointerPressed="OnThumbnailItemPointerPressed"
                          PointerMoved="OnThumbnailItemPointerMoved"
                          PointerReleased="OnThumbnailItemPointerReleased"
                          PointerEntered="OnThumbnailPointerEntered"
                          PointerExited="OnThumbnailPointerExited"
                          Tapped="OnThumbnailItemTapped"
                          RightTapped="OnThumbnailItemRightTapped">
                      <Grid.ContextFlyout>
                        <MenuFlyout>
                          <MenuFlyoutItem Text="{Binding DataContext.Labels.PageRotateLeft, ElementName=Root}" Click="OnThumbnailRotateLeftClick">
                            <MenuFlyoutItem.Icon>
                              <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" RenderTransformOrigin="0.5,0.5">
                                <FontIcon.RenderTransform><ScaleTransform ScaleX="-1" /></FontIcon.RenderTransform>
                              </FontIcon>
                            </MenuFlyoutItem.Icon>
                          </MenuFlyoutItem>
                          <MenuFlyoutItem Text="{Binding DataContext.Labels.PageRotateRight, ElementName=Root}" Click="OnThumbnailRotateRightClick">
                            <MenuFlyoutItem.Icon>
                              <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" />
                            </MenuFlyoutItem.Icon>
                          </MenuFlyoutItem>
                          <MenuFlyoutSeparator />
                          <MenuFlyoutItem Text="{Binding DataContext.Labels.PageMoveUp, ElementName=Root}" Click="OnThumbnailMoveUpClick">
                            <MenuFlyoutItem.Icon>
                              <FontIcon Glyph="&#xE74A;" FontFamily="Segoe Fluent Icons" />
                            </MenuFlyoutItem.Icon>
                          </MenuFlyoutItem>
                          <MenuFlyoutItem Text="{Binding DataContext.Labels.PageMoveDown, ElementName=Root}" Click="OnThumbnailMoveDownClick">
                            <MenuFlyoutItem.Icon>
                              <FontIcon Glyph="&#xE74B;" FontFamily="Segoe Fluent Icons" />
                            </MenuFlyoutItem.Icon>
                          </MenuFlyoutItem>
                          <MenuFlyoutSeparator />
                          <MenuFlyoutItem Text="{Binding DataContext.Labels.PageDelete, ElementName=Root}" Click="OnThumbnailDeleteClick">
                            <MenuFlyoutItem.Icon>
                              <FontIcon Glyph="&#xE107;" FontFamily="Segoe Fluent Icons" />
                            </MenuFlyoutItem.Icon>
                          </MenuFlyoutItem>
                        </MenuFlyout>
                      </Grid.ContextFlyout>
                      <Grid.TranslationTransition>
                        <Vector3Transition Duration="0:0:0.2" />
                      </Grid.TranslationTransition>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>

                      <Rectangle Grid.Column="0"
                                 Width="3"
                                 RadiusX="1.5"
                                 RadiusY="1.5"
                                 Fill="{ThemeResource AccentBrush}"
                                 VerticalAlignment="Stretch"
                                 Margin="0,8"
                                 Visibility="{Binding IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                      <Rectangle x:Name="HoverBar"
                                 Grid.Column="0"
                                 Width="3"
                                 RadiusX="1.5"
                                 RadiusY="1.5"
                                 Fill="{ThemeResource AccentBrush}"
                                 VerticalAlignment="Stretch"
                                 Margin="0,8"
                                 Opacity="0" />

                      <StackPanel Grid.Column="1"
                                  Margin="4,0,0,0"
                                  HorizontalAlignment="Center"
                                  Spacing="4">
                        <Grid Width="110" Height="144">
                          <Image Source="{Binding Image, Mode=OneWay}"
                                 Stretch="Uniform"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                          <ProgressRing Width="24"
                                        Height="24"
                                        IsActive="{Binding IsLoading, Mode=OneWay}"
                                        Visibility="{Binding IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                          <TextBlock Text="{Binding PlaceholderText, Mode=OneWay}"
                                     Foreground="{ThemeResource TextSecondaryBrush}"
                                     FontSize="11"
                                     TextAlignment="Center"
                                     TextWrapping="Wrap"
                                     MaxWidth="100"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Visibility="{Binding HasPlaceholder, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                        <TextBlock Text="{Binding PageNumber}"
                                   Foreground="{ThemeResource TextPrimaryBrush}"
                                   FontSize="11"
                                   HorizontalAlignment="Center" />
                      </StackPanel>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <!-- Drag ghost overlay -->
            <Image x:Name="ThumbnailDragGhost"
                   Width="80"
                   Height="104"
                   Stretch="Uniform"
                   Opacity="0.8"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Visibility="Collapsed" />

            <!-- Drop indicator line -->
            <Rectangle x:Name="ThumbnailDropIndicator"
                       Height="3"
                       RadiusX="1.5"
                       RadiusY="1.5"
                       Fill="{ThemeResource AccentBrush}"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Top"
                       IsHitTestVisible="False"
                       Margin="8,0"
                       Visibility="Collapsed" />
          </Grid>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Width="8"
              Visibility="{Binding DataContext.IsPagesPanelVisible, ElementName=Root, Mode=OneWay, FallbackValue=Collapsed, Converter={StaticResource BoolToVisibility}}" />

      <Border Grid.Column="2"
              Background="{ThemeResource ViewerBackgroundBrush}"
              BorderBrush="{ThemeResource PanelLineBrush}"
              BorderThickness="1"
              CornerRadius="8">
        <Grid>
          <ScrollViewer HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        ZoomMode="Enabled">
            <Grid MinHeight="840"
                  Padding="40,16,40,24"
                  DataContext="{Binding ActiveDocumentTab, Mode=OneWay}">
              <Grid HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      Width="{Binding CommentLaneWidth, Mode=OneWay}"
                      Height="{Binding CurrentPagePixelHeight, Mode=OneWay}"
                      Visibility="{Binding HasCurrentPageComments, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                  <ItemsControl ItemsSource="{Binding CurrentPageCommentOverlays, Mode=OneWay}"
                                Width="280"
                                Height="{Binding CurrentPagePixelHeight, Mode=OneWay}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Width="{Binding LaneWidth}"
                              MinHeight="78"
                              Margin="{Binding Margin}">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                          </Grid.ColumnDefinitions>

                          <Border Background="{ThemeResource CardBrush}"
                                  BorderBrush="{ThemeResource CardBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="12,10"
                                  DoubleTapped="OnCommentCardDoubleTapped">
                            <StackPanel Spacing="6">
                              <Grid>
                                <TextBlock Text="{Binding PageLabel}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11" />
                                <TextBlock Text="{Binding TimeText}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11"
                                           HorizontalAlignment="Right" />
                              </Grid>
                              <TextBlock Text="{Binding Text}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         FontSize="13"
                                         TextWrapping="Wrap"
                                         MaxLines="4"
                                         Visibility="{Binding ReadVisibility}" />
                              <TextBox Text="{Binding EditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       AcceptsReturn="True"
                                       MinHeight="40"
                                       Padding="6,4"
                                       Background="Transparent"
                                       BorderThickness="0"
                                       Visibility="{Binding EditVisibility}"
                                       LostFocus="OnCommentEditLostFocus"
                                       KeyDown="OnCommentEditKeyDown" />
                            </StackPanel>
                          </Border>

                          <Grid Grid.Column="1"
                                Height="28"
                                Margin="0,18,0,0"
                                VerticalAlignment="Top">
                            <Rectangle Height="1"
                                       Fill="{Binding StrokeBrush}"
                                       VerticalAlignment="Center" />
                            <Ellipse Width="8"
                                     Height="8"
                                     Fill="{Binding StrokeBrush}"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center" />
                          </Grid>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>

                <Border Grid.Column="1"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Background="{ThemeResource PaperBrush}"
                      BorderBrush="{ThemeResource PaperBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="2">
                <Grid x:Name="DocumentPageLayer"
                      Width="{Binding CurrentPagePixelWidth, Mode=OneWay}"
                      Height="{Binding CurrentPagePixelHeight, Mode=OneWay}"
                      Background="Transparent"
                      PointerPressed="OnDocumentLayerPointerPressed"
                      PointerMoved="OnDocumentLayerPointerMoved"
                      PointerReleased="OnDocumentLayerPointerReleased"
                      PointerCanceled="OnDocumentLayerPointerCanceled">
                  <Image Source="{Binding CurrentPageImage, Mode=OneWay}"
                         Width="{Binding CurrentPagePixelWidth, Mode=OneWay}"
                         Height="{Binding CurrentPagePixelHeight, Mode=OneWay}"
                         Stretch="None"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Top" />

                  <ItemsControl ItemsSource="{Binding CurrentPageAnnotationOverlays, Mode=OneWay}"
                                Width="{Binding CurrentPagePixelWidth, Mode=OneWay}"
                                Height="{Binding CurrentPagePixelHeight, Mode=OneWay}"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Width="{Binding Width}"
                              Height="{Binding Height}"
                              Margin="{Binding Margin}"
                              Opacity="{Binding Opacity}"
                              Visibility="{Binding IsHidden, Converter={StaticResource InverseBoolToVisibility}}">
                          <Border Background="{Binding FillBrush}"
                                  BorderBrush="{Binding StrokeBrush}"
                                  BorderThickness="{Binding BorderThickness}"
                                  CornerRadius="{Binding CornerRadius}"
                                  Visibility="{Binding BoxVisibility}" />
                          <Polyline Points="{Binding InkPoints}"
                                    Stroke="{Binding StrokeBrush}"
                                    StrokeThickness="{Binding StrokeThickness}"
                                    Visibility="{Binding InkVisibility}" />
                          <Image Source="{Binding SignatureImageSource}"
                                 Margin="8"
                                 Stretch="Uniform"
                                 Visibility="{Binding SignatureImageVisibility}" />
                          <StackPanel Orientation="Horizontal"
                                      Padding="8,3"
                                      Spacing="6"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding TextVisibility}">
                            <FontIcon Glyph="{Binding Glyph}"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{Binding TextBrush}"
                                      FontSize="13"
                                      Visibility="{Binding GlyphVisibility}" />
                            <TextBlock Text="{Binding Text}"
                                       Foreground="{Binding TextBrush}"
                                       FontSize="{Binding TextFontSize}"
                                       FontFamily="{Binding TextFontFamily}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                          </StackPanel>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <Grid Width="{Binding InlineTextEditor.Width, Mode=OneWay, FallbackValue=180}"
                        Height="{Binding InlineTextEditor.Height, Mode=OneWay, FallbackValue=72}"
                        Margin="{Binding InlineTextEditor.Margin, Mode=OneWay}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Visibility="{Binding HasInlineTextEditor, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <TextBox x:Name="InlineTextEditorBox"
                             Padding="4,2"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{Binding InlineTextEditor.StrokeBrush, Mode=OneWay}"
                             FontSize="{Binding InlineTextEditor.FontSize, Mode=OneWay, FallbackValue=14}"
                             FontFamily="{Binding InlineTextEditor.FontFamily, Mode=OneWay, FallbackValue='Segoe UI'}"
                             Text="{Binding InlineTextEditor.Text, Mode=OneWay}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             TextChanged="OnInlineTextEditorTextChanged"
                             LostFocus="OnInlineTextEditorLostFocus"
                             KeyDown="OnInlineTextEditorKeyDown" />
                  </Grid>

                  <ItemsControl ItemsSource="{Binding SearchHighlights, Mode=OneWay}"
                                Width="{Binding CurrentPagePixelWidth, Mode=OneWay}"
                                Height="{Binding CurrentPagePixelHeight, Mode=OneWay}"
                                Visibility="{Binding HasSearchHighlights, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Width="{Binding Width}"
                                Height="{Binding Height}"
                                Margin="{Binding Margin}"
                                Background="#FFE600"
                                Opacity="0.34" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                  <ItemsControl ItemsSource="{Binding TextSelectionHighlights, Mode=OneWay}"
                                Width="{Binding CurrentPagePixelWidth, Mode=OneWay}"
                                Height="{Binding CurrentPagePixelHeight, Mode=OneWay}"
                                Visibility="{Binding HasTextSelectionHighlights, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                IsHitTestVisible="False"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Width="{Binding Width}"
                                Height="{Binding Height}"
                                Margin="{Binding Margin}"
                                Background="{ThemeResource AccentBrush}"
                                Opacity="0.28" />
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Grid>
              </Border>
              </Grid>
            </Grid>
          </ScrollViewer>
        </Grid>
      </Border>

      <Grid Grid.Column="3" HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="8,0,0,0"
            Visibility="{Binding ActiveDocumentTab.IsAnnotationsPanelOpen, Converter={StaticResource BoolToVisibility}}">
        <Border Width="420"
                VerticalAlignment="Stretch"
                Background="{ThemeResource PanelDeepBrush}"
                BorderBrush="{ThemeResource PanelLineBrush}"
                BorderThickness="1"
                CornerRadius="8">
          <Grid Padding="20,20,20,12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
              <StackPanel Spacing="6">
                <TextBlock Text="{Binding Labels.Annotations}"
                           Foreground="{ThemeResource TextPrimaryBrush}"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Labels.AnnotationDescriptionShort}"
                           Foreground="{ThemeResource TextSecondaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Width="28"
                      Height="28"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Command="{Binding ToggleAnnotationsPanelCommand}"
                      ToolTipService.ToolTip="{Binding Labels.Close}">
                <FontIcon Glyph="&#xE8BB;"
                          FontFamily="Segoe Fluent Icons"
                          Foreground="{ThemeResource TextSecondaryBrush}"
                          FontSize="12" />
              </Button>
            </Grid>

            <Border Grid.Row="1"
                    Height="38"
                    Margin="0,14,0,14"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
              <Grid Margin="3">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{ThemeResource ActiveToolBgBrush}"
                        CornerRadius="8"
                        Visibility="{Binding IsAnnotationToolsTabSelected, Converter={StaticResource BoolToVisibility}}">
                  <Rectangle Height="2"
                             Width="40"
                             RadiusX="1"
                             RadiusY="1"
                             Fill="{ThemeResource AccentBrush}"
                             VerticalAlignment="Bottom"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,2" />
                </Border>
                <Button Grid.Column="0"
                        Height="32"
                        MinWidth="0"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding SelectAnnotationPanelTabCommand}"
                        CommandParameter="Tools"
                        AutomationProperties.Name="{Binding Labels.AnnotationToolsTab}">
                  <TextBlock Text="{Binding Labels.AnnotationToolsTab}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontSize="13"
                             FontWeight="SemiBold" />
                </Button>

                <Border Grid.Column="1"
                        Background="{ThemeResource ActiveToolBgBrush}"
                        CornerRadius="8"
                        Visibility="{Binding IsAnnotationCommentsTabSelected, Converter={StaticResource BoolToVisibility}}">
                  <Rectangle Height="2"
                             Width="40"
                             RadiusX="1"
                             RadiusY="1"
                             Fill="{ThemeResource AccentBrush}"
                             VerticalAlignment="Bottom"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,2" />
                </Border>
                <Button Grid.Column="1"
                        Height="32"
                        MinWidth="0"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="8"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding SelectAnnotationPanelTabCommand}"
                        CommandParameter="Comments"
                        AutomationProperties.Name="{Binding Labels.AnnotationCommentsTab}">
                  <TextBlock Text="{Binding Labels.AnnotationCommentsTab}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontSize="13"
                             FontWeight="SemiBold" />
                </Button>
              </Grid>
            </Border>

            <Grid Grid.Row="2"
                  RowSpacing="8"
                  HorizontalAlignment="Stretch"
                  Visibility="{Binding IsAnnotationToolsTabSelected, Converter={StaticResource BoolToVisibility}}">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <TextBlock Text="{Binding Labels.AnnotationActiveTool}"
                         Foreground="{ThemeResource PanelLabelBrush}"
                         FontSize="13" />
              <Button Grid.Row="1"
                      Height="42"
                      Background="{ThemeResource CardBrush}"
                      BorderBrush="{ThemeResource CardBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="14,0"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      ToolTipService.ToolTip="{Binding ActiveAnnotationToolLabel}"
                      AutomationProperties.Name="{Binding ActiveAnnotationToolLabel}">
                <Button.Flyout>
                  <MenuFlyout>
                    <MenuFlyoutItem Text="{Binding Labels.Select}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Select" />
                    <MenuFlyoutItem Text="{Binding Labels.Highlight}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Highlight" />
                    <MenuFlyoutItem Text="{Binding Labels.Ink}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Ink" />
                    <MenuFlyoutItem Text="{Binding Labels.Text}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Text" />
                    <MenuFlyoutItem Text="{Binding Labels.Note}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Note" />
                    <MenuFlyoutItem Text="{Binding Labels.Rectangle}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Rectangle" />
                    <MenuFlyoutItem Text="{Binding Labels.Signature}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Signature" />
                    <MenuFlyoutItem Text="{Binding Labels.Stamp}" Command="{Binding SelectAnnotationToolCommand}" CommandParameter="Stamp" />
                  </MenuFlyout>
                </Button.Flyout>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <Border Width="22"
                          Height="22"
                          Background="{Binding SelectedAnnotationColorBrush}"
                          CornerRadius="8"
                          VerticalAlignment="Center" />

                  <TextBlock Grid.Column="1"
                             Text="{Binding ActiveAnnotationToolLabel}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontSize="14"
                             Margin="12,0,0,0"
                             VerticalAlignment="Center" />

                  <FontIcon Grid.Column="2"
                            Glyph="&#xE70D;"
                            FontFamily="Segoe Fluent Icons"
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            FontSize="11"
                            VerticalAlignment="Center" />
                </Grid>
              </Button>
            </Grid>

            <StackPanel Grid.Row="3"
                        Margin="0,12,0,0"
                        Spacing="10"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding IsAnnotationToolsTabSelected, Converter={StaticResource BoolToVisibility}}">
              <TextBlock Text="{Binding Labels.AnnotationQuickTools}"
                         Foreground="{ThemeResource PanelLabelBrush}"
                         FontSize="13" />
              <ItemsControl ItemsSource="{Binding AnnotationTools}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"
                                   MaximumRowsOrColumns="4"
                                   ItemWidth="90"
                                   ItemHeight="68" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Width="82"
                            Height="58"
                            Margin="0"
                            CornerRadius="8"
                            Background="{Binding IsSelected, Converter={StaticResource BoolToSelectedToolBackground}}"
                            BorderBrush="{ThemeResource ButtonBorderBrush}"
                            BorderThickness="1"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsEnabled="{Binding IsEnabled}"
                            ToolTipService.ToolTip="{Binding Label}"
                            AutomationProperties.Name="{Binding Label}"
                            Click="OnAnnotationToolClicked">
                      <FontIcon Glyph="{Binding Glyph}"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="21" />
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <StackPanel Spacing="6"
                          Visibility="{Binding ShowAnnotationTextEditor, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding Labels.AnnotationText}"
                           Foreground="{ThemeResource PanelLabelBrush}"
                           FontSize="13" />
                <TextBox MinHeight="78"
                         Padding="10,8"
                         Background="{ThemeResource InputBrush}"
                         BorderBrush="{ThemeResource InputBorderBrush}"
                         BorderThickness="1"
                         CornerRadius="8"
                         Foreground="{ThemeResource TextPrimaryBrush}"
                         PlaceholderText="{Binding Labels.AnnotationTextPlaceholder}"
                         Text="{Binding AnnotationTextDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True" />
              </StackPanel>

              <StackPanel Spacing="10"
                          Visibility="{Binding ShowTextStyleControls, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Font"
                           Foreground="{ThemeResource PanelLabelBrush}"
                           FontSize="13" />
                <ComboBox ItemsSource="{Binding AnnotationFontFamilyOptions}"
                          SelectedItem="{Binding AnnotationFontFamily, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"
                          Background="{ThemeResource InputBrush}"
                          BorderBrush="{ThemeResource InputBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="8" />
                <Grid ColumnSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Size"
                             Foreground="{ThemeResource PanelLabelBrush}"
                             FontSize="13"
                             VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            Width="90"
                            ItemsSource="{Binding AnnotationFontSizeOptions}"
                            SelectedItem="{Binding AnnotationFontSize, Mode=TwoWay}"
                            Background="{ThemeResource InputBrush}"
                            BorderBrush="{ThemeResource InputBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8" />
                </Grid>
              </StackPanel>

              <StackPanel Spacing="10"
                          Visibility="{Binding ShowSignatureControls, Converter={StaticResource BoolToVisibility}}">
                <Grid ColumnSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding Labels.SignatureLibrary}"
                             Foreground="{ThemeResource PanelLabelBrush}"
                             FontSize="13"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="1"
                          Height="32"
                          MinWidth="0"
                          Padding="10,0"
                          CornerRadius="8"
                          Background="{ThemeResource CardBrush}"
                          BorderBrush="{ThemeResource CardBorderBrush}"
                          BorderThickness="1"
                          Command="{Binding ImportSignatureAssetCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <FontIcon Glyph="&#xE8E5;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="13" />
                      <TextBlock Text="{Binding Labels.SignatureImportImage}"
                                 FontSize="12" />
                    </StackPanel>
                  </Button>
                  <Button Grid.Column="2"
                          Width="32"
                          Height="32"
                          Padding="0"
                          CornerRadius="8"
                          Background="Transparent"
                          BorderBrush="{ThemeResource CardBorderBrush}"
                          BorderThickness="1"
                          Command="{Binding DeleteSelectedSignatureAssetCommand}"
                          CommandParameter="{Binding SelectedSignatureAssetId}"
                          ToolTipService.ToolTip="{Binding Labels.SignatureDeleteSelected}"
                          AutomationProperties.Name="{Binding Labels.SignatureDeleteSelected}">
                    <FontIcon Glyph="&#xE74D;"
                              FontFamily="Segoe Fluent Icons"
                              FontSize="13" />
                  </Button>
                </Grid>

                <ScrollViewer MaxHeight="132"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasSignatureAssets, Converter={StaticResource BoolToVisibility}}">
                  <ItemsControl ItemsSource="{Binding SignatureAssets}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{ThemeResource CardBrush}"
                                BorderBrush="{ThemeResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,0,0,6">
                          <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding DataContext.SelectSignatureAssetCommand, ElementName=Root}"
                                    CommandParameter="{Binding Id}">
                              <StackPanel Spacing="2">
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="{ThemeResource TextPrimaryBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding FilePath}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis" />
                              </StackPanel>
                            </Button>
                            <Button Grid.Column="1"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding DataContext.DeleteSelectedSignatureAssetCommand, ElementName=Root}"
                                    CommandParameter="{Binding Id}"
                                    ToolTipService.ToolTip="{Binding DataContext.Labels.SignatureDeleteSelected, ElementName=Root}"
                                    AutomationProperties.Name="{Binding DataContext.Labels.SignatureDeleteSelected, ElementName=Root}">
                              <FontIcon Glyph="&#xE74D;"
                                        FontFamily="Segoe Fluent Icons"
                                        Foreground="{ThemeResource TextSecondaryBrush}"
                                        FontSize="13" />
                            </Button>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>

                <TextBlock Text="{Binding Labels.SignatureDraw}"
                           Foreground="{ThemeResource PanelLabelBrush}"
                           FontSize="13" />
                <TextBox Height="36"
                         Padding="10,0"
                         Background="{ThemeResource InputBrush}"
                         BorderBrush="{ThemeResource InputBorderBrush}"
                         BorderThickness="1"
                         CornerRadius="8"
                         Foreground="{ThemeResource TextPrimaryBrush}"
                         PlaceholderText="{Binding Labels.SignatureNamePlaceholder}"
                         Text="{Binding SignatureAssetNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <Border Height="146"
                        Background="{ThemeResource CardBrush}"
                        BorderBrush="{ThemeResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10">
                  <Grid HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Rectangle Width="248"
                               Height="124"
                               Fill="#FFFDFDFD"
                               RadiusX="4"
                               RadiusY="4" />
                    <Polyline Points="{Binding SignaturePadPoints}"
                              Stroke="#111827"
                              StrokeThickness="2.2"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    <Border x:Name="SignaturePadInteractionLayer"
                            Width="248"
                            Height="124"
                            Background="Transparent"
                            PointerPressed="OnSignaturePadPointerPressed"
                            PointerMoved="OnSignaturePadPointerMoved"
                            PointerReleased="OnSignaturePadPointerReleased"
                            PointerCanceled="OnSignaturePadPointerCanceled" />
                  </Grid>
                </Border>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                  <Button Height="32"
                          MinWidth="0"
                          Padding="10,0"
                          CornerRadius="8"
                          Background="{ThemeResource CardBrush}"
                          BorderBrush="{ThemeResource CardBorderBrush}"
                          BorderThickness="1"
                          Command="{Binding ClearSignatureCaptureCommand}"
                          Content="{Binding Labels.SignatureClearDrawing}" />
                  <Button Height="32"
                          MinWidth="0"
                          Padding="10,0"
                          CornerRadius="8"
                          Background="{ThemeResource AccentBgBrush}"
                          BorderBrush="{ThemeResource AccentBrush}"
                          BorderThickness="1"
                          Command="{Binding SaveDrawnSignatureAssetCommand}"
                          Content="{Binding Labels.SignatureSave}" />
                </StackPanel>
              </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="4"
                        Margin="0,2,0,0"
                        Spacing="8"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding IsAnnotationToolsAppearancePanelVisible, Converter={StaticResource BoolToVisibility}}">
              <TextBlock Text="{Binding Labels.AnnotationColor}"
                         Foreground="{ThemeResource PanelLabelBrush}"
                         FontSize="13" />
              <ItemsControl ItemsSource="{Binding AnnotationColorOptions}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Width="30"
                            Height="30"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTipService.ToolTip="{Binding Hex}"
                            AutomationProperties.Name="{Binding Hex}"
                            Click="OnAnnotationColorClicked">
                      <Grid>
                        <Ellipse Width="24"
                                 Height="24"
                                 Fill="{Binding Brush}" />
                        <Ellipse Width="30"
                                 Height="30"
                                 Stroke="{ThemeResource AccentBrush}"
                                 StrokeThickness="3"
                                 Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}" />
                        <Ellipse Width="20"
                                 Height="20"
                                 Stroke="{ThemeResource TextPrimaryBrush}"
                                 StrokeThickness="1"
                                 Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}" />
                      </Grid>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Margin="0,10,0,0"
                        Spacing="8"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding ShowRectangleFillControls, Converter={StaticResource BoolToVisibility}}">
              <CheckBox Content="{Binding Labels.AnnotationFill}"
                        IsChecked="{Binding AnnotationFillEnabled, Mode=TwoWay}" />
              <StackPanel Spacing="6"
                          Visibility="{Binding AnnotationFillEnabled, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding Labels.AnnotationFillColor}"
                           Foreground="{ThemeResource PanelLabelBrush}"
                           FontSize="13" />
                <ItemsControl ItemsSource="{Binding AnnotationFillColorOptions}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Width="28"
                              Height="28"
                              Padding="0"
                              Background="Transparent"
                              BorderThickness="0"
                              ToolTipService.ToolTip="{Binding Hex}"
                              Click="OnAnnotationFillColorClicked">
                        <Grid>
                          <Ellipse Width="22"
                                   Height="22"
                                   Fill="{Binding Brush}" />
                          <Ellipse Width="28"
                                   Height="28"
                                   Stroke="{ThemeResource AccentBrush}"
                                   StrokeThickness="3"
                                   Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="5"
                        Margin="0,10,0,0"
                        Spacing="6"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding IsAnnotationToolsAppearancePanelVisible, Converter={StaticResource BoolToVisibility}}">
              <Grid>
                <TextBlock Text="{Binding Labels.AnnotationOpacity}"
                           Foreground="{ThemeResource PanelLabelBrush}"
                           FontSize="13" />
                <TextBlock Text="{Binding AnnotationOpacityText}"
                           Foreground="{ThemeResource TextPrimaryBrush}"
                           FontSize="12"
                           HorizontalAlignment="Right" />
              </Grid>
              <Slider Minimum="0"
                      Maximum="100"
                      Value="{Binding AnnotationOpacity, Mode=TwoWay}" />
            </StackPanel>

            <Border Grid.Row="6"
                    Margin="0,14,0,0"
                    HorizontalAlignment="Stretch"
                    BorderBrush="{ThemeResource AnnotationSeparatorBrush}"
                    BorderThickness="0"
                    Visibility="{Binding IsAnnotationToolsTabSelected, Converter={StaticResource BoolToVisibility}}">
              <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                  <TextBlock Text="{Binding Labels.AnnotationCurrent}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontSize="15" />
                  <Border HorizontalAlignment="Right"
                          Padding="10,4"
                          Background="{ThemeResource CardBrush}"
                          BorderBrush="{ThemeResource CardBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding Labels.AnnotationRecent}"
                                 Foreground="{ThemeResource TextPrimaryBrush}"
                                 FontSize="12" />
                      <FontIcon Glyph="&#xE70D;"
                                FontFamily="Segoe Fluent Icons"
                                Foreground="{ThemeResource TextSecondaryBrush}"
                                FontSize="10"
                                VerticalAlignment="Center" />
                    </StackPanel>
                  </Border>
                </Grid>

                <Grid Grid.Row="1">
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled"
                                Visibility="{Binding ActiveDocumentTab.HasCurrentPageAnnotations, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl ItemsSource="{Binding ActiveDocumentTab.CurrentPageAnnotationOverlays}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="{ThemeResource CardBrush}"
                                  BorderBrush="{ThemeResource CardBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="12,10"
                                  Margin="0,0,0,8"
                                  Opacity="{Binding ListItemOpacity}">
                            <Grid ColumnSpacing="12">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>

                              <Grid Grid.Column="0"
                                    VerticalAlignment="Top"
                                    Margin="0,2,0,0">
                                <FontIcon Glyph="{Binding Glyph}"
                                          FontFamily="Segoe Fluent Icons"
                                          Foreground="{Binding StrokeBrush}"
                                          FontSize="18" />
                                <FontIcon Glyph="&#xE72E;"
                                          FontFamily="Segoe Fluent Icons"
                                          Foreground="{ThemeResource TextSecondaryBrush}"
                                          FontSize="10"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Bottom"
                                          Margin="0,0,-4,-4"
                                          Visibility="{Binding LockIconVisibility}" />
                                <FontIcon Glyph="&#xED1A;"
                                          FontFamily="Segoe Fluent Icons"
                                          Foreground="{ThemeResource TextSecondaryBrush}"
                                          FontSize="10"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Bottom"
                                          Margin="-4,0,0,-4"
                                          Visibility="{Binding HiddenIconVisibility}" />
                              </Grid>

                              <StackPanel Grid.Column="1" Spacing="1">
                                <TextBlock Text="{Binding Label}"
                                           Foreground="{ThemeResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding PageLabel}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11" />
                                <TextBlock Text="{Binding PreviewText}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding HasPreviewText, Converter={StaticResource BoolToVisibility}}" />
                              </StackPanel>

                              <StackPanel Grid.Column="2"
                                          Orientation="Horizontal"
                                          Spacing="6"
                                          VerticalAlignment="Top"
                                          Margin="0,2,0,0">
                                <TextBlock Text="{Binding TimeText}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                                <Button Width="28"
                                        Height="28"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0">
                                  <FontIcon Glyph="&#xE712;"
                                            FontFamily="Segoe Fluent Icons"
                                            Foreground="{ThemeResource TextSecondaryBrush}"
                                            FontSize="13" />
                                  <Button.Flyout>
                                    <MenuFlyout>
                                      <MenuFlyoutItem Text="{Binding DataContext.Labels.AnnotationMenuEdit, ElementName=Root}"
                                                      Click="OnAnnotationMenuEditClicked">
                                        <MenuFlyoutItem.Icon>
                                          <FontIcon Glyph="&#xE70F;" FontFamily="Segoe Fluent Icons" />
                                        </MenuFlyoutItem.Icon>
                                      </MenuFlyoutItem>
                                      <MenuFlyoutItem Text="{Binding HideMenuText}"
                                                      Click="OnAnnotationMenuHideClicked">
                                        <MenuFlyoutItem.Icon>
                                          <FontIcon Glyph="&#xED1A;" FontFamily="Segoe Fluent Icons" />
                                        </MenuFlyoutItem.Icon>
                                      </MenuFlyoutItem>
                                      <MenuFlyoutItem Text="{Binding LockMenuText}"
                                                      Click="OnAnnotationMenuLockClicked">
                                        <MenuFlyoutItem.Icon>
                                          <FontIcon Glyph="&#xE72E;" FontFamily="Segoe Fluent Icons" />
                                        </MenuFlyoutItem.Icon>
                                      </MenuFlyoutItem>
                                      <MenuFlyoutSeparator />
                                      <MenuFlyoutItem Text="{Binding DataContext.Labels.AnnotationMenuDelete, ElementName=Root}"
                                                      Click="OnAnnotationMenuDeleteClicked">
                                        <MenuFlyoutItem.Icon>
                                          <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" />
                                        </MenuFlyoutItem.Icon>
                                      </MenuFlyoutItem>
                                    </MenuFlyout>
                                  </Button.Flyout>
                                </Button>
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <StackPanel VerticalAlignment="Top"
                              HorizontalAlignment="Center"
                              Spacing="10"
                              Margin="0,96,0,0"
                              Visibility="{Binding ActiveDocumentTab.HasCurrentPageAnnotations, Converter={StaticResource InverseBoolToVisibility}}">
                    <FontIcon Glyph="&#xE90A;"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="{ThemeResource EmptyStateIconBrush}"
                              FontSize="38"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding Labels.AnnotationEmptyPage}"
                               Foreground="{ThemeResource TextPrimaryBrush}"
                               FontSize="12"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding Labels.AnnotationEmptyHint}"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="12"
                               Width="260" />
                  </StackPanel>
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="6"
                    Margin="0,14,0,0"
                    HorizontalAlignment="Stretch"
                    BorderBrush="{ThemeResource AnnotationSeparatorBrush}"
                    BorderThickness="0"
                    Visibility="{Binding IsAnnotationCommentsTabSelected, Converter={StaticResource BoolToVisibility}}">
              <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                  <TextBlock Text="{Binding Labels.AnnotationCommentsCurrent}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontSize="15" />
                  <Border HorizontalAlignment="Right"
                          Padding="10,4"
                          Background="{ThemeResource CardBrush}"
                          BorderBrush="{ThemeResource CardBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6">
                    <TextBlock Text="{Binding ActiveDocumentTab.CurrentPageCommentCountText}"
                               Foreground="{ThemeResource TextPrimaryBrush}"
                               FontSize="12" />
                  </Border>
                </Grid>

                <Grid Grid.Row="1">
                  <ScrollViewer VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled"
                                Visibility="{Binding ActiveDocumentTab.HasCurrentPageComments, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl ItemsSource="{Binding ActiveDocumentTab.CurrentPageCommentOverlays}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="{ThemeResource CardBrush}"
                                  BorderBrush="{ThemeResource CardBorderBrush}"
                                  BorderThickness="1"
                                  CornerRadius="6"
                                  Padding="12,10"
                                  Margin="0,0,0,8">
                            <Grid ColumnSpacing="12">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>

                              <FontIcon Grid.Column="0"
                                        Glyph="&#xE90A;"
                                        FontFamily="Segoe Fluent Icons"
                                        Foreground="{Binding StrokeBrush}"
                                        FontSize="18"
                                        VerticalAlignment="Top"
                                        Margin="0,2,0,0" />

                              <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Binding Text}"
                                           Foreground="{ThemeResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           MaxLines="3" />
                                <TextBlock Text="{Binding PageLabel}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11" />
                              </StackPanel>

                              <StackPanel Grid.Column="2"
                                          Orientation="Horizontal"
                                          Spacing="6"
                                          VerticalAlignment="Top"
                                          Margin="0,2,0,0">
                                <TextBlock Text="{Binding TimeText}"
                                           Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                                <Button Width="28"
                                        Height="28"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTipService.ToolTip="{Binding DataContext.Labels.AnnotationDeleteSelected, ElementName=Root}"
                                        AutomationProperties.Name="{Binding DataContext.Labels.AnnotationDeleteSelected, ElementName=Root}"
                                        Tapped="OnDeleteAnnotationTapped">
                                  <FontIcon Glyph="&#xE712;"
                                            FontFamily="Segoe Fluent Icons"
                                            Foreground="{ThemeResource TextSecondaryBrush}"
                                            FontSize="13" />
                                </Button>
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <StackPanel VerticalAlignment="Top"
                              HorizontalAlignment="Center"
                              Spacing="10"
                              Margin="0,96,0,0"
                              Visibility="{Binding ActiveDocumentTab.HasCurrentPageComments, Converter={StaticResource InverseBoolToVisibility}}">
                    <FontIcon Glyph="&#xE90A;"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="{ThemeResource EmptyStateIconBrush}"
                              FontSize="38"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding Labels.AnnotationCommentsEmptyPage}"
                               Foreground="{ThemeResource TextPrimaryBrush}"
                               FontSize="12"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding Labels.AnnotationCommentsEmptyHint}"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="12"
                               Width="260" />
                  </StackPanel>
                </Grid>
              </Grid>
            </Border>

            <Button Grid.Row="7"
                    HorizontalAlignment="Right"
                    Width="40"
                    Height="36"
                    Margin="0,8,0,0"
                    Padding="0"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Command="{Binding ToggleAnnotationsPanelCommand}"
                    ToolTipService.ToolTip="{Binding Labels.Annotations}"
                    AutomationProperties.Name="{Binding Labels.Annotations}">
              <TextBlock Text="&#x00AB;"
                         Foreground="{ThemeResource TextPrimaryBrush}"
                         FontSize="22" />
            </Button>
          </Grid>
        </Border>

        <Border Width="356"
                Background="{ThemeResource PanelDeepBrush}"
                BorderBrush="{ThemeResource PanelLineBrush}"
                BorderThickness="1,0,0,0"
                CornerRadius="0"
                Visibility="{Binding ActiveDocumentTab.IsSettingsPanelOpen, Converter={StaticResource BoolToVisibility}}">
          <StackPanel Padding="18,14" Spacing="16">
            <StackPanel Spacing="5">
              <TextBlock Text="{Binding Labels.Settings}" Style="{StaticResource PanelTitleStyle}" />
              <TextBlock Text="{Binding Labels.PreferencesDescription}"
                         Foreground="{ThemeResource TextSecondaryBrush}"
                         FontSize="12"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Border Background="{ThemeResource CardBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
              <StackPanel Spacing="14">
                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding Labels.PreferencesLanguage}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding PreferenceLanguageOptions}"
                            SelectedItem="{Binding SelectedPreferenceLanguage, Mode=TwoWay}" />
                </Grid>

                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding Labels.PreferencesTheme}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding PreferenceThemeOptions}"
                            SelectedItem="{Binding SelectedPreferenceTheme, Mode=TwoWay}" />
                </Grid>

                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding Labels.PreferencesDefaultZoom}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding PreferenceZoomOptions}"
                            SelectedItem="{Binding SelectedPreferenceZoom, Mode=TwoWay}" />
                </Grid>

                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="{Binding Labels.PreferencesShowThumbnails}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap" />
                  <ToggleSwitch Grid.Column="1"
                                IsOn="{Binding ShowThumbnails, Mode=TwoWay}"
                                OnContent=""
                                OffContent="" />
                </Grid>

                <StackPanel Spacing="6">
                  <Grid>
                    <TextBlock Text="{Binding Labels.PreferencesCacheSize}"
                               Foreground="{ThemeResource TextPrimaryBrush}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CacheSizeText}"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               HorizontalAlignment="Right" />
                  </Grid>
                  <Slider Minimum="64"
                          Maximum="1024"
                          Value="{Binding CacheSizeMegabytes, Mode=TwoWay}" />
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Width="420"
                VerticalAlignment="Stretch"
                Background="{ThemeResource PanelDeepBrush}"
                BorderBrush="{ThemeResource PanelLineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding ActiveDocumentTab.IsInfoPanelOpen, Converter={StaticResource BoolToVisibility}}">
          <Grid Padding="20,20,20,12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
              <StackPanel Spacing="6">
                <TextBlock Text="{Binding Labels.Info}"
                           Foreground="{ThemeResource TextPrimaryBrush}"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Labels.InfoDescription}"
                           Foreground="{ThemeResource TextSecondaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Width="28"
                      Height="28"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Command="{Binding ToggleInfoPanelCommand}"
                      ToolTipService.ToolTip="{Binding Labels.Close}">
                <FontIcon Glyph="&#xE8BB;"
                          FontFamily="Segoe Fluent Icons"
                          Foreground="{ThemeResource TextSecondaryBrush}"
                          FontSize="12" />
              </Button>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,14,0,0"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
              <StackPanel Spacing="10">
                <TextBlock Text="{Binding ActiveDocumentTab.Title}"
                           Foreground="{ThemeResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <Grid ColumnSpacing="12" RowSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <TextBlock Grid.Row="0" Grid.Column="0"
                             Text="{Binding Labels.InfoFileSize}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="0" Grid.Column="1"
                             Text="{Binding ActiveDocumentTab.FileSize}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />

                  <TextBlock Grid.Row="1" Grid.Column="0"
                             Text="{Binding Labels.InfoDimensions}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="1" Grid.Column="1"
                             Text="{Binding ActiveDocumentTab.Dimensions}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />

                  <TextBlock Grid.Row="2" Grid.Column="0"
                             Text="{Binding Labels.InfoPages}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="2" Grid.Column="1"
                             Text="{Binding ActiveDocumentTab.PageCountText}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />

                  <TextBlock Grid.Row="3" Grid.Column="0"
                             Text="{Binding Labels.InfoFormat}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="3" Grid.Column="1"
                             Text="{Binding ActiveDocumentTab.Format}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />

                  <TextBlock Grid.Row="4" Grid.Column="0"
                             Text="{Binding Labels.InfoAuthor}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="4" Grid.Column="1"
                             Text="{Binding ActiveDocumentTab.Author}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />

                  <TextBlock Grid.Row="5" Grid.Column="0"
                             Text="{Binding Labels.InfoCreated}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="5" Grid.Column="1"
                             Text="{Binding ActiveDocumentTab.CreatedDate}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />

                  <TextBlock Grid.Row="6" Grid.Column="0"
                             Text="{Binding Labels.InfoModified}"
                             Style="{StaticResource PanelLabelStyle}" />
                  <TextBlock Grid.Row="6" Grid.Column="1"
                             Text="{Binding ActiveDocumentTab.ModifiedDate}"
                             Foreground="{ThemeResource TextPrimaryBrush}" />
                </Grid>
              </StackPanel>
            </Border>
          </Grid>
        </Border>

        <Border Width="356"
                VerticalAlignment="Stretch"
                Background="{ThemeResource PanelDeepBrush}"
                BorderBrush="{ThemeResource PanelLineBrush}"
                BorderThickness="1,0,0,0"
                CornerRadius="0"
                Visibility="{Binding ActiveDocumentTab.IsSearchPanelOpen, Converter={StaticResource BoolToVisibility}}">
          <Grid Padding="18,14" RowSpacing="14">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="5">
              <TextBlock Text="{Binding Labels.Search}" Style="{StaticResource PanelTitleStyle}" />
              <TextBlock Text="{Binding Labels.SearchDescription}"
                         Foreground="{ThemeResource TextSecondaryBrush}"
                         FontSize="12"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,8"
                    Visibility="{Binding ActiveDocumentTab.HasSearchPanelNotice, Converter={StaticResource BoolToVisibility}}">
              <TextBlock Text="{Binding ActiveDocumentTab.SearchPanelNotice}"
                         Foreground="{ThemeResource TextSecondaryBrush}"
                         TextWrapping="Wrap" />
            </Border>

            <StackPanel Grid.Row="2" Spacing="8">
              <TextBlock Text="{Binding Labels.SearchQuery}"
                         Style="{StaticResource PanelLabelStyle}" />
              <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Height="38"
                        Background="{ThemeResource SearchBrush}"
                        BorderBrush="{ThemeResource InputBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE721;"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="{ThemeResource TextSecondaryBrush}"
                              Margin="12,0,8,0"
                              VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Background="Transparent"
                             BorderThickness="0"
                             PlaceholderText="{Binding Labels.SearchQueryPlaceholder}"
                             Text="{Binding ActiveDocumentTab.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="OnSearchBoxKeyDown" />
                  </Grid>
                </Border>

                <Button Grid.Column="1"
                        Height="38"
                        MinWidth="78"
                        Content="{Binding Labels.Search}"
                        Command="{Binding SearchTextCommand}" />
              </Grid>
            </StackPanel>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        Spacing="8">
              <Button Content="{Binding Labels.SearchRecognize}"
                      Command="{Binding RunSearchOcrCommand}"
                      Visibility="{Binding ActiveDocumentTab.RequiresSearchOcr, Converter={StaticResource BoolToVisibility}}" />
              <ProgressRing Width="24"
                            Height="24"
                            IsActive="{Binding ActiveDocumentTab.IsAnalyzingDocumentText}"
                            Visibility="{Binding ActiveDocumentTab.IsAnalyzingDocumentText, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>

            <Border Grid.Row="4"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{ThemeResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10"
                    Visibility="{Binding ActiveDocumentTab.HasSearchResults, Converter={StaticResource BoolToVisibility}}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Text="{Binding ActiveDocumentTab.SearchResultSummary}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             FontWeight="SemiBold" />
                  <TextBlock Text="{Binding ActiveDocumentTab.SearchSelectionIndicator}"
                             Foreground="{ThemeResource TextSecondaryBrush}"
                             FontSize="12" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                  <Button Width="32"
                          Height="32"
                          Padding="0"
                          Command="{Binding PreviousSearchResultCommand}"
                          ToolTipService.ToolTip="{Binding Labels.SearchPreviousResult}"
                          AutomationProperties.Name="{Binding Labels.SearchPreviousResult}">
                    <FontIcon Glyph="&#xE70E;" FontFamily="Segoe Fluent Icons" FontSize="11" />
                  </Button>
                  <Button Width="32"
                          Height="32"
                          Padding="0"
                          Command="{Binding NextSearchResultCommand}"
                          ToolTipService.ToolTip="{Binding Labels.SearchNextResult}"
                          AutomationProperties.Name="{Binding Labels.SearchNextResult}">
                    <FontIcon Glyph="&#xE70D;" FontFamily="Segoe Fluent Icons" FontSize="11" />
                  </Button>
                </StackPanel>
              </Grid>
            </Border>

            <ListView Grid.Row="5"
                      ItemsSource="{Binding ActiveDocumentTab.SearchResults}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      SelectionChanged="OnSearchResultSelectionChanged"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ActiveDocumentTab.HasSearchResults, Converter={StaticResource BoolToVisibility}}">
              <ListView.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{ThemeResource CardBrush}"
                            BorderBrush="{ThemeResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,8">
                      <StackPanel Spacing="5">
                        <TextBlock Text="{Binding PageLabel}"
                                   Foreground="{ThemeResource PanelLabelBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Excerpt}"
                                   Foreground="{ThemeResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>
          </Grid>
        </Border>

      </Grid>
    </Grid>

    <Border Grid.Row="4"
            Background="{ThemeResource TitleBarBgBrush}"
            BorderBrush="{ThemeResource PanelLineBrush}"
            BorderThickness="0,1,0,0"
            Padding="12,4">
      <TextBlock Text="{Binding StatusText, Mode=OneWay}"
                 Foreground="{ThemeResource TextSecondaryBrush}"
                 FontSize="12"
                 VerticalAlignment="Center"
                 TextTrimming="CharacterEllipsis" />
    </Border>

  </Grid>
</Window>
