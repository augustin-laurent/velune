<Window
    x:Class="Velune.Presentation.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="1200"
    Height="800"
    MinWidth="900"
    MinHeight="600"
    Title="{Binding Title}">

  <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="260,*">

    <!-- Header -->
    <Border Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="16,12"
            BorderBrush="#22000000"
            BorderThickness="0,0,0,1">
      <DockPanel LastChildFill="False">
        <TextBlock Text="{Binding ApplicationTitle}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />

        <StackPanel Orientation="Horizontal"
                    Spacing="8"
                    DockPanel.Dock="Right">
          <Button Content="Open" />
          <Button Content="Zoom In" />
          <Button Content="Zoom Out" />
          <Button Content="Rotate Left" />
          <Button Content="Rotate Right" />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Sidebar -->
    <Border Grid.Row="1"
            Grid.Column="0"
            Padding="12"
            BorderBrush="#22000000"
            BorderThickness="0,0,1,0">
      <StackPanel Spacing="8">
        <TextBlock Text="{Binding SidebarTitle}"
                   FontSize="16"
                   FontWeight="SemiBold" />

        <Border Padding="12"
                CornerRadius="8"
                Background="#11000000">
          <TextBlock Text="Thumbnails will appear here." />
        </Border>
      </StackPanel>
    </Border>

    <!-- Main content -->
    <Border Grid.Row="1"
            Grid.Column="1"
            Padding="24">
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="12">
        <TextBlock Text="{Binding EmptyStateTitle}"
                   FontSize="28"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center" />

        <TextBlock Text="{Binding EmptyStateDescription}"
                   FontSize="15"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />

        <Button Content="Open a file"
                HorizontalAlignment="Center"
                Width="140" />
      </StackPanel>
    </Border>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="12,8"
            BorderBrush="#22000000"
            BorderThickness="0,1,0,0">
      <TextBlock Text="{Binding StatusText}" />
    </Border>
  </Grid>
</Window>
