<Window
    x:Class="Velune.Presentation.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="1280"
    Height="860"
    MinWidth="1000"
    MinHeight="700"
    Title="{Binding Title}">

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenCommand}" />
    <KeyBinding Gesture="Meta+O" Command="{Binding OpenCommand}" />
    <KeyBinding Gesture="Ctrl+Add" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Ctrl+OemPlus" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Meta+Add" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Meta+OemPlus" Command="{Binding ZoomInCommand}" />
    <KeyBinding Gesture="Ctrl+Subtract" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Ctrl+OemMinus" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Meta+Subtract" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Meta+OemMinus" Command="{Binding ZoomOutCommand}" />
    <KeyBinding Gesture="Right" Command="{Binding NextPageCommand}" />
    <KeyBinding Gesture="Left" Command="{Binding PreviousPageCommand}" />
    <KeyBinding Gesture="PageDown" Command="{Binding NextPageCommand}" />
    <KeyBinding Gesture="PageUp" Command="{Binding PreviousPageCommand}" />
  </Window.KeyBindings>

  <Grid RowDefinitions="Auto,*,Auto">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="{Binding SidebarColumnWidth}" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Header -->
    <Border Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="16,12"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,0,1"
            Background="{DynamicResource Brush.Surface}">
      <DockPanel LastChildFill="False">
        <TextBlock Text="{Binding HeaderTitle}"
                   Classes="title"
                   VerticalAlignment="Center" />

        <StackPanel Orientation="Horizontal"
                    Spacing="8"
                    DockPanel.Dock="Right">
          <Button Content="Open" Command="{Binding OpenCommand}" />
          <Button Content="Close" Command="{Binding CloseCommand}" />
          <Button Content="Prev" Command="{Binding PreviousPageCommand}" />
          <Button Content="Next" Command="{Binding NextPageCommand}" />

          <TextBox Width="72"
                   Watermark="Page"
                   Text="{Binding GoToPageInput}" />

          <Button Content="Go"
                  Command="{Binding GoToPageCommand}" />

          <Button Content="Zoom In" Command="{Binding ZoomInCommand}" />
          <Button Content="Zoom Out" Command="{Binding ZoomOutCommand}" />
          <Button Content="Fit Width" Command="{Binding FitToWidthCommand}" />
          <Button Content="Fit Page" Command="{Binding FitToPageCommand}" />
          <Button Content="Rotate Left" Command="{Binding RotateLeftCommand}" />
          <Button Content="Rotate Right" Command="{Binding RotateRightCommand}" />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Sidebar -->
    <Border Grid.Row="1"
            Grid.Column="0"
            Width="{Binding SidebarWidth}"
            Padding="12"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,1,0"
            Background="{DynamicResource Brush.Surface}"
            IsVisible="{Binding IsSidebarVisible}">
      <Grid RowDefinitions="Auto,*">
        <DockPanel Grid.Row="0"
                   LastChildFill="False"
                   Margin="0,0,0,10">
          <TextBlock Text="Pages"
                     Classes="title"
                     VerticalAlignment="Center" />

          <TextBlock Text="Loading..."
                     Classes="muted"
                     DockPanel.Dock="Right"
                     IsVisible="{Binding IsGeneratingThumbnails}" />
        </DockPanel>

        <ScrollViewer Grid.Row="1"
                      Width="216"
                      MaxWidth="216"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Thumbnails}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Classes="thumbnail-button"
                        Command="{Binding $parent[Window].DataContext.SelectThumbnailCommand}"
                        CommandParameter="{Binding}"
                        HorizontalContentAlignment="Stretch">
                  <Border Classes="thumbnail-item"
                          Width="200"
                          MaxWidth="200"
                          MinHeight="120">
                    <StackPanel Spacing="8">
                      <Border Classes="thumbnail-image-host"
                              Width="180"
                              MaxWidth="180"
                              Height="160"
                              HorizontalAlignment="Center">
                        <Grid>
                          <Image Source="{Binding Thumbnail}"
                                 Stretch="Uniform"
                                 MaxWidth="170"
                                 MaxHeight="150"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                          <TextBlock Text="Loading..."
                                     Classes="muted"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding IsLoading}" />
                        </Grid>
                      </Border>

                      <StackPanel Orientation="Horizontal"
                                  HorizontalAlignment="Center"
                                  Spacing="6">
                        <TextBlock Text="{Binding PageNumber, StringFormat=Page {0}}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="●"
                                   Foreground="{DynamicResource Brush.Accent}"
                                   IsVisible="{Binding IsSelected}" />
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Main content -->
    <Grid Grid.Row="1"
          Grid.Column="1"
          Background="{DynamicResource Brush.Background}">

      <!-- Toast -->
      <Border Classes="banner"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="16"
              Padding="12,10"
              MinWidth="320"
              MaxWidth="420"
              ZIndex="10"
              IsVisible="{Binding HasUserMessage}">
        <DockPanel LastChildFill="True">
          <Button Content="Dismiss"
                  DockPanel.Dock="Right"
                  Command="{Binding DismissMessageCommand}" />

          <TextBlock Text="{Binding UserMessage}"
                     Classes="muted"
                     VerticalAlignment="Center"
                     Margin="0,0,12,0"
                     TextWrapping="Wrap" />
        </DockPanel>
      </Border>

      <!-- Empty state -->
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="16"
                  MaxWidth="520"
                  IsVisible="{Binding IsEmptyStateVisible}">
        <Border Classes="card"
                Padding="20"
                HorizontalAlignment="Center">
          <TextBlock Text="📄"
                     FontSize="40"
                     HorizontalAlignment="Center" />
        </Border>

        <TextBlock Text="{Binding EmptyStateTitle}"
                   Classes="hero"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />

        <TextBlock Text="{Binding EmptyStateDescription}"
                   Classes="muted"
                   FontSize="{DynamicResource FontSize.BodyLarge}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8">
          <Button Content="Open a file"
                  Width="140"
                  Command="{Binding OpenCommand}" />
          <Button Content="Simulate error"
                  Width="140"
                  Command="{Binding SimulateErrorCommand}" />
        </StackPanel>

        <Border Classes="card"
                Padding="16"
                Margin="0,12,0,0"
                IsVisible="{Binding HasRecentFiles}">
          <StackPanel Spacing="10">
            <DockPanel LastChildFill="False">
              <TextBlock Text="Recent files"
                         Classes="title"
                         VerticalAlignment="Center" />

              <Button Content="Clear"
                      DockPanel.Dock="Right"
                      Command="{Binding ClearRecentFilesCommand}" />
            </DockPanel>

            <ItemsControl ItemsSource="{Binding RecentFiles}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Classes="recent-file-button"
                          Command="{Binding $parent[Window].DataContext.OpenRecentFileCommand}"
                          CommandParameter="{Binding}"
                          HorizontalContentAlignment="Stretch">
                    <Border Classes="recent-file-item">
                      <StackPanel>
                        <TextBlock Text="{Binding FileName}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding DocumentType}"
                                   Classes="muted" />
                        <TextBlock Text="{Binding FilePath}"
                                   Classes="muted"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- Viewer -->
      <Grid Margin="24"
            IsVisible="{Binding HasOpenDocument}">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Grid.Row="0"
                      Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      Spacing="12"
                      Margin="12,0,12,8">
            <TextBlock Text="{Binding PageIndicator}" Classes="muted" />
            <TextBlock Text="{Binding CurrentZoom}" Classes="muted" />
            <TextBlock Text="{Binding CurrentRotation}" Classes="muted" />
          </StackPanel>

          <Grid Grid.Row="1"
                Margin="12"
                SizeChanged="OnDocumentViewerSizeChanged">
            <Grid IsVisible="{Binding IsImageAutoFitActive}">
              <Image Source="{Binding CurrentRenderedBitmap}"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
            </Grid>

            <ScrollViewer x:Name="DocumentScrollViewer"
                          IsVisible="{Binding IsScrollableViewerVisible}"
                          PointerWheelChanged="OnDocumentPointerWheelChanged"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
              <Image Source="{Binding CurrentRenderedBitmap}"
                     Stretch="None"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top" />
            </ScrollViewer>

            <Border Classes="banner"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="12,10"
                    IsVisible="{Binding IsRendering}">
              <TextBlock Text="Rendering..."
                         Classes="muted" />
            </Border>
          </Grid>
        </Grid>
      </Grid>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Padding="12,8"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,1,0,0"
            Background="{DynamicResource Brush.Surface}">
      <TextBlock Text="{Binding StatusText}"
                 Classes="muted" />
    </Border>
  </Grid>
</Window>
